@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.FluentUI.AspNetCore.Components
@using Cdm.Web.Services.State
@rendermode InteractiveServer

<AuthorizeView>
    <Authorized>
        <div style="position: relative; display: inline-flex;" @onclick:stopPropagation>
            <FluentButton Id="user-menu-btn" Appearance="Appearance.Stealth" OnClick="ToggleDropdown"
                          Title="@context.User.Identity?.Name">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                    <FluentPersona Name="@context.User.Identity?.Name"
                                   Initials="@GetInitials(context)"
                                   Size="28px" />
                    <FluentIcon Value="@(new Icons.Regular.Size12.ChevronDown())" />
                </FluentStack>
            </FluentButton>

            @if (_isOpen)
            {
                <FluentCard Style="position: absolute; top: calc(100% + 4px); right: 0; min-width: 220px; z-index: 10500; padding: 8px 0;">
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0; width: 100%;">
                        <!-- User info -->
                        <FluentStack Orientation="Orientation.Vertical" Style="padding: 12px 16px; gap: 2px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@context.User.Identity?.Name</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Style="opacity: 0.6; font-size: 12px;">@GetUserEmail(context)</FluentLabel>
                        </FluentStack>

                        <FluentDivider Style="width: 100%;" />

                        <!-- Menu items -->
                        <FluentAnchor Href="/profile" Appearance="Appearance.Stealth" Style="width: 100%; justify-content: flex-start;">
                            <FluentIcon Value="@(new Icons.Regular.Size16.Person())" Slot="start" />
                            Mon Profil
                        </FluentAnchor>
                        <FluentAnchor Href="/settings" Appearance="Appearance.Stealth" Style="width: 100%; justify-content: flex-start;">
                            <FluentIcon Value="@(new Icons.Regular.Size16.Settings())" Slot="start" />
                            Paramètres
                        </FluentAnchor>

                        <FluentDivider Style="width: 100%;" />

                        <FluentButton Appearance="Appearance.Stealth" OnClick="HandleLogout"
                                      Style="width: 100%; justify-content: flex-start; color: var(--color-error-500);">
                            <FluentIcon Value="@(new Icons.Regular.Size16.ArrowExit())" Slot="start" Color="Color.Error" />
                            Déconnexion
                        </FluentButton>
                    </FluentStack>
                </FluentCard>
            }
        </div>

        @if (_isOpen)
        {
            <div style="position: fixed; inset: 0; z-index: 10499;" @onclick="CloseDropdown"></div>
        }
    </Authorized>
    <NotAuthorized>
        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 8px;">
            <FluentAnchor Href="/login" Appearance="Appearance.Outline">Connexion</FluentAnchor>
            <FluentAnchor Href="/register" Appearance="Appearance.Accent">Inscription</FluentAnchor>
        </FluentStack>
    </NotAuthorized>
</AuthorizeView>
