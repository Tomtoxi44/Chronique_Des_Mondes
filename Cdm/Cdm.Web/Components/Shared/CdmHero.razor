@* Hero immersif : cadre « signature » selon le type de jeu (défini dans themes.css
   via .theme-X .cdm-hero) + ornements d'angle décoratifs. À placer À L'INTÉRIEUR
   d'un AppThemeWrapper. Contenu libre (badge, titre, tagline, méta, actions)
   via les classes .cdm-hero-badge / .cdm-hero-title / .cdm-hero-tagline / .cdm-hero-meta. *@
@using Cdm.Common.Enums

<div class="cdm-hero @Class">
    @switch (Corner)
    {
        case "ornate":
            <span class="cdm-hero-deco cdm-hero-deco--ornate" style="top:7px;left:13px;">&#10087;</span>
            <span class="cdm-hero-deco cdm-hero-deco--ornate" style="top:7px;right:13px;transform:scaleX(-1);">&#10087;</span>
            <span class="cdm-hero-deco cdm-hero-deco--ornate" style="bottom:7px;left:13px;transform:scaleY(-1);">&#10087;</span>
            <span class="cdm-hero-deco cdm-hero-deco--ornate" style="bottom:7px;right:13px;transform:scale(-1,-1);">&#10087;</span>
            break;
        case "brackets":
            <span class="cdm-hero-deco cdm-hero-deco--bracket" style="top:12px;left:14px;border-top:2px solid var(--theme-primary);border-left:2px solid var(--theme-primary);"></span>
            <span class="cdm-hero-deco cdm-hero-deco--bracket" style="top:12px;right:14px;border-top:2px solid var(--theme-primary);border-right:2px solid var(--theme-primary);"></span>
            <span class="cdm-hero-deco cdm-hero-deco--bracket" style="bottom:12px;left:14px;border-bottom:2px solid var(--theme-primary);border-left:2px solid var(--theme-primary);"></span>
            <span class="cdm-hero-deco cdm-hero-deco--bracket" style="bottom:12px;right:14px;border-bottom:2px solid var(--theme-primary);border-right:2px solid var(--theme-primary);"></span>
            break;
        case "rivet":
            <span class="cdm-hero-deco cdm-hero-deco--rivet" style="top:11px;left:13px;"></span>
            <span class="cdm-hero-deco cdm-hero-deco--rivet" style="top:11px;right:13px;"></span>
            <span class="cdm-hero-deco cdm-hero-deco--rivet" style="bottom:11px;left:13px;"></span>
            <span class="cdm-hero-deco cdm-hero-deco--rivet" style="bottom:11px;right:13px;"></span>
            break;
        case "occult":
            <span class="cdm-hero-deco cdm-hero-deco--sigil">&#10039;</span>
            break;
    }
    @ChildContent
</div>

@code {
    [Parameter] public GameType GameType { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string Corner => GameType switch
    {
        GameType.DnD5e => "ornate",
        GameType.Cyberpunk => "brackets",
        GameType.Warhammer => "rivet",
        GameType.CallOfCthulhu => "occult",
        _ => "none"
    };
}
