@using Microsoft.AspNetCore.Components.Forms

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <InputFile OnChange="HandleFileSelectedAsync" 
               accept=".jpg,.jpeg,.png,.webp" 
               style="display: none;" 
               id="@inputId" />
    
    <FluentButton Appearance="Appearance.Outline" 
                  IconStart="@(new Icons.Regular.Size20.ArrowUpload())"
                  OnClick="@(() => { })">
        <label for="@inputId" style="cursor: pointer; margin: 0;">
            Choisir une image
        </label>
    </FluentButton>
    
    @if (!string.IsNullOrEmpty(this.errorMessage))
    {
        <FluentMessageBar Title="Erreur" Intent="@MessageIntent.Error" AllowDismiss="true" OnDismiss="@(() => this.errorMessage = null)">
            @this.errorMessage
        </FluentMessageBar>
    }
    
    @if (!string.IsNullOrEmpty(this.previewUrl))
    {
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" VerticalAlignment="VerticalAlignment.Center">
            <img src="@this.previewUrl" alt="Preview" style="max-width: 300px; max-height: 200px; border-radius: 4px; border: 1px solid var(--neutral-stroke-rest);" />
            <FluentButton Appearance="Appearance.Outline" 
                          IconStart="@(new Icons.Regular.Size20.Delete())"
                          OnClick="ClearImage">
                Supprimer
            </FluentButton>
        </FluentStack>
    }
    
    <FluentLabel Typo="Typography.Body" Style="font-size: 12px; color: var(--neutral-foreground-hint);">
        Formats acceptes: JPG, PNG, WebP. Taille maximale: 5 MB
    </FluentLabel>
</FluentStack>

@code {
    /// <summary>
    /// Event callback when an image is selected and converted to Base64.
    /// </summary>
    [Parameter]
    public EventCallback<string?> OnImageSelected { get; set; }

    /// <summary>
    /// Optional unique ID for the input element.
    /// </summary>
    [Parameter]
    public string InputId { get; set; } = "imageInput";

    private string? errorMessage;
    private string? previewUrl;
    private string? base64Image;
    private string inputId => this.InputId;

    /// <summary>
    /// Handles file selection and converts to Base64.
    /// </summary>
    /// <param name="e">The input file change event arguments.</param>
    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs e)
    {
        this.errorMessage = null;
        this.previewUrl = null;
        this.base64Image = null;

        var file = e.File;

        // Validate file type
        var allowedTypes = new[] { "image/jpeg", "image/jpg", "image/png", "image/webp" };
        if (!allowedTypes.Contains(file.ContentType.ToLowerInvariant()))
        {
            this.errorMessage = "Format de fichier non valide. Utilisez JPG, PNG ou WebP.";
            return;
        }

        // Validate file size (5 MB max)
        const long maxFileSize = 5 * 1024 * 1024; // 5 MB
        if (file.Size > maxFileSize)
        {
            this.errorMessage = "Le fichier est trop volumineux. Taille maximale: 5 MB.";
            return;
        }

        try
        {
            // Read file as Base64
            using var stream = file.OpenReadStream(maxFileSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var imageBytes = memoryStream.ToArray();
            this.base64Image = Convert.ToBase64String(imageBytes);

            // Create preview URL
            this.previewUrl = $"data:{file.ContentType};base64,{this.base64Image}";

            // Notify parent component
            await this.OnImageSelected.InvokeAsync(this.base64Image);
        }
        catch (Exception ex)
        {
            this.errorMessage = $"Erreur lors du chargement de l'image: {ex.Message}";
        }
    }

    /// <summary>
    /// Clears the selected image.
    /// </summary>
    private async Task ClearImage()
    {
        this.previewUrl = null;
        this.base64Image = null;
        this.errorMessage = null;
        await this.OnImageSelected.InvokeAsync(null);
    }
}
