@* Titre de section « codex » : petit label en capitales espacées, icône accent
   et filet inférieur. Réutilise .section-eyebrow (voir components.css).
   Utiliser pour les en-têtes de section À L'INTÉRIEUR d'une carte — pas pour
   les noms d'entité (campagne, session…), qui gardent .card-title (serif). *@

<h3 class="section-eyebrow">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <i class="bi @Icon"></i>
    }
    @Title
    @if (Actions is not null)
    {
        <span class="eyebrow-actions">@Actions</span>
    }
</h3>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Icon { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
