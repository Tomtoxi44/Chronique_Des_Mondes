@using Cdm.Business.Abstraction.DTOs
@using Cdm.Web.Services.ApiClients
@using Cdm.Common.Enums
@using Microsoft.FluentUI.AspNetCore.Components
@inject NotificationApiClient NotificationClient
@inject NavigationManager NavigationManager

<div style="position: relative; display: inline-flex;" @onclick:stopPropagation>
    <FluentButton Appearance="Appearance.Stealth" OnClick="TogglePanel" Title="Notifications">
        @if (unreadCount > 0)
        {
            <FluentIcon Value="@(new Icons.Filled.Size20.Alert())" />
        }
        else
        {
            <FluentIcon Value="@(new Icons.Regular.Size20.Alert())" />
        }
        @if (unreadCount > 0)
        {
            <FluentBadge Appearance="Appearance.Accent"
                         Style="position: absolute; top: -4px; right: -4px; min-width: 18px; height: 18px; font-size: 10px; padding: 0 4px;">
                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
            </FluentBadge>
        }
    </FluentButton>

    @if (isOpen)
    {
        <FluentCard Style="position: absolute; top: calc(100% + 8px); right: 0; width: 380px; max-height: 480px; z-index: 9999; display: flex; flex-direction: column; overflow: hidden;">
            <!-- Header -->
            <FluentStack Orientation="Orientation.Horizontal"
                         VerticalAlignment="VerticalAlignment.Center"
                         HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                         Style="padding: 12px 16px; border-bottom: 1px solid var(--neutral-stroke-divider-rest);">
                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Notifications</FluentLabel>
                @if (unreadCount > 0)
                {
                    <FluentButton Appearance="Appearance.Stealth" OnClick="MarkAllAsRead" Disabled="@isLoading"
                                  Style="font-size: 12px;">
                        Tout marquer comme lu
                    </FluentButton>
                }
            </FluentStack>

            <!-- List -->
            <div style="overflow-y: auto; flex: 1;">
                @if (isLoading)
                {
                    <FluentStack Orientation="Orientation.Vertical"
                                 HorizontalAlignment="HorizontalAlignment.Center"
                                 VerticalAlignment="VerticalAlignment.Center"
                                 Style="padding: 40px 16px; gap: 8px;">
                        <FluentProgress />
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.6; font-size: 12px;">Chargement...</FluentLabel>
                    </FluentStack>
                }
                else if (!notifications.Any())
                {
                    <FluentStack Orientation="Orientation.Vertical"
                                 HorizontalAlignment="HorizontalAlignment.Center"
                                 VerticalAlignment="VerticalAlignment.Center"
                                 Style="padding: 40px 16px; gap: 8px;">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Neutral" Style="opacity: 0.4;" />
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.6; font-size: 12px;">Aucune notification</FluentLabel>
                    </FluentStack>
                }
                else
                {
                    @foreach (var notif in notifications)
                    {
                        <div class="notif-item @(notif.IsRead ? "" : "unread")" @onclick="() => OnNotificationClick(notif)">
                            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px; padding: 12px 16px; align-items: flex-start;">
                                @GetNotifIconFragment(notif.Type)
                                <FluentStack Orientation="Orientation.Vertical" Style="flex: 1; min-width: 0; gap: 2px;">
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                        @notif.Title
                                    </FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @notif.Message
                                    </FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.5; font-size: 11px;">
                                        @GetRelativeTime(notif.CreatedAt)
                                    </FluentLabel>
                                </FluentStack>
                                <FluentButton Appearance="Appearance.Stealth" class="notif-delete"
                                              OnClick="@(() => DeleteNotification(notif.Id))"
                                              Title="Supprimer"
                                              IconStart="@(new Icons.Regular.Size16.Dismiss())" />
                            </FluentStack>
                        </div>
                    }
                }
            </div>
        </FluentCard>
    }
</div>

@if (isOpen)
{
    <div style="position: fixed; inset: 0; z-index: 9998;" @onclick="ClosePanel"></div>
}

<style>
    .notif-item {
        cursor: pointer;
        transition: background 0.15s;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest, rgba(255,255,255,0.08));
        position: relative;
    }
    .notif-item:last-child { border-bottom: none; }
    .notif-item:hover { background: var(--neutral-fill-stealth-hover, rgba(255,255,255,0.04)); }
    .notif-item.unread { background: var(--accent-fill-rest, rgba(99,102,241,0.06)); opacity: 1; }
    .notif-item.unread::before {
        content: '';
        position: absolute; left: 0; top: 0; bottom: 0;
        width: 3px;
        background: var(--accent-fill-rest);
        border-radius: 0 2px 2px 0;
    }
    .notif-delete { opacity: 0; transition: opacity 0.15s; }
    .notif-item:hover .notif-delete { opacity: 1; }
</style>

@code {
    private bool isOpen = false;
    private bool isLoading = false;
    private List<NotificationDto> notifications = new();
    private int unreadCount = 0;
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadUnreadCount();
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                unreadCount = await NotificationClient.GetUnreadCountAsync();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    private async Task LoadUnreadCount()
    {
        unreadCount = await NotificationClient.GetUnreadCountAsync();
    }

    private async Task TogglePanel()
    {
        isOpen = !isOpen;
        if (isOpen)
        {
            isLoading = true;
            notifications = await NotificationClient.GetNotificationsAsync();
            unreadCount = notifications.Count(n => !n.IsRead);
            isLoading = false;
        }
    }

    private void ClosePanel() => isOpen = false;

    private async Task OnNotificationClick(NotificationDto notif)
    {
        if (!notif.IsRead)
        {
            await NotificationClient.MarkAsReadAsync(notif.Id);
            notif.IsRead = true;
            unreadCount = Math.Max(0, unreadCount - 1);
        }
        if (!string.IsNullOrEmpty(notif.ActionUrl))
        {
            isOpen = false;
            NavigationManager.NavigateTo(notif.ActionUrl);
        }
    }

    private async Task MarkAllAsRead()
    {
        await NotificationClient.MarkAllAsReadAsync();
        foreach (var n in notifications) n.IsRead = true;
        unreadCount = 0;
    }

    private async Task DeleteNotification(int id)
    {
        await NotificationClient.DeleteNotificationAsync(id);
        notifications.RemoveAll(n => n.Id == id);
        unreadCount = notifications.Count(n => !n.IsRead);
    }

    private RenderFragment GetNotifIconFragment(NotificationType type) => type switch
    {
        NotificationType.CampaignInvite => @<FluentIcon Value="@(new Icons.Regular.Size20.Map())" Color="Color.Success" Style="flex-shrink: 0; margin-top: 2px;" />,
        NotificationType.AchievementUnlocked => @<FluentIcon Value="@(new Icons.Regular.Size20.Trophy())" Color="Color.Warning" Style="flex-shrink: 0; margin-top: 2px;" />,
        NotificationType.SessionStarting => @<FluentIcon Value="@(new Icons.Regular.Size20.Play())" Color="Color.Info" Style="flex-shrink: 0; margin-top: 2px;" />,
        NotificationType.TradeProposed => @<FluentIcon Value="@(new Icons.Regular.Size20.ArrowSwap())" Color="Color.Neutral" Style="flex-shrink: 0; margin-top: 2px;" />,
        NotificationType.MessageMention => @<FluentIcon Value="@(new Icons.Regular.Size20.Chat())" Color="Color.Neutral" Style="flex-shrink: 0; margin-top: 2px;" />,
        NotificationType.SystemAnnouncement => @<FluentIcon Value="@(new Icons.Regular.Size20.Info())" Color="Color.Info" Style="flex-shrink: 0; margin-top: 2px;" />,
        NotificationType.CharacterUpdate => @<FluentIcon Value="@(new Icons.Regular.Size20.Person())" Color="Color.Neutral" Style="flex-shrink: 0; margin-top: 2px;" />,
        _ => @<FluentIcon Value="@(new Icons.Regular.Size20.Alert())" Color="Color.Neutral" Style="flex-shrink: 0; margin-top: 2px;" />
    };

    private Color GetNotifColor(NotificationType type) => type switch
    {
        NotificationType.CampaignInvite => Color.Success,
        NotificationType.AchievementUnlocked => Color.Warning,
        NotificationType.SessionStarting or NotificationType.CombatTurn => Color.Info,
        _ => Color.Neutral
    };

    private string GetRelativeTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 1) return "À l'instant";
        if (diff.TotalHours < 1) return $"Il y a {(int)diff.TotalMinutes} min";
        if (diff.TotalDays < 1) return $"Il y a {(int)diff.TotalHours} h";
        if (diff.TotalDays < 7) return $"Il y a {(int)diff.TotalDays} j";
        return dt.ToString("dd/MM/yyyy");
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
