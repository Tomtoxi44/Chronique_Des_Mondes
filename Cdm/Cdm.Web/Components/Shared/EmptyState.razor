@* EmptyState — Elegant empty state with icon, message and optional CTA *@

<div class="cdm-empty-state">
    <div class="cdm-empty-icon">@Icon</div>
    <FluentLabel Typo="Typography.H5" Class="cdm-empty-title">@Title</FluentLabel>
    @if (!string.IsNullOrEmpty(Message))
    {
        <FluentLabel Typo="Typography.Body" Class="cdm-empty-message">@Message</FluentLabel>
    }
    @if (Action != null)
    {
        <div class="cdm-empty-action">
            @Action
        </div>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = "📭";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Message { get; set; }
    [Parameter] public RenderFragment? Action { get; set; }
}
