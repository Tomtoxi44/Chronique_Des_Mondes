@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using Cdm.Web.Services.ApiClients
@inject IStringLocalizer<AppStrings> L
@inject NavigationManager NavigationManager

<PageTitle>@L["Nav_Home"] — @L["AppName"]</PageTitle>

<AuthorizeView>
    <Authorized>
        <PageHeader Title="@string.Format(L["Home_Welcome"], context.User.Identity?.Name ?? L["Home_WelcomeDefault"])"
                    Subtitle="@L["Home_Subtitle"]" />

        <!-- Stats -->
        <div class="cdm-grid-stats" style="margin-bottom: var(--spacing-xl);">
            <StatCard Icon="🌍" Value="@worldCount.ToString()" Label="@L["Home_Stats_Worlds"]" />
            <StatCard Icon="⚔️" Value="@characterCount.ToString()" Label="@L["Home_Stats_Characters"]" />
            <StatCard Icon="📜" Value="@campaignCount.ToString()" Label="@L["Home_Stats_Campaigns"]" />
        </div>

        <!-- Quick Actions -->
        <div class="cdm-section">
            <FluentLabel Typo="Typography.H5" Class="cdm-section-title">@L["Home_QuickActions"]</FluentLabel>
            <div class="cdm-grid-actions">
                <a href="/worlds/create" class="cdm-action-card">
                    <span class="cdm-action-card-icon">🌍</span>
                    <span class="cdm-action-card-text">@L["Home_CreateWorld"]</span>
                </a>
                <a href="/characters/create" class="cdm-action-card">
                    <span class="cdm-action-card-icon">⚔️</span>
                    <span class="cdm-action-card-text">@L["Home_CreateCharacter"]</span>
                </a>
                <a href="/campaigns" class="cdm-action-card">
                    <span class="cdm-action-card-icon">📜</span>
                    <span class="cdm-action-card-text">@L["Home_ViewCampaigns"]</span>
                </a>
            </div>
        </div>
    </Authorized>
    
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private int worldCount = 0;
    private int characterCount = 0;
    private int campaignCount = 0;

    [Inject] private WorldApiClient WorldApi { get; set; } = default!;
    [Inject] private CharacterApiClient CharacterApi { get; set; } = default!;
    [Inject] private CampaignApiClient CampaignApi { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var worlds = await WorldApi.GetMyWorldsAsync();
            worldCount = worlds?.Count() ?? 0;
        }
        catch { /* graceful fallback */ }

        try
        {
            var characters = await CharacterApi.GetMyCharactersAsync();
            characterCount = characters?.Count() ?? 0;
        }
        catch { }

        try
        {
            var campaigns = await CampaignApi.GetMyCampaignsAsync();
            campaignCount = campaigns?.Count() ?? 0;
        }
        catch { }
    }
}
