@page "/"
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@layout MainLayout

<PageTitle>Accueil - Chronique des Mondes</PageTitle>

<AuthorizeView>
    <Authorized>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 24px;">
            <!-- Hero Welcome -->
            <FluentCard>
                <FluentStack Orientation="Orientation.Horizontal" 
                             VerticalAlignment="VerticalAlignment.Center"
                             HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                             Wrap="true"
                             Style="padding: 24px; gap: 16px;">
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                        <FluentLabel Typo="Typography.H3">
                            Bienvenue, @context.User.Identity?.Name !
                        </FluentLabel>
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.8;">
                            Pret pour votre prochaine aventure epique ?
                        </FluentLabel>
                    </FluentStack>
                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 12px;" Wrap="true">
                        <FluentButton Appearance="Appearance.Accent" 
                                      IconStart="@(new Icons.Regular.Size20.Add())"
                                      Href="/campaigns/create">
                            Nouvelle Campagne
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Outline" 
                                      IconStart="@(new Icons.Regular.Size20.PersonAdd())"
                                      Href="/characters/create">
                            Nouveau Personnage
                        </FluentButton>
                    </FluentStack>
                </FluentStack>
            </FluentCard>

            <!-- Stats Cards -->
            <FluentGrid Spacing="3" Justify="JustifyContent.FlexStart">
                <FluentGridItem xs="12" sm="6" md="3">
                    <FluentCard Style="height: 100%;">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 16px;">
                            <FluentIcon Value="@(new Icons.Regular.Size28.People())" Color="Color.Accent" />
                            <FluentStack Orientation="Orientation.Vertical">
                                <FluentLabel Typo="Typography.H4">0</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Personnages</FluentLabel>
                            </FluentStack>
                        </FluentStack>
                    </FluentCard>
                </FluentGridItem>
                
                <FluentGridItem xs="12" sm="6" md="3">
                    <FluentCard Style="height: 100%;">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 16px;">
                            <FluentIcon Value="@(new Icons.Regular.Size28.BookOpen())" Color="Color.Error" />
                            <FluentStack Orientation="Orientation.Vertical">
                                <FluentLabel Typo="Typography.H4">0</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Campagnes</FluentLabel>
                            </FluentStack>
                        </FluentStack>
                    </FluentCard>
                </FluentGridItem>
                
                <FluentGridItem xs="12" sm="6" md="3">
                    <FluentCard Style="height: 100%;">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 16px;">
                            <FluentIcon Value="@(new Icons.Regular.Size28.Globe())" Color="Color.Warning" />
                            <FluentStack Orientation="Orientation.Vertical">
                                <FluentLabel Typo="Typography.H4">0</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Mondes</FluentLabel>
                            </FluentStack>
                        </FluentStack>
                    </FluentCard>
                </FluentGridItem>
                
                <FluentGridItem xs="12" sm="6" md="3">
                    <FluentCard Style="height: 100%;">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 16px;">
                            <FluentIcon Value="@(new Icons.Regular.Size28.Trophy())" Color="Color.Success" />
                            <FluentStack Orientation="Orientation.Vertical">
                                <FluentLabel Typo="Typography.H4">0</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Succes</FluentLabel>
                            </FluentStack>
                        </FluentStack>
                    </FluentCard>
                </FluentGridItem>
            </FluentGrid>

            <!-- Quick Actions -->
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Flash())" Color="Color.Accent" />
                        <FluentLabel Typo="Typography.H5">Actions Rapides</FluentLabel>
                    </FluentStack>
                    
                    <FluentGrid Spacing="3">
                        <FluentGridItem xs="12" sm="6" md="3">
                            <FluentCard Style="cursor: pointer; transition: all 0.2s;" @onclick='() => NavigateTo("/characters")'>
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Style="gap: 12px; padding: 16px;">
                                    <FluentIcon Value="@(new Icons.Regular.Size32.Person())" Color="Color.Accent" />
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Mes Personnages</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; text-align: center; font-size: 12px;">Creez et gerez vos heros</FluentLabel>
                                </FluentStack>
                            </FluentCard>
                        </FluentGridItem>
                        
                        <FluentGridItem xs="12" sm="6" md="3">
                            <FluentCard Style="cursor: pointer; transition: all 0.2s;" @onclick='() => NavigateTo("/campaigns")'>
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Style="gap: 12px; padding: 16px;">
                                    <FluentIcon Value="@(new Icons.Regular.Size32.Book())" Color="Color.Accent" />
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Mes Campagnes</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; text-align: center; font-size: 12px;">Explorez vos aventures</FluentLabel>
                                </FluentStack>
                            </FluentCard>
                        </FluentGridItem>
                        
                        <FluentGridItem xs="12" sm="6" md="3">
                            <FluentCard Style="cursor: pointer; transition: all 0.2s;" @onclick='() => NavigateTo("/worlds")'>
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Style="gap: 12px; padding: 16px;">
                                    <FluentIcon Value="@(new Icons.Regular.Size32.Globe())" Color="Color.Accent" />
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Mes Mondes</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; text-align: center; font-size: 12px;">Creez des univers</FluentLabel>
                                </FluentStack>
                            </FluentCard>
                        </FluentGridItem>
                        
                        <FluentGridItem xs="12" sm="6" md="3">
                            <FluentCard Style="cursor: pointer; transition: all 0.2s;" @onclick='() => NavigateTo("/dice")'>
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Style="gap: 12px; padding: 16px;">
                                    <FluentIcon Value="@(new Icons.Regular.Size32.Cube())" Color="Color.Accent" />
                                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Lanceur de Des</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; text-align: center; font-size: 12px;">Lancez les des du destin</FluentLabel>
                                </FluentStack>
                            </FluentCard>
                        </FluentGridItem>
                    </FluentGrid>
                </FluentStack>
            </FluentCard>

            <!-- Recent Activity -->
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.History())" Color="Color.Accent" />
                        <FluentLabel Typo="Typography.H5">Activite Recente</FluentLabel>
                    </FluentStack>
                    
                    <FluentStack Orientation="Orientation.Vertical" 
                                 HorizontalAlignment="HorizontalAlignment.Center"
                                 Style="padding: 48px; gap: 16px;">
                        <FluentIcon Value="@(new Icons.Regular.Size48.Clock())" Color="Color.Neutral" />
                        <FluentLabel Typo="Typography.H6">Aucune activite recente</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; text-align: center;">
                            Commencez par creer votre premier personnage ou rejoignez une campagne !
                        </FluentLabel>
                        <FluentButton Appearance="Appearance.Accent" 
                                      IconStart="@(new Icons.Regular.Size20.Add())"
                                      Href="/characters/create">
                            Creer un personnage
                        </FluentButton>
                    </FluentStack>
                </FluentStack>
            </FluentCard>
        </FluentStack>
    </Authorized>
    
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url);
    }
}
