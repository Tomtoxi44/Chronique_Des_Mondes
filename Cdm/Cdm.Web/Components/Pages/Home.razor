@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.FluentUI.AspNetCore.Components

<PageTitle>Accueil - Chronique des Mondes</PageTitle>

<AuthorizeView>
    <Authorized>
        <FluentStack Orientation="Orientation.Vertical"
                     HorizontalAlignment="HorizontalAlignment.Center"
                     Style="padding: 4rem 2rem; max-width: 1200px; margin: 0 auto; text-align: center;">
            <FluentLabel Typo="Typography.PageTitle" Style="margin-bottom: 1rem;">
                Bienvenue, @context.User.Identity?.Name !
            </FluentLabel>
            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">
                Votre aventure commence ici.
            </FluentLabel>
        </FluentStack>
    </Authorized>

    <NotAuthorized>
        <FluentStack Orientation="Orientation.Vertical"
                     HorizontalAlignment="HorizontalAlignment.Center"
                     Style="padding: 4rem 2rem; max-width: 1200px; margin: 0 auto; text-align: center;">
            <FluentLabel Typo="Typography.PageTitle" Style="margin-bottom: 1rem;">
                Chronique des Mondes
            </FluentLabel>
            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">
                Veuillez vous connecter pour continuer
            </FluentLabel>
        </FluentStack>
    </NotAuthorized>
</AuthorizeView>
