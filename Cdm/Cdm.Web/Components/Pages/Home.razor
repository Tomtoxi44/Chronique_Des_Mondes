@page "/"
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Accueil - Chronique des Mondes</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="home-page">
            <div class="welcome-section">
                <h1>Bienvenue, @context.User.Identity?.Name !</h1>
                <p>Votre nouvelle application redesignée</p>
            </div>
        </div>
    </Authorized>
    
    <NotAuthorized>
        <div class="home-page">
            <div class="welcome-section">
                <h1>Chronique des Mondes</h1>
                <p>Veuillez vous connecter pour continuer</p>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .home-page {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .welcome-section {
        text-align: center;
        padding: 4rem 2rem;
    }

    .welcome-section h1 {
        font-size: 2.5rem;
        color: var(--color-text-primary);
        margin-bottom: 1rem;
    }

    .welcome-section p {
        font-size: 1.125rem;
        color: var(--color-text-secondary);
    }
</style>

