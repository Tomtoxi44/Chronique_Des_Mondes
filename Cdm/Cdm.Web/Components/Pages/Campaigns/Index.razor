@page "/campaigns"
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Components.Layout
@using Cdm.Web.Services.ApiClients
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@inject CampaignApiClient CampaignApiClient
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Mes Campagnes - Chronique des Mondes</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <!-- Page Header -->
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Style="flex-wrap: wrap; gap: 16px;">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
            <FluentLabel Typo="Typography.H3" Style="color: var(--color-text-primary);">
                Mes Campagnes
            </FluentLabel>
            <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-secondary);">
                Gerez vos aventures et vos sessions de jeu
            </FluentLabel>
        </FluentStack>
        
        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 8px;">
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size20.PersonAdd())"
                          OnClick="@(() => NavigationManager.NavigateTo("/campaigns/join"))">
                Rejoindre
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" 
                          IconStart="@(new Icons.Regular.Size20.Add())"
                          OnClick="@(() => NavigationManager.NavigateTo("/campaigns/create"))">
                Nouvelle Campagne
            </FluentButton>
        </FluentStack>
    </FluentStack>

    <!-- Filters -->
    <FluentCard Style="padding: 16px;">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" Style="flex-wrap: wrap;">
            <FluentSearch Placeholder="Rechercher une campagne..." @bind-Value="_searchTerm" Style="min-width: 250px;" />
            <FluentSelect TOption="string" @bind-Value="_statusFilter" Style="min-width: 150px;">
                <FluentOption Value="">Tous les statuts</FluentOption>
                <FluentOption Value="Planning">En planification</FluentOption>
                <FluentOption Value="Active">En cours</FluentOption>
                <FluentOption Value="OnHold">En pause</FluentOption>
                <FluentOption Value="Completed">Terminees</FluentOption>
                <FluentOption Value="Cancelled">Annulees</FluentOption>
            </FluentSelect>
        </FluentStack>
    </FluentCard>

    @if (_isLoading)
    {
        <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 48px; gap: 16px;">
            <FluentProgressRing Style="width: 48px; height: 48px;" />
            <FluentLabel Typo="Typography.Body">Chargement des campagnes...</FluentLabel>
        </FluentStack>
    }
    <!-- Empty State -->
    else if (!FilteredCampaigns.Any())
    {
        <FluentCard Style="padding: 48px; text-align: center;">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="16" HorizontalAlignment="HorizontalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size48.Briefcase())" Style="color: var(--cdm-gold); opacity: 0.5;" />
                <FluentLabel Typo="Typography.H4" Style="color: var(--cdm-text-primary);">
                    Aucune campagne pour le moment
                </FluentLabel>
                <FluentLabel Typo="Typography.Body" Style="color: var(--cdm-text-muted); max-width: 400px;">
                    Les campagnes sont des aventures que vous menez avec vos joueurs. Creez votre premiere campagne ou rejoignez-en une !
                </FluentLabel>
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 8px; margin-top: 8px;">
                    <FluentButton Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size20.PersonAdd())"
                                  OnClick="@(() => NavigationManager.NavigateTo("/campaigns/join"))">
                        Rejoindre une campagne
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Accent" 
                                  IconStart="@(new Icons.Regular.Size20.Add())"
                                  OnClick="@(() => NavigationManager.NavigateTo("/campaigns/create"))">
                        Creer ma premiere campagne
                    </FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentCard>
    }
    else
    {
        <!-- Campaigns Grid -->
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">
            @foreach (var campaign in FilteredCampaigns)
            {
                <FluentCard Style="padding: 0; overflow: hidden; cursor: pointer;" @onclick="@(() => NavigationManager.NavigateTo($"/campaigns/{campaign.Id}"))">
                    <div style="height: 140px; background: url('@(campaign.CoverImageUrl ?? "images/campaigns/default-cover.png")') center/cover; position: relative;">
                        <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 12px; background: linear-gradient(transparent, rgba(0,0,0,0.8));">
                            <FluentBadge Appearance="@GetStatusAppearance(campaign.Status)">@GetStatusLabel(campaign.Status)</FluentBadge>
                        </div>
                    </div>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Style="padding: 16px;">
                        <FluentLabel Typo="Typography.H5" Style="color: var(--cdm-text-primary);">@campaign.Name</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Style="color: var(--cdm-text-muted); font-size: 14px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @(campaign.Description ?? "Aucune description")
                        </FluentLabel>
                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" Style="margin-top: 8px; color: var(--cdm-text-muted); font-size: 13px;">
                            <span>
                                <FluentIcon Value="@(new Icons.Regular.Size16.People())" Style="margin-right: 4px;" />
                                Max @campaign.MaxPlayers joueurs
                            </span>
                            <span>
                                <FluentIcon Value="@(new Icons.Regular.Size16.Games())" Style="margin-right: 4px;" />
                                @GetGameTypeLabel(campaign.GameType)
                            </span>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            }
        </div>
    }
</FluentStack>

@code {
    private List<CampaignDto> _campaigns = new();
    private string _searchTerm = string.Empty;
    private string _statusFilter = string.Empty;
    private bool _isLoading = true;

    private IEnumerable<CampaignDto> FilteredCampaigns => _campaigns
        .Where(c => string.IsNullOrEmpty(_searchTerm) || c.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(c => string.IsNullOrEmpty(_statusFilter) || c.Status.ToString() == _statusFilter);

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _campaigns = await CampaignApiClient.GetMyCampaignsAsync();
        _isLoading = false;
    }

    private Appearance GetStatusAppearance(CampaignStatus status) => status switch
    {
        CampaignStatus.Active => Appearance.Accent,
        CampaignStatus.OnHold => Appearance.Neutral,
        CampaignStatus.Completed => Appearance.Outline,
        _ => Appearance.Neutral
    };

    private string GetStatusLabel(CampaignStatus status) => status switch
    {
        CampaignStatus.Planning => "En planification",
        CampaignStatus.Active => "En cours",
        CampaignStatus.OnHold => "En pause",
        CampaignStatus.Completed => "Terminee",
        CampaignStatus.Cancelled => "Annulee",
        _ => status.ToString()
    };

    private string GetGameTypeLabel(GameType gameType) => gameType switch
    {
        GameType.DnD5e => "D&D 5e",
        GameType.Pathfinder => "Pathfinder",
        GameType.CallOfCthulhu => "Call of Cthulhu",
        GameType.Warhammer => "Warhammer",
        GameType.Skyrim => "Skyrim",
        GameType.Custom => "Personnalise",
        _ => "Generique"
    };
}
