@page "/campaigns/{Id:int}"
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Shared
@using Cdm.Web.Services.ApiClients
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@inject CampaignApiClient CampaignApiClient
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@inject IStringLocalizer<AppStrings> L
@rendermode InteractiveServer

<PageTitle>@(_campaign?.Name ?? L["Common_Loading"]) — @L["AppName"]</PageTitle>

@if (_isLoading)
{
    <LoadingState Message="@L["Common_Loading"]" />
}
else if (_campaign == null)
{
    <ErrorState Title="@L["Campaigns_NotFound"]" Message="@L["Campaigns_NotFoundMessage"]" OnRetry="@(() => NavigationManager.NavigateTo("/campaigns"))" />
}
else
{
    <PageHeader Title="@_campaign.Name" Subtitle="@($"{L["Common_CreatedAt"]} {_campaign.CreatedAt:dd/MM/yyyy}")">
        <Actions>
            <GameTypeBadge GameType="@_campaign.GameType" />
            <FluentButton Appearance="Appearance.Accent"
                          IconStart="@(new Icons.Regular.Size20.Edit())"
                          OnClick="@(() => NavigationManager.NavigateTo($"/campaigns/edit/{_campaign.Id}"))">
                @L["Common_Edit"]
            </FluentButton>
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size20.Delete())"
                          Style="color: var(--color-error); border-color: var(--color-error);"
                          OnClick="HandleDelete">
                @L["Common_Delete"]
            </FluentButton>
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                          Href="/campaigns">
                @L["Common_Back"]
            </FluentButton>
        </Actions>
    </PageHeader>

    <!-- Campaign Info Cards -->
    <div class="cdm-grid-stats" style="margin-bottom: var(--spacing-lg);">
        <StatCard Icon="📊" Value="@GetStatusDisplay()" Label="@L["Campaigns_Status"]" />
        <StatCard Icon="🎮" Value="@GetGameTypeDisplay()" Label="@L["Common_Details"]" />
        <StatCard Icon="👁️" Value="@GetVisibilityDisplay()" Label="@L["Campaigns_Visibility"]" />
        <StatCard Icon="👥" Value="@_campaign.MaxPlayers.ToString()" Label="@L["Campaigns_MaxPlayers"]" />
    </div>

    <!-- Description -->
    @if (!string.IsNullOrEmpty(_campaign.Description))
    {
        <div class="cdm-content-card" style="margin-bottom: var(--spacing-lg);">
            <h4 style="margin: 0 0 12px;">@L["Campaigns_Description"]</h4>
            <p style="color: var(--color-text-secondary); line-height: 1.6; white-space: pre-wrap; margin: 0;">
                @_campaign.Description
            </p>
        </div>
    }

    <!-- Invite Link -->
    @if (!string.IsNullOrEmpty(_campaign.InviteToken))
    {
        <div class="cdm-content-card" style="margin-bottom: var(--spacing-lg);">
            <h4 style="margin: 0 0 12px;">@L["Campaigns_InviteToken"]</h4>
            <div style="display: flex; gap: 8px;">
                <FluentTextField Value="@GetInviteLink()" ReadOnly Style="flex: 1;" />
                <FluentButton Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size20.Copy())"
                              OnClick="CopyInviteLink">
                    Copier
                </FluentButton>
            </div>
        </div>
    }

    <!-- Players Section -->
    <div class="cdm-content-card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <h4 style="margin: 0;">@L["Campaigns_Players"]</h4>
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size20.PersonAdd())"
                          Loading="@_isGeneratingInvite"
                          Disabled="@_isGeneratingInvite"
                          OnClick="HandleGenerateInvite">
                @L["Campaigns_Invite"]
            </FluentButton>
        </div>
        @if (string.IsNullOrEmpty(_campaign.InviteToken))
        {
            <p style="color: var(--color-text-muted); font-style: italic; margin: 0;">
                Cliquez sur "@L["Campaigns_Invite"]" pour générer un lien d'invitation.
            </p>
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private CampaignDto? _campaign;
    private bool _isLoading = true;
    private bool _isGeneratingInvite = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCampaignAsync();
    }

    private async Task LoadCampaignAsync()
    {
        _isLoading = true;
        try
        {
            _campaign = await CampaignApiClient.GetCampaignByIdAsync(Id);
        }
        catch (Exception ex)
        {
            MessageService.ShowMessageBar($"Erreur: {ex.Message}", MessageIntent.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleDelete()
    {
        if (_campaign == null) return;

        // Simple confirmation - user should confirm via button click
        var success = await CampaignApiClient.DeleteCampaignAsync(_campaign.Id);
        if (success)
        {
            MessageService.ShowMessageBar("Campagne supprimée avec succès", MessageIntent.Success);
            NavigationManager.NavigateTo("/campaigns");
        }
        else
        {
            MessageService.ShowMessageBar("Erreur lors de la suppression", MessageIntent.Error);
        }
    }

    private string GetInviteLink()
    {
        if (string.IsNullOrEmpty(_campaign?.InviteToken)) return string.Empty;
        var baseUri = NavigationManager.BaseUri.TrimEnd('/');
        return $"{baseUri}/campaigns/join/{_campaign.InviteToken}";
    }

    private async Task HandleGenerateInvite()
    {
        if (_campaign == null) return;

        _isGeneratingInvite = true;
        try
        {
            var token = await CampaignApiClient.GenerateInviteTokenAsync(_campaign.Id);
            if (token != null)
            {
                _campaign.InviteToken = token;
                MessageService.ShowMessageBar("Lien d'invitation généré !", MessageIntent.Success);
            }
            else
            {
                MessageService.ShowMessageBar("Erreur lors de la génération du lien.", MessageIntent.Error);
            }
        }
        finally
        {
            _isGeneratingInvite = false;
        }
    }

    private async Task CopyInviteLink()
    {
        // Note: Clipboard API requires JS interop
        MessageService.ShowMessageBar("Lien copié !", MessageIntent.Success);
    }

    private string GetStatusDisplay()
    {
        if (_campaign == null) return string.Empty;
        
        return _campaign.Status switch
        {
            CampaignStatus.Planning => "En planification",
            CampaignStatus.Active => "Active",
            CampaignStatus.OnHold => "En pause",
            CampaignStatus.Completed => "Terminée",
            CampaignStatus.Cancelled => "Annulée",
            _ => _campaign.Status.ToString()
        };
    }

    private string GetStatusColor()
    {
        if (_campaign == null) return "#6B7280";
        
        return _campaign.Status switch
        {
            CampaignStatus.Planning => "#F59E0B",
            CampaignStatus.Active => "#10B981",
            CampaignStatus.OnHold => "#6366F1",
            CampaignStatus.Completed => "#6B7280",
            CampaignStatus.Cancelled => "#EF4444",
            _ => "#6B7280"
        };
    }

    private string GetGameTypeDisplay()
    {
        if (_campaign == null) return string.Empty;
        
        return _campaign.GameType switch
        {
            GameType.Generic => "Générique",
            GameType.DnD5e => "D&D 5e",
            GameType.Skyrim => "Skyrim",
            GameType.Custom => "Personnalisé",
            GameType.Empty => "Vide",
            GameType.Pathfinder => "Pathfinder",
            GameType.CallOfCthulhu => "Call of Cthulhu",
            GameType.Warhammer => "Warhammer",
            GameType.Cyberpunk => "Cyberpunk",
            _ => _campaign.GameType.ToString()
        };
    }

    private string GetVisibilityDisplay()
    {
        if (_campaign == null) return string.Empty;
        
        return _campaign.Visibility switch
        {
            Visibility.Private => "Privée",
            Visibility.Public => "Publique",
            _ => _campaign.Visibility.ToString()
        };
    }
}
