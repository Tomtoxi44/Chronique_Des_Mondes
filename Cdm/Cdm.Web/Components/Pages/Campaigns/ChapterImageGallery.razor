@using Cdm.Business.Abstraction.DTOs
@inject Cdm.Web.Services.ApiClients.ChapterImageApiClient ChapterImageClient

@* GM gallery of maps / place visuals for a chapter. *@
<div class="cdm-card" style="margin-top: var(--spacing-lg);">
    <AppSectionTitle Title="Plans & lieux" Icon="bi-image" />
    <p style="color: var(--color-text-muted); font-size: var(--font-size-sm); margin-top: -4px;">
        Ajoutez des plans ou des visuels de lieu pour ce chapitre. Vous pourrez les montrer aux joueurs en session.
    </p>

    <div style="display: flex; flex-wrap: wrap; gap: var(--spacing-sm); align-items: flex-end; margin-bottom: var(--spacing-md);">
        <div class="form-group" style="margin: 0; flex: 1; min-width: 180px;">
            <label class="form-label">Légende (optionnelle)</label>
            <input class="form-control" @bind="NewCaption" placeholder="Plan du donjon, Taverne..." />
        </div>
        <AppImageUpload Category="maps" Label="Ajouter une image" OnUploaded="OnImageUploaded" />
    </div>

    @if (IsLoading)
    {
        <AppLoadingSpinner Inline="true" Size="sm" />
    }
    else if (Images.Count == 0)
    {
        <p style="color: var(--color-text-muted); font-style: italic; font-size: var(--font-size-sm);">Aucune image pour ce chapitre.</p>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: var(--spacing-sm);">
            @foreach (var img in Images)
            {
                <div style="border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; background: var(--color-surface-alt);">
                    <img src="@img.ImageUrl" alt="@img.Caption" style="width: 100%; height: 100px; object-fit: cover; display: block;" />
                    <div style="padding: 4px 6px; display: flex; justify-content: space-between; align-items: center; gap: 4px;">
                        <span style="font-size: var(--font-size-xs); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            @(string.IsNullOrEmpty(img.Caption) ? "Sans légende" : img.Caption)
                        </span>
                        <button class="btn btn-ghost btn-icon danger" title="Supprimer" @onclick="() => Delete(img.Id)">
                            <i class="bi bi-trash3" style="font-size: 0.7rem;"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int ChapterId { get; set; }

    private List<ChapterImageDto> Images = new();
    private bool IsLoading = true;
    private string NewCaption = string.Empty;
    private int _loadedFor;

    protected override async Task OnParametersSetAsync()
    {
        if (ChapterId > 0 && _loadedFor != ChapterId)
        {
            _loadedFor = ChapterId;
            await Reload();
        }
    }

    private async Task Reload()
    {
        IsLoading = true;
        Images = await ChapterImageClient.GetForChapterAsync(ChapterId);
        IsLoading = false;
    }

    private async Task OnImageUploaded(string url)
    {
        var dto = new AddChapterImageDto
        {
            ImageUrl = url,
            Caption = string.IsNullOrWhiteSpace(NewCaption) ? null : NewCaption.Trim(),
        };
        var added = await ChapterImageClient.AddAsync(ChapterId, dto);
        if (added != null)
        {
            Images.Add(added);
            NewCaption = string.Empty;
        }
    }

    private async Task Delete(int id)
    {
        if (await ChapterImageClient.DeleteAsync(id))
        {
            Images.RemoveAll(i => i.Id == id);
        }
    }
}
