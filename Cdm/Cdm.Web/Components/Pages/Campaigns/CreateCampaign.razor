@page "/campaigns/create"
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Campaigns
@using Cdm.Web.Services
@using Microsoft.AspNetCore.Authorization
@layout AppLayout
@attribute [Authorize]
@inject ICampaignService CampaignService
@inject NavigationManager NavigationManager
@inject ILogger<CreateCampaign> Logger
@rendermode InteractiveServer

<PageTitle>Nouvelle Campagne - Chronique des Mondes</PageTitle>

<div class="create-campaign-page">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs">
        <a href="/" class="breadcrumb-item">
            <i class="bi bi-house-door"></i>
        </a>
        <span class="breadcrumb-separator">/</span>
        <a href="/campaigns" class="breadcrumb-item">Campagnes</a>
        <span class="breadcrumb-separator">/</span>
        <span class="breadcrumb-current">Nouvelle</span>
    </nav>

    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-plus-circle text-gold"></i>
            Créer une Nouvelle Campagne
        </h1>
        <p class="page-subtitle">Donnez vie à votre prochaine aventure épique</p>
    </div>

    <div class="card card-gold" style="max-width: 800px;">
        <div class="card-body" style="padding: var(--spacing-2xl);">
            @if (!string.IsNullOrEmpty(this.errorMessage))
            {
                <div class="auth-alert auth-alert-error" style="margin-bottom: var(--spacing-lg);">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@this.errorMessage</span>
                    <button type="button" 
                            class="btn btn-ghost btn-sm" 
                            style="margin-left: auto;"
                            @onclick="() => this.errorMessage = null">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }

            @if (this.success)
            {
                <div class="auth-alert auth-alert-success">
                    <i class="bi bi-check-circle"></i>
                    <span>Campagne créée avec succès ! Redirection en cours...</span>
                </div>
            }
            else
            {
                <CampaignForm Model="@this.model" 
                             IsSubmitting="@this.isSubmitting" 
                             OnSubmit="HandleCreateCampaignAsync" />
            }
        </div>
    </div>

    <div style="margin-top: var(--spacing-xl); text-align: center;">
        <a href="/campaigns" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i>
            Retour aux campagnes
        </a>
    </div>
</div>

@code {
    private CampaignForm.CreateCampaignModel model = new();
    private bool isSubmitting = false;
    private bool success = false;
    private string? errorMessage;

    /// <summary>
    /// Handles campaign creation submission.
    /// </summary>
    private async Task HandleCreateCampaignAsync()
    {
        try
        {
            this.isSubmitting = true;
            this.errorMessage = null;

            this.Logger.LogInformation("Submitting campaign creation: {Name}", this.model.Name);

            var createdCampaign = await this.CampaignService.CreateCampaignAsync(this.model);

            if (createdCampaign != null)
            {
                this.Logger.LogInformation("Campaign created successfully with ID: {Id}", createdCampaign.Id);
                this.success = true;

                // Redirect to campaign details page after a short delay
                await Task.Delay(1500);
                this.NavigationManager.NavigateTo("/campaigns");
            }
            else
            {
                this.errorMessage = "Échec de la création de la campagne. Veuillez vérifier vos données et réessayer.";
                this.Logger.LogWarning("Campaign creation failed");
            }
        }
        catch (Exception ex)
        {
            this.errorMessage = $"Une erreur s'est produite : {ex.Message}";
            this.Logger.LogError(ex, "Error creating campaign");
        }
        finally
        {
            this.isSubmitting = false;
        }
    }
}
