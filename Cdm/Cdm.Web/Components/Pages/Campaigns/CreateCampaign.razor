@page "/campaigns/create"
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Campaigns
@using Cdm.Web.Services
@using Microsoft.AspNetCore.Authorization
@layout AppLayout
@attribute [Authorize(Roles = "GameMaster")]
@inject ICampaignService CampaignService
@inject NavigationManager NavigationManager
@inject ILogger<CreateCampaign> Logger
@rendermode InteractiveServer

<PageTitle>Nouvelle Campagne - Chronique des Mondes</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24" Style="max-width: 800px; margin: 0 auto; padding: 24px;">
    <!-- Breadcrumbs -->
    <FluentBreadcrumb>
        <FluentBreadcrumbItem Href="/">
            <FluentIcon Value="@(new Icons.Regular.Size16.Home())" Style="margin-right: 4px;" /> Accueil
        </FluentBreadcrumbItem>
        <FluentBreadcrumbItem Href="/campaigns">
            Campagnes
        </FluentBreadcrumbItem>
        <FluentBreadcrumbItem>
            Nouvelle
        </FluentBreadcrumbItem>
    </FluentBreadcrumb>

    <!-- Page Header -->
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.H3" Style="color: var(--color-text-primary);">
            Creer une Nouvelle Campagne
        </FluentLabel>
        <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-secondary);">
            Donnez vie a votre prochaine aventure epique
        </FluentLabel>
    </FluentStack>

    <!-- Main Card -->
    <FluentCard Style="padding: 32px;">
        @if (!string.IsNullOrEmpty(this.errorMessage))
        {
            <FluentMessageBar Title="Erreur" 
                             Intent="@MessageIntent.Error" 
                             AllowDismiss="true" 
                             OnDismiss="@(() => this.errorMessage = null)"
                             Style="margin-bottom: 24px;">
                @this.errorMessage
            </FluentMessageBar>
        }

        @if (this.success)
        {
            <FluentMessageBar Title="Succes" Intent="@MessageIntent.Success">
                <FluentIcon Value="@(new Icons.Regular.Size20.CheckmarkCircle())" Style="margin-right: 8px;" />
                Campagne creee avec succes ! Redirection en cours...
            </FluentMessageBar>
        }
        else
        {
            <CampaignForm Model="@this.model" 
                         IsSubmitting="@this.isSubmitting" 
                         OnSubmit="HandleCreateCampaignAsync" />
        }
    </FluentCard>

    <!-- Back Button -->
    <FluentStack HorizontalAlignment="HorizontalAlignment.Center">
        <FluentAnchor Href="/campaigns" Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size20.ArrowLeft())">
            Retour aux campagnes
        </FluentAnchor>
    </FluentStack>
</FluentStack>

@code {
    private CampaignForm.CreateCampaignModel model = new();
    private bool isSubmitting = false;
    private bool success = false;
    private string? errorMessage;

    /// <summary>
    /// Handles campaign creation submission.
    /// </summary>
    private async Task HandleCreateCampaignAsync()
    {
        try
        {
            this.isSubmitting = true;
            this.errorMessage = null;

            this.Logger.LogInformation("Submitting campaign creation: {Name}", this.model.Name);

            var createdCampaign = await this.CampaignService.CreateCampaignAsync(this.model);

            if (createdCampaign != null)
            {
                this.Logger.LogInformation("Campaign created successfully with ID: {Id}", createdCampaign.Id);
                this.success = true;

                // Redirect to campaign details page after a short delay
                await Task.Delay(1500);
                this.NavigationManager.NavigateTo("/campaigns");
            }
            else
            {
                this.errorMessage = "Echec de la creation de la campagne. Veuillez verifier vos donnees et reessayer.";
                this.Logger.LogWarning("Campaign creation failed");
            }
        }
        catch (Exception ex)
        {
            this.errorMessage = $"Une erreur s'est produite : {ex.Message}";
            this.Logger.LogError(ex, "Error creating campaign");
        }
        finally
        {
            this.isSubmitting = false;
        }
    }
}
