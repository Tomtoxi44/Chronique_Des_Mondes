@page "/campaigns/create"
@attribute [Authorize]

<PageTitle>@L["Campaigns_Create"] — Chronique des Mondes</PageTitle>

<AppPageHeader Title="@L["Campaigns_Create"]"
               Subtitle="@L["Campaigns_CreateSubtitle"]"
               Icon="bi-plus-circle"
               Breadcrumbs="@Breadcrumbs" />

<div style="max-width: 680px;">
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-error" style="margin-bottom: var(--spacing-lg);">
            <i class="bi bi-exclamation-triangle-fill"></i>
            @ErrorMessage
        </div>
    }

    <EditForm Model="Model" OnValidSubmit="HandleCreate" FormName="campaign-create">
        <DataAnnotationsValidator />

        <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
            <h3 class="card-title" style="margin-bottom: var(--spacing-md);">Informations</h3>

            <div class="form-group">
                <label class="form-label">@L["Campaigns_Name"] *</label>
                <InputText @bind-Value="Model.Name" class="form-control"
                           placeholder="La Quête des Éclats..." />
                <ValidationMessage For="() => Model.Name" class="form-error" />
            </div>

            <div class="form-group">
                <label class="form-label">@L["Campaigns_Description"]</label>
                <InputTextArea @bind-Value="Model.Description" class="form-control" rows="3"
                               placeholder="Décrivez l'histoire de cette campagne..." />
            </div>

            <div class="form-group">
                <label class="form-label">Monde *</label>
                @if (Worlds.Count == 0)
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i>
                        Vous devez d'abord <a href="/worlds/create">créer un monde</a>.
                    </div>
                }
                else
                {
                    <InputSelect @bind-Value="Model.WorldId" class="form-control">
                        <option value="0">-- Sélectionner un monde --</option>
                        @foreach (var world in Worlds)
                        {
                            <option value="@world.Id">@world.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => Model.WorldId" class="form-error" />
                }
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-md);">
                <div class="form-group">
                    <label class="form-label">@L["Campaigns_MaxPlayers"]</label>
                    <InputNumber @bind-Value="Model.MaxPlayers" class="form-control" min="1" max="20" />
                    <ValidationMessage For="() => Model.MaxPlayers" class="form-error" />
                </div>

                <div class="form-group">
                    <label class="form-label">@L["Campaigns_Visibility"]</label>
                    <InputSelect @bind-Value="Model.Visibility" class="form-control">
                        <option value="0">Privée</option>
                        <option value="1">Publique</option>
                    </InputSelect>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a href="/campaigns" class="btn btn-ghost">
                <i class="bi bi-arrow-left"></i>
                @L["Common_Cancel"]
            </a>
            <button type="submit" class="btn btn-primary" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <AppLoadingSpinner Inline="true" Size="sm" />
                }
                else
                {
                    <i class="bi bi-check-circle"></i>
                }
                @(IsLoading ? L["Common_Saving"] : L["Common_Create"])
            </button>
        </div>
    </EditForm>
</div>
