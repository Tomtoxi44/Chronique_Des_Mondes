@page "/campaigns/{CampaignId:int}"
@attribute [Authorize]
@implements IDisposable

<PageTitle>@(Campaign?.Name ?? "Campagne") — Chronique des Mondes</PageTitle>

@if (IsLoading)
{
    <AppLoadingSpinner Label="@L["Common_Loading"]" />
}
else if (Campaign == null)
{
    <AppEmptyState Icon="bi-map"
                   Title="@L["Campaigns_NotFound"]"
                   Message="@L["Campaigns_NotFoundMessage"]">
        <ActionContent>
            <a href="/campaigns" class="btn btn-primary">
                <i class="bi bi-arrow-left"></i>
                @L["Common_Back"]
            </a>
        </ActionContent>
    </AppEmptyState>
}
else
{
    <AppThemeWrapper GameType="@Campaign.GameType">
        <AppPageHeader Title="@Campaign.Name"
                       Subtitle="@Campaign.Description"
                       Icon="bi-map"
                       Breadcrumbs="@Breadcrumbs">
            <Actions>
                <span class="status-badge @GetStatusClass(Campaign.Status)">@GetStatusLabel(Campaign.Status)</span>
            </Actions>
        </AppPageHeader>

        <!-- Contenu du chapitre sélectionné ou vue générale -->
        @if (SelectedChapter != null)
        {
            <div class="cdm-card">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-md);">
                    <div>
                        <h3 class="card-title">Chapitre @SelectedChapter.ChapterNumber — @SelectedChapter.Title</h3>
                        @if (SelectedChapter.IsActive)
                        {
                            <span class="status-badge status-active">@L["Chapters_Active"]</span>
                        }
                        else if (SelectedChapter.IsCompleted)
                        {
                            <span class="status-badge status-completed">@L["Chapters_Completed"]</span>
                        }
                    </div>
                    <div style="display: flex; gap: var(--spacing-sm);">
                        @if (!SelectedChapter.IsActive && !SelectedChapter.IsCompleted)
                        {
                            <button class="btn btn-primary btn-sm" @onclick="() => StartChapter(SelectedChapter)">
                                <i class="bi bi-play-circle"></i>
                                @L["Chapters_Start"]
                            </button>
                        }
                        @if (SelectedChapter.IsActive)
                        {
                            <button class="btn btn-ghost btn-sm" @onclick="() => CompleteChapter(SelectedChapter)">
                                <i class="bi bi-check-circle"></i>
                                @L["Chapters_Complete"]
                            </button>
                        }
                        <button class="btn btn-ghost btn-sm danger" @onclick="() => ConfirmDeleteChapter(SelectedChapter)">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(SelectedChapter.Content))
                {
                    <div class="chapter-content">
                        @SelectedChapter.Content
                    </div>
                }
                else
                {
                    <p style="color: var(--color-text-muted); font-style: italic;">Aucun contenu pour ce chapitre.</p>
                }
            </div>

            @if (IsGm)
            {
                <!-- Section PNJ (GM uniquement) -->
                <div class="cdm-card" style="margin-top: var(--spacing-lg);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-md);">
                        <h4 class="card-title" style="margin: 0;">
                            <i class="bi bi-person-badge"></i>
                            Personnages non-joueurs
                        </h4>
                        <button class="btn btn-ghost btn-sm" @onclick="ShowAddNpc">
                            <i class="bi bi-plus"></i> Ajouter
                        </button>
                    </div>

                    @if (ShowNpcForm)
                    {
                        <div class="cdm-card" style="background: var(--color-surface-alt); margin-bottom: var(--spacing-md);">
                            @if (IsDnd5e)
                            {
                                <EditForm Model="NewDndNpc" OnValidSubmit="CreateNpc" FormName="npc-create">
                                    @* Monster template picker *@
                                    @if (MonsterTemplates.Count > 0)
                                    {
                                        <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                                            <label class="form-label">
                                                <i class="bi bi-dragon" style="margin-right: 4px;"></i>
                                                Template monstre (optionnel)
                                            </label>
                                            <select class="form-control" @bind="SelectedMonsterTemplateId">
                                                <option value="0">— Aucun template —</option>
                                                @foreach (var monster in MonsterTemplates)
                                                {
                                                    <option value="@monster.Id">@monster.Name (@monster.ChallengeRating) — @monster.MonsterType</option>
                                                }
                                            </select>
                                            <small style="color: var(--color-text-muted);">Sélectionner un template pré-remplit les statistiques.</small>
                                        </div>
                                        <hr style="border-color: var(--color-border); margin: var(--spacing-sm) 0;" />
                                    }

                                    @* Base NPC fields *@
                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-sm);">
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label">Prénom</label>
                                            <InputText @bind-Value="NewDndNpc.FirstName" class="form-control" placeholder="Prénom..." />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label">Nom</label>
                                            <InputText @bind-Value="NewDndNpc.Name" class="form-control" placeholder="Nom..." />
                                        </div>
                                    </div>
                                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--spacing-sm); margin-top: var(--spacing-sm);">
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label">Âge</label>
                                            <InputNumber @bind-Value="NewDndNpc.Age" class="form-control" placeholder="Âge..." />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label">Race</label>
                                            <InputText @bind-Value="NewDndNpc.Race" class="form-control" placeholder="Gobelin, Elfe..." />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label">Classe</label>
                                            <InputText @bind-Value="NewDndNpc.CharacterClass" class="form-control" placeholder="Guerrier, Voleur..." />
                                        </div>
                                    </div>
                                    <div class="form-group" style="margin-top: var(--spacing-sm);">
                                        <label class="form-label">Description</label>
                                        <InputTextArea @bind-Value="NewDndNpc.Description" class="form-control" rows="2" placeholder="Description..." />
                                    </div>

                                    @* D&D Stats *@
                                    <div style="margin-top: var(--spacing-sm); margin-bottom: var(--spacing-xs);">
                                        <strong style="font-size: var(--font-size-sm); color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">
                                            <i class="bi bi-shield-fill-check" style="margin-right: 4px;"></i>Statistiques D&amp;D
                                        </strong>
                                    </div>
                                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--spacing-xs);">
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label" style="font-size: 0.7rem;">Niveau</label>
                                            <InputNumber @bind-Value="NewDndNpc.Level" class="form-control form-control-sm" placeholder="1" />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label" style="font-size: 0.7rem;">PV</label>
                                            <InputNumber @bind-Value="NewDndNpc.HitPoints" class="form-control form-control-sm" placeholder="10" />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label" style="font-size: 0.7rem;">CA</label>
                                            <InputNumber @bind-Value="NewDndNpc.ArmorClass" class="form-control form-control-sm" placeholder="10" />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label" style="font-size: 0.7rem;">Vitesse</label>
                                            <InputNumber @bind-Value="NewDndNpc.Speed" class="form-control form-control-sm" placeholder="30" />
                                        </div>
                                    </div>
                                    <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: var(--spacing-xs); margin-top: var(--spacing-xs);">
                                        <div class="form-group" style="margin-bottom: 0; text-align: center;">
                                            <label class="form-label" style="font-size: 0.7rem;">FOR</label>
                                            <InputNumber @bind-Value="NewDndNpc.Strength" class="form-control form-control-sm" placeholder="10" />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0; text-align: center;">
                                            <label class="form-label" style="font-size: 0.7rem;">DEX</label>
                                            <InputNumber @bind-Value="NewDndNpc.Dexterity" class="form-control form-control-sm" placeholder="10" />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0; text-align: center;">
                                            <label class="form-label" style="font-size: 0.7rem;">CON</label>
                                            <InputNumber @bind-Value="NewDndNpc.Constitution" class="form-control form-control-sm" placeholder="10" />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0; text-align: center;">
                                            <label class="form-label" style="font-size: 0.7rem;">INT</label>
                                            <InputNumber @bind-Value="NewDndNpc.Intelligence" class="form-control form-control-sm" placeholder="10" />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0; text-align: center;">
                                            <label class="form-label" style="font-size: 0.7rem;">SAG</label>
                                            <InputNumber @bind-Value="NewDndNpc.Wisdom" class="form-control form-control-sm" placeholder="10" />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0; text-align: center;">
                                            <label class="form-label" style="font-size: 0.7rem;">CHA</label>
                                            <InputNumber @bind-Value="NewDndNpc.Charisma" class="form-control form-control-sm" placeholder="10" />
                                        </div>
                                    </div>
                                    <div class="form-actions" style="margin-top: var(--spacing-sm);">
                                        <button type="button" class="btn btn-ghost btn-sm" @onclick="() => ShowNpcForm = false">Annuler</button>
                                        <button type="submit" class="btn btn-primary btn-sm" disabled="@IsSavingNpc">
                                            @if (IsSavingNpc) { <AppLoadingSpinner Inline="true" Size="sm" /> }
                                            Créer le PNJ D&amp;D
                                        </button>
                                    </div>
                                </EditForm>
                            }
                            else
                            {
                                <EditForm Model="NewNpc" OnValidSubmit="CreateNpc" FormName="npc-create">
                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-sm);">
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label">Prénom</label>
                                            <InputText @bind-Value="NewNpc.FirstName" class="form-control" placeholder="Prénom..." />
                                        </div>
                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label class="form-label">Nom</label>
                                            <InputText @bind-Value="NewNpc.Name" class="form-control" placeholder="Nom..." />
                                        </div>
                                    </div>
                                    <div class="form-group" style="margin-top: var(--spacing-sm);">
                                        <label class="form-label">Âge</label>
                                        <InputNumber @bind-Value="NewNpc.Age" class="form-control" placeholder="Âge..." />
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Description</label>
                                        <InputTextArea @bind-Value="NewNpc.Description" class="form-control" rows="2" placeholder="Description..." />
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Description physique</label>
                                        <InputTextArea @bind-Value="NewNpc.PhysicalDescription" class="form-control" rows="2" placeholder="Apparence physique..." />
                                    </div>
                                    <div class="form-actions" style="margin-top: var(--spacing-sm);">
                                        <button type="button" class="btn btn-ghost btn-sm" @onclick="() => ShowNpcForm = false">Annuler</button>
                                        <button type="submit" class="btn btn-primary btn-sm" disabled="@IsSavingNpc">
                                            @if (IsSavingNpc) { <AppLoadingSpinner Inline="true" Size="sm" /> }
                                            Créer le PNJ
                                        </button>
                                    </div>
                                </EditForm>
                            }
                        </div>
                    }

                    @if (Npcs.Count == 0 && !ShowNpcForm)
                    {
                        <p style="color: var(--color-text-muted); font-style: italic; font-size: var(--font-size-sm);">Aucun PNJ dans ce chapitre.</p>
                    }
                    else
                    {
                        <div class="npc-list">
                            @foreach (var npc in Npcs)
                            {
                                var dndNpc = npc as DndNpcDto;
                                <div class="npc-card">
                                    <div class="npc-card-header">
                                        <div>
                                            <strong>@npc.DisplayName</strong>
                                            @if (dndNpc?.Race != null || dndNpc?.CharacterClass != null)
                                            {
                                                <span style="color: var(--color-text-muted); font-size: var(--font-size-sm); margin-left: var(--spacing-sm);">
                                                    @(dndNpc.Race) @(dndNpc.CharacterClass != null ? $"- {dndNpc.CharacterClass}" : "")
                                                    @if (dndNpc.Level.HasValue) { <text> Nv.@dndNpc.Level</text> }
                                                </span>
                                            }
                                            else if (npc.Age.HasValue)
                                            {
                                                <span style="color: var(--color-text-muted); font-size: var(--font-size-sm); margin-left: var(--spacing-sm);">@npc.Age ans</span>
                                            }
                                        </div>
                                        <button class="btn btn-ghost btn-sm danger" @onclick="() => ConfirmDeleteNpc(npc)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                    @if (dndNpc != null && (dndNpc.HitPoints.HasValue || dndNpc.ArmorClass.HasValue || dndNpc.Strength.HasValue))
                                    {
                                        <div style="display: flex; gap: var(--spacing-sm); flex-wrap: wrap; margin: var(--spacing-xs) 0; font-size: var(--font-size-sm);">
                                            @if (dndNpc.HitPoints.HasValue)
                                            {
                                                <span class="badge" style="background: var(--color-error-subtle, #4a1010); color: #e88;">
                                                    <i class="bi bi-heart-fill"></i> @dndNpc.HitPoints PV
                                                </span>
                                            }
                                            @if (dndNpc.ArmorClass.HasValue)
                                            {
                                                <span class="badge" style="background: var(--color-surface-alt);">
                                                    <i class="bi bi-shield"></i> CA @dndNpc.ArmorClass
                                                </span>
                                            }
                                            @if (dndNpc.Speed.HasValue)
                                            {
                                                <span class="badge" style="background: var(--color-surface-alt);">
                                                    @dndNpc.Speed m/r
                                                </span>
                                            }
                                        </div>
                                        @if (dndNpc.Strength.HasValue)
                                        {
                                            <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 4px; font-size: 0.7rem; text-align: center; margin-top: 4px;">
                                                @{
                                                    int Mod(int? v) => v.HasValue ? (v.Value - 10) / 2 : 0;
                                                    string Sign(int m) => m >= 0 ? $"+{m}" : $"{m}";
                                                }
                                                <div style="background: var(--color-surface-alt); border-radius: 4px; padding: 2px;">
                                                    <div style="font-weight: 600;">FOR</div>
                                                    <div>@dndNpc.Strength</div>
                                                    <div style="color: var(--color-text-muted);">@Sign(Mod(dndNpc.Strength))</div>
                                                </div>
                                                <div style="background: var(--color-surface-alt); border-radius: 4px; padding: 2px;">
                                                    <div style="font-weight: 600;">DEX</div>
                                                    <div>@dndNpc.Dexterity</div>
                                                    <div style="color: var(--color-text-muted);">@Sign(Mod(dndNpc.Dexterity))</div>
                                                </div>
                                                <div style="background: var(--color-surface-alt); border-radius: 4px; padding: 2px;">
                                                    <div style="font-weight: 600;">CON</div>
                                                    <div>@dndNpc.Constitution</div>
                                                    <div style="color: var(--color-text-muted);">@Sign(Mod(dndNpc.Constitution))</div>
                                                </div>
                                                <div style="background: var(--color-surface-alt); border-radius: 4px; padding: 2px;">
                                                    <div style="font-weight: 600;">INT</div>
                                                    <div>@dndNpc.Intelligence</div>
                                                    <div style="color: var(--color-text-muted);">@Sign(Mod(dndNpc.Intelligence))</div>
                                                </div>
                                                <div style="background: var(--color-surface-alt); border-radius: 4px; padding: 2px;">
                                                    <div style="font-weight: 600;">SAG</div>
                                                    <div>@dndNpc.Wisdom</div>
                                                    <div style="color: var(--color-text-muted);">@Sign(Mod(dndNpc.Wisdom))</div>
                                                </div>
                                                <div style="background: var(--color-surface-alt); border-radius: 4px; padding: 2px;">
                                                    <div style="font-weight: 600;">CHA</div>
                                                    <div>@dndNpc.Charisma</div>
                                                    <div style="color: var(--color-text-muted);">@Sign(Mod(dndNpc.Charisma))</div>
                                                </div>
                                            </div>
                                        }
                                    }
                                    @if (!string.IsNullOrEmpty(npc.Description))
                                    {
                                        <p class="npc-description">@npc.Description</p>
                                    }
                                    @if (!string.IsNullOrEmpty(npc.PhysicalDescription))
                                    {
                                        <p class="npc-description" style="font-style: italic; color: var(--color-text-muted);">@npc.PhysicalDescription</p>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <!-- Vue générale de la campagne -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: var(--spacing-md); margin-bottom: var(--spacing-xl);">
                <AppStatCard Value="@Chapters.Count.ToString()" Label="@L["Campaigns_Chapters"]" Icon="bi-book" />
                <AppStatCard Value="@Campaign.MaxPlayers.ToString()" Label="@L["Campaigns_MaxPlayers"]" Icon="bi-people" />
            </div>

            @if (Chapters.Count == 0)
            {
                <AppEmptyState Icon="bi-book"
                               Title="@L["Chapters_Empty"]"
                               Message="@L["Chapters_EmptyMessage"]">
                    <ActionContent>
                        <button class="btn btn-primary" @onclick="ShowCreateChapter">
                            <i class="bi bi-plus"></i>
                            @L["Chapters_Create"]
                        </button>
                    </ActionContent>
                </AppEmptyState>
            }
        }

        <!-- Formulaire de création de chapitre -->
        @if (ShowChapterForm)
        {
            <div class="cdm-card" style="margin-top: var(--spacing-lg);">
                <h3 class="card-title" style="margin-bottom: var(--spacing-md);">@L["Chapters_Create"]</h3>
                <EditForm Model="NewChapter" OnValidSubmit="CreateChapter" FormName="chapter-create">
                    <DataAnnotationsValidator />
                    <div class="form-group">
                        <label class="form-label">Titre</label>
                        <InputText @bind-Value="NewChapter.Title" class="form-control"
                                   placeholder="Titre du chapitre..." />
                    </div>
                    <div class="form-group">
                        <label class="form-label">@L["Chapters_Content"]</label>
                        <InputTextArea @bind-Value="NewChapter.Content" class="form-control" rows="4" />
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn btn-ghost" @onclick="() => ShowChapterForm = false">
                            @L["Common_Cancel"]
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@IsSaving">
                            @if (IsSaving) { <AppLoadingSpinner Inline="true" Size="sm" /> }
                            @L["Common_Create"]
                        </button>
                    </div>
                </EditForm>
            </div>
        }
    </AppThemeWrapper>
}

<AppConfirmDialog @ref="DeleteChapterDialog"
                  Title="@L["Common_Confirm"]"
                  Message="Supprimer ce chapitre ?"
                  ConfirmLabel="@L["Common_Delete"]"
                  CancelLabel="@L["Common_Cancel"]"
                  OnConfirm="DeleteChapter" />

<AppConfirmDialog @ref="DeleteNpcDialog"
                  Title="@L["Common_Confirm"]"
                  Message="Supprimer ce PNJ ?"
                  ConfirmLabel="@L["Common_Delete"]"
                  CancelLabel="@L["Common_Cancel"]"
                  OnConfirm="DeleteNpc" />
