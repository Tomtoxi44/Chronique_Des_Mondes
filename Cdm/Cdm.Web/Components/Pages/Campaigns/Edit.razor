@page "/campaigns/edit/{Id:int}"
@using System.ComponentModel.DataAnnotations
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Components.Layout
@using Cdm.Web.Services.ApiClients
@using Microsoft.AspNetCore.Authorization
@layout AppLayout
@attribute [Authorize]
@inject CampaignApiClient CampaignApiClient
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@rendermode InteractiveServer

<PageTitle>Modifier @(_campaign?.Name ?? "Campagne") - Chronique des Mondes</PageTitle>

@if (_isLoading)
{
    <FluentStack Orientation="Orientation.Vertical" 
                 HorizontalAlignment="HorizontalAlignment.Center"
                 Style="padding: 48px; gap: 16px;">
        <FluentProgressRing Style="width: 48px; height: 48px;" />
        <FluentLabel Typo="Typography.Body">Chargement...</FluentLabel>
    </FluentStack>
}
else if (_campaign == null)
{
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" 
                     HorizontalAlignment="HorizontalAlignment.Center"
                     Style="padding: 48px; gap: 16px;">
            <FluentIcon Value="@(new Icons.Regular.Size48.ErrorCircle())" Color="Color.Error" />
            <FluentLabel Typo="Typography.H5">Campagne introuvable</FluentLabel>
            <FluentButton Appearance="Appearance.Accent" 
                          OnClick="@(() => NavigationManager.NavigateTo("/campaigns"))">
                Retour aux campagnes
            </FluentButton>
        </FluentStack>
    </FluentCard>
}
else
{
    <FluentStack Orientation="Orientation.Vertical" Style="gap: 24px; max-width: 800px; margin: 0 auto;">
        <!-- Breadcrumbs -->
        <FluentBreadcrumb>
            <FluentBreadcrumbItem Href="/">
                <FluentIcon Value="@(new Icons.Regular.Size16.Home())" Style="margin-right: 4px;" /> Accueil
            </FluentBreadcrumbItem>
            <FluentBreadcrumbItem Href="/campaigns">
                Campagnes
            </FluentBreadcrumbItem>
            <FluentBreadcrumbItem Href="@($"/campaigns/{Id}")">
                @_campaign.Name
            </FluentBreadcrumbItem>
            <FluentBreadcrumbItem>
                Modifier
            </FluentBreadcrumbItem>
        </FluentBreadcrumb>

        <!-- Page Header -->
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 4px;">
            <FluentLabel Typo="Typography.H3" Style="color: var(--color-text-primary);">Modifier la Campagne</FluentLabel>
            <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-secondary);">Mettez à jour les informations de votre campagne</FluentLabel>
        </FluentStack>

        <!-- Form Card -->
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 24px; padding: 8px;">
                <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 20px;">
                        <!-- Name -->
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                                Nom de la campagne <span style="color: var(--color-error-500);">*</span>
                            </FluentLabel>
                            <FluentTextField @bind-Value="_model.Name"
                                             Placeholder="Ex: La Légende du Dragon"
                                             Required
                                             Style="width: 100%;" />
                            <ValidationMessage For="@(() => _model.Name)" />
                        </FluentStack>

                        <!-- Description -->
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                                Description
                            </FluentLabel>
                            <FluentTextArea @bind-Value="_model.Description"
                                            Placeholder="Décrivez votre campagne..."
                                            Rows="5"
                                            Style="width: 100%;" />
                            <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-muted); font-size: 12px;">
                                Une brève description de votre aventure (optionnel)
                            </FluentLabel>
                        </FluentStack>

                        <!-- Status -->
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                                Statut <span style="color: var(--color-error-500);">*</span>
                            </FluentLabel>
                            <FluentSelect TOption="string" 
                                          Value="@(_model.Status.ToString())"
                                          ValueChanged="@((string value) => _model.Status = Enum.Parse<CampaignStatus>(value))"
                                          Style="width: 100%;">
                                <FluentOption Value="@CampaignStatus.Planning.ToString()">📋 En planification</FluentOption>
                                <FluentOption Value="@CampaignStatus.Active.ToString()">✅ Active</FluentOption>
                                <FluentOption Value="@CampaignStatus.OnHold.ToString()">⏸️ En pause</FluentOption>
                                <FluentOption Value="@CampaignStatus.Completed.ToString()">🏁 Terminée</FluentOption>
                                <FluentOption Value="@CampaignStatus.Cancelled.ToString()">❌ Annulée</FluentOption>
                            </FluentSelect>
                        </FluentStack>

                        <!-- Visibility -->
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                                Visibilité <span style="color: var(--color-error-500);">*</span>
                            </FluentLabel>
                            <FluentSelect TOption="string" 
                                          Value="@(_model.Visibility.ToString())"
                                          ValueChanged="@((string value) => _model.Visibility = Enum.Parse<Visibility>(value))"
                                          Style="width: 100%;">
                                <FluentOption Value="@Visibility.Private.ToString()">🔒 Privée (sur invitation uniquement)</FluentOption>
                                <FluentOption Value="@Visibility.Public.ToString()">🌍 Publique (visible par tous)</FluentOption>
                            </FluentSelect>
                        </FluentStack>

                        <!-- Max Players -->
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                                Nombre maximum de joueurs <span style="color: var(--color-error-500);">*</span>
                            </FluentLabel>
                            <FluentNumberField @bind-Value="_model.MaxPlayers"
                                               Min="1"
                                               Max="20"
                                               Required
                                               Style="width: 200px;" />
                            <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-muted); font-size: 12px;">
                                Nombre maximum de joueurs (1-20)
                            </FluentLabel>
                            <ValidationMessage For="@(() => _model.MaxPlayers)" />
                        </FluentStack>

                        <!-- Info: GameType cannot be changed -->
                        <FluentMessageBar Title="Information" Intent="MessageIntent.Info">
                            Le type de jeu ne peut pas être modifié après la création. Type actuel: <strong>@GetGameTypeDisplay()</strong>
                        </FluentMessageBar>

                        <!-- Action Buttons -->
                        <FluentStack Orientation="Orientation.Horizontal" 
                                     HorizontalAlignment="HorizontalAlignment.End"
                                     Style="gap: 12px; margin-top: 8px;">
                            <FluentButton Appearance="Appearance.Outline"
                                          OnClick="@(() => NavigationManager.NavigateTo($"/campaigns/{Id}"))"
                                          Disabled="@_isSubmitting">
                                Annuler
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Accent"
                                          Type="ButtonType.Submit"
                                          Loading="@_isSubmitting"
                                          Disabled="@_isSubmitting"
                                          IconStart="@(new Icons.Regular.Size20.Save())">
                                Enregistrer
                            </FluentButton>
                        </FluentStack>
                    </FluentStack>
                </EditForm>
            </FluentStack>
        </FluentCard>
    </FluentStack>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private CampaignDto? _campaign;
    private UpdateCampaignModel _model = new();
    private bool _isLoading = true;
    private bool _isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCampaignAsync();
    }

    private async Task LoadCampaignAsync()
    {
        _isLoading = true;
        try
        {
            _campaign = await CampaignApiClient.GetCampaignByIdAsync(Id);
            
            if (_campaign != null)
            {
                _model.Name = _campaign.Name;
                _model.Description = _campaign.Description ?? string.Empty;
                _model.Visibility = _campaign.Visibility;
                _model.MaxPlayers = _campaign.MaxPlayers;
                _model.Status = _campaign.Status;
            }
        }
        catch (Exception ex)
        {
            MessageService.ShowMessageBar($"Erreur: {ex.Message}", MessageIntent.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (_campaign == null) return;

        _isSubmitting = true;
        try
        {
            var request = new UpdateCampaignRequest(
                _model.Name,
                _model.Description,
                _model.Visibility,
                _model.MaxPlayers,
                _model.Status
            );

            var result = await CampaignApiClient.UpdateCampaignAsync(Id, request);

            if (result != null)
            {
                MessageService.ShowMessageBar("Campagne mise à jour avec succès !", MessageIntent.Success);
                NavigationManager.NavigateTo($"/campaigns/{Id}");
            }
            else
            {
                MessageService.ShowMessageBar("Erreur lors de la mise à jour de la campagne", MessageIntent.Error);
            }
        }
        catch (Exception ex)
        {
            MessageService.ShowMessageBar($"Erreur: {ex.Message}", MessageIntent.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string GetGameTypeDisplay()
    {
        if (_campaign == null) return string.Empty;
        
        return _campaign.GameType switch
        {
            GameType.Generic => "Générique",
            GameType.DnD5e => "D&D 5e",
            GameType.Skyrim => "Skyrim",
            GameType.Custom => "Personnalisé",
            GameType.Empty => "Vide",
            GameType.Pathfinder => "Pathfinder",
            GameType.CallOfCthulhu => "Call of Cthulhu",
            GameType.Warhammer => "Warhammer",
            GameType.Cyberpunk => "Cyberpunk",
            _ => _campaign.GameType.ToString()
        };
    }

    public class UpdateCampaignModel
    {
        [Required(ErrorMessage = "Le nom de la campagne est requis")]
        [StringLength(100, ErrorMessage = "Le nom ne peut pas dépasser 100 caractères")]
        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }

        public Visibility Visibility { get; set; } = Visibility.Private;

        [Range(1, 20, ErrorMessage = "Le nombre de joueurs doit être entre 1 et 20")]
        public int MaxPlayers { get; set; } = 6;

        public CampaignStatus Status { get; set; } = CampaignStatus.Planning;
    }
}
