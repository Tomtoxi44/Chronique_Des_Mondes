@page "/sessions/{SessionId:int}/gm"
@attribute [Authorize]

<PageTitle>Session MJ — Chronique des Mondes</PageTitle>

@if (IsLoading)
{
    <div style="display: flex; justify-content: center; align-items: center; height: 60vh;">
        <AppLoadingSpinner />
    </div>
}
else if (ErrorMessage != null)
{
    <AppEmptyState Icon="bi-exclamation-circle"
                   Title="Erreur"
                   Message="@ErrorMessage" />
}
else if (Session != null)
{
    <div class="session-gm-shell">
        <!-- Topbar session -->
        <div class="session-topbar">
            <div class="session-topbar-left">
                <i class="bi bi-play-circle-fill" style="color: var(--color-success); font-size: 1.1rem;"></i>
                <strong>@Session.CampaignName</strong>
                <span style="color: var(--color-text-muted); font-size: var(--font-size-sm);">
                    — Session démarrée le @Session.StartedAt.ToString("dd/MM/yyyy à HH:mm")
                </span>
            </div>
            <div class="session-topbar-right">
                @if (SelectedChapter != null)
                {
                    <button class="btn btn-ghost btn-sm" @onclick="() => NavigateChapter(-1)"
                            disabled="@(Chapters.OrderBy(c => c.ChapterNumber).First().Id == SelectedChapter.Id)">
                        <i class="bi bi-chevron-left"></i> Précédent
                    </button>
                    <button class="btn btn-ghost btn-sm" @onclick="() => NavigateChapter(1)"
                            disabled="@(Chapters.OrderBy(c => c.ChapterNumber).Last().Id == SelectedChapter.Id)">
                        Suivant <i class="bi bi-chevron-right"></i>
                    </button>
                }
                <button class="btn btn-danger btn-sm" @onclick="EndSession" disabled="@IsEnding">
                    @if (IsEnding)
                    {
                        <span class="btn-spinner"></span>
                    }
                    else
                    {
                        <i class="bi bi-stop-circle"></i>
                    }
                    Terminer la session
                </button>
            </div>
        </div>

        <!-- Contenu principal -->
        <div class="session-gm-body">
            <!-- Sidebar chapitres -->
            <aside class="session-chapters-sidebar">
                <div class="session-sidebar-header">
                    <i class="bi bi-journals"></i>
                    <span>Chapitres</span>
                </div>
                @if (Chapters.Count == 0)
                {
                    <p style="color: var(--color-text-muted); font-size: var(--font-size-sm); padding: var(--spacing-md);">
                        Aucun chapitre.
                    </p>
                }
                else
                {
                    <nav class="chapter-nav-list">
                        @foreach (var ch in Chapters.OrderBy(c => c.ChapterNumber))
                        {
                            var isSelected = SelectedChapter?.Id == ch.Id;
                            var isCurrentSession = Session.CurrentChapterId == ch.Id;
                            <button class="chapter-nav-item @(isSelected ? "active" : "") @(isCurrentSession ? "current-session" : "")"
                                    @onclick="() => SelectChapter(ch)">
                                <span class="chapter-nav-num">@ch.ChapterNumber</span>
                                <span class="chapter-nav-title">@ch.Title</span>
                                @if (ch.IsCompleted)
                                {
                                    <i class="bi bi-check-circle-fill" style="color: var(--color-success); font-size: 0.75rem;"></i>
                                }
                                else if (ch.IsActive)
                                {
                                    <i class="bi bi-circle-fill" style="color: var(--color-primary); font-size: 0.6rem;"></i>
                                }
                            </button>
                        }
                    </nav>
                }
            </aside>

            <!-- Zone contenu du chapitre -->
            <main class="session-chapter-content">
                @if (SelectedChapter == null)
                {
                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: var(--spacing-md); color: var(--color-text-muted);">
                        <i class="bi bi-book" style="font-size: 3rem; opacity: 0.3;"></i>
                        <p>Sélectionnez un chapitre pour commencer.</p>
                    </div>
                }
                else
                {
                    <div class="session-chapter-header">
                        <div>
                            <p class="chapter-number-label">Chapitre @SelectedChapter.ChapterNumber</p>
                            <h2 class="chapter-title-large">@SelectedChapter.Title</h2>
                        </div>
                        <div style="display: flex; gap: var(--spacing-sm);">
                            @if (SelectedChapter.IsCompleted)
                            {
                                <span class="status-badge status-completed">Terminé</span>
                            }
                            else if (SelectedChapter.IsActive)
                            {
                                <span class="status-badge status-active">En cours</span>
                            }
                        </div>
                    </div>

                    <div class="session-chapter-body">
                        <div id="session-chapter-preview-content">
                        @if (!string.IsNullOrWhiteSpace(SelectedChapter.Content))
                        {
                            <div class="chapter-content-text">@RenderChapterContent(SelectedChapter.Content)</div>
                        }
                        else
                        {
                            <p style="color: var(--color-text-muted); font-style: italic;">Ce chapitre n'a pas encore de contenu.</p>
                        }
                        </div>

                        @if (ChapterNpcs.Count > 0)
                        {
                            <div class="npc-panel" style="margin-top: var(--spacing-lg);">
                                <div class="npc-panel-header">
                                    <i class="bi bi-person-badge"></i>
                                    <span>PNJ (@ChapterNpcs.Count)</span>
                                </div>
                                <div class="npc-list">
                                    @foreach (var npc in ChapterNpcs)
                                    {
                                        <div class="npc-card" id="gm-npc-@npc.Id">
                                            <div class="npc-card-header">
                                                <strong>@npc.DisplayName</strong>
                                                @if (npc.Age.HasValue)
                                                {
                                                    <span style="color: var(--color-text-muted); font-size: var(--font-size-sm); margin-left: 6px;">@npc.Age ans</span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrEmpty(npc.Description))
                                            {
                                                <p class="npc-description">@npc.Description</p>
                                            }
                                            @if (!string.IsNullOrEmpty(npc.PhysicalDescription))
                                            {
                                                <p class="npc-description" style="font-style: italic; color: var(--color-text-muted);">@npc.PhysicalDescription</p>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </main>

            <!-- Sidebar participants -->
            <aside class="session-participants-sidebar">
                <div class="session-sidebar-header">
                    <i class="bi bi-people"></i>
                    <span>Joueurs (@Session.Participants.Count())</span>
                </div>
                <div class="participants-list">
                    @foreach (var p in Session.Participants)
                    {
                        var sheet = WorldCharacters.FirstOrDefault(wc => wc.Id == p.WorldCharacterId);
                        var isSheetOpen = SelectedPlayerSheet?.Id == sheet?.Id;
                        <div>
                            <button class="participant-card participant-card-btn @(isSheetOpen ? "selected" : "")"
                                    @onclick="() => TogglePlayerSheet(p)" title="Voir la fiche personnage">
                                <div class="participant-avatar">
                                    @p.CharacterName.Substring(0, Math.Min(2, p.CharacterName.Length)).ToUpper()
                                </div>
                                <div class="participant-info">
                                    <span class="participant-name">@p.CharacterName</span>
                                    <span class="participant-player">@p.UserName</span>
                                </div>
                                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:2px;">
                                    <span class="status-badge @GetParticipantStatusClass(p.Status)" style="font-size: 0.65rem; padding: 2px 6px;">
                                        @GetParticipantStatusLabel(p.Status)
                                    </span>
                                    <i class="bi @(isSheetOpen ? "bi-chevron-up" : "bi-chevron-down")" style="font-size: 0.7rem; color: var(--color-text-muted);"></i>
                                </div>
                            </button>

                            @if (isSheetOpen && sheet != null)
                            {
                                var fields = ParseGameSpecificData(sheet.GameSpecificData);
                                <div class="player-sheet-panel">
                                    <div class="info-grid" style="grid-template-columns: 1fr 1fr;">
                                        @if (sheet.Level.HasValue)
                                        {
                                            <div><span class="info-label">Niveau</span><span class="info-value">@sheet.Level</span></div>
                                        }
                                        @if (sheet.CurrentHealth.HasValue && sheet.MaxHealth.HasValue)
                                        {
                                            <div><span class="info-label">PV</span><span class="info-value">@sheet.CurrentHealth/@sheet.MaxHealth</span></div>
                                        }
                                        @if (fields.TryGetValue("class", out var cls))
                                        {
                                            <div><span class="info-label">Classe</span><span class="info-value">@cls</span></div>
                                        }
                                        @if (fields.TryGetValue("race", out var race))
                                        {
                                            <div><span class="info-label">Race</span><span class="info-value">@race</span></div>
                                        }
                                    </div>
                                    @{
                                        var statKeys = new[] { ("strength","FOR"),("dexterity","DEX"),("constitution","CON"),("intelligence","INT"),("wisdom","SAG"),("charisma","CHA") };
                                        var hasStats = statKeys.Any(s => fields.ContainsKey(s.Item1));
                                    }
                                    @if (hasStats)
                                    {
                                        <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:4px;margin-top:var(--spacing-xs);">
                                            @foreach (var (key, abbr) in statKeys)
                                            {
                                                @if (fields.TryGetValue(key, out var val))
                                                {
                                                    <div class="char-stat-box" style="padding:4px 2px;">
                                                        <span class="char-stat-label" style="font-size:0.6rem;">@abbr</span>
                                                        <span class="char-stat-value" style="font-size:0.85rem;">@val</span>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    @if (!Session.Participants.Any())
                    {
                        <p style="color: var(--color-text-muted); font-size: var(--font-size-sm); padding: var(--spacing-sm);">
                            Aucun joueur invité.
                        </p>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Session.WelcomeMessage))
                {
                    <div style="margin-top: var(--spacing-md); padding: var(--spacing-sm); background: var(--color-surface-alt); border-radius: var(--border-radius-sm); border-left: 3px solid var(--color-primary);">
                        <p style="font-size: var(--font-size-xs); color: var(--color-text-muted); margin-bottom: 4px;">Message de session</p>
                        <p style="font-size: var(--font-size-sm);">@Session.WelcomeMessage</p>
                    </div>
                }

                <!-- Chat + Dés MJ -->
                <div class="gm-chat-section">
                    <div class="session-sidebar-header" style="border-top: 1px solid var(--color-border); margin-top: var(--spacing-sm);">
                        <i class="bi bi-chat-dots"></i>
                        <span>Chat & Dés</span>
                        @if (!IsHubConnected)
                        {
                            <span style="font-size: var(--font-size-xs); color: var(--color-text-muted); margin-left: auto;">
                                <i class="bi bi-wifi-off"></i>
                            </span>
                        }
                    </div>
                    <div class="gm-chat-feed" id="gm-chat-feed">
                        @if (ChatEntries.Count == 0)
                        {
                            <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); font-style: italic; text-align: center; padding: var(--spacing-sm);">
                                Aucun message.
                            </p>
                        }
                        @foreach (var entry in ChatEntries)
                        {
                            <div class="chat-entry">
                                <div class="chat-entry-meta">
                                    <span class="chat-entry-author">@entry.UserName</span>
                                    <span class="chat-entry-time">@entry.Timestamp.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                                @if (entry.Type == "text")
                                {
                                    <span class="chat-entry-text">@entry.Text</span>
                                }
                                else if (entry.Type == "dice" && entry.Results != null)
                                {
                                    <div class="chat-entry-dice">
                                        <span class="chat-dice-type">@entry.DiceType</span>
                                        <span>→</span>
                                        <span class="chat-dice-result">@string.Join(", ", entry.Results)</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="gm-dice-row">
                        @foreach (var faces in new[] { 2, 4, 6, 8, 10, 12, 20, 100 })
                        {
                            var f = faces;
                            <button class="gm-dice-btn @(RollingDie == f ? "rolling" : "")"
                                    @onclick="() => RollDice(f)"
                                    disabled="@(!IsHubConnected || RollingDie.HasValue)"
                                    title="Lancer un D@f">
                                D@f
                            </button>
                        }
                    </div>
                    <div class="gm-chat-input-row">
                        <input class="form-control" style="font-size: var(--font-size-xs);"
                               placeholder="Envoyer un message…"
                               @bind="ChatInput"
                               @bind:event="oninput"
                               @onkeydown="@(async e => { if (e.Key == "Enter") await SendMessage(); })"
                               disabled="@(!IsHubConnected)" />
                        <button class="btn btn-primary btn-sm" @onclick="SendMessage"
                                disabled="@(!IsHubConnected || string.IsNullOrWhiteSpace(ChatInput))">
                            <i class="bi bi-send"></i>
                        </button>
                    </div>
                </div>
            </aside>
        </div>
    </div>
}
