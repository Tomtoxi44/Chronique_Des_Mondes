@page "/profile"
@using Cdm.Web.Services
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@layout AppLayout
@attribute [Authorize]

<PageTitle>Mon Profil - Chronique des Mondes</PageTitle>

<div class="profile-page">
    @if (profile == null && string.IsNullOrEmpty(errorMessage))
    {
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <span class="loading-text">Chargement du profil...</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="card" style="max-width: 600px; margin: 0 auto;">
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="bi bi-exclamation-triangle text-crimson"></i>
                </div>
                <h3 class="empty-state-title">Erreur de chargement</h3>
                <p class="empty-state-description">@errorMessage</p>
                <button type="button" class="btn btn-primary" @onclick="LoadProfileAsync">
                    <i class="bi bi-arrow-clockwise"></i>
                    Réessayer
                </button>
            </div>
        </div>
    }
    else if (profile != null)
    {
        <!-- Profile Header Card -->
        <div class="card card-gold">
            <div class="profile-header">
                <AuthorizeView>
                    <Authorized>
                        <div class="profile-avatar">
                            @if (!string.IsNullOrEmpty(profile.AvatarUrl))
                            {
                                <img src="@profile.AvatarUrl" alt="Avatar de @profile.Nickname" />
                            }
                            else
                            {
                                <i class="bi bi-person-fill"></i>
                            }
                        </div>
                        <h1 class="profile-name">@profile.Nickname</h1>
                        <p class="profile-email">
                            <i class="bi bi-envelope"></i>
                            @profile.Email
                        </p>
                        @if (!string.IsNullOrEmpty(profile.Username))
                        {
                            <span class="badge badge-gold" style="margin-top: var(--spacing-sm);">
                                <i class="bi bi-at"></i> @profile.Username
                            </span>
                        }
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>

        <!-- Role Management -->
        <div class="profile-section">
            <RoleManager />
        </div>

        <!-- Account Information -->
        <div class="card">
            <div class="card-header">
                <h2 class="profile-section-title">
                    <i class="bi bi-info-circle"></i>
                    Informations du compte
                </h2>
            </div>
            <div class="card-body">
                <div class="profile-info-grid">
                    <div class="profile-info-item">
                        <span class="profile-info-label">Membre depuis</span>
                        <span class="profile-info-value">
                            <i class="bi bi-calendar3 text-gold"></i>
                            @profile.CreatedAt.ToString("dd MMMM yyyy")
                        </span>
                    </div>
                    
                    @if (profile.LastLoginAt.HasValue)
                    {
                        <div class="profile-info-item">
                            <span class="profile-info-label">Dernière connexion</span>
                            <span class="profile-info-value">
                                <i class="bi bi-clock text-gold"></i>
                                @profile.LastLoginAt.Value.ToString("dd MMMM yyyy à HH:mm")
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header">
                <h2 class="profile-section-title">
                    <i class="bi bi-lightning"></i>
                    Actions rapides
                </h2>
            </div>
            <div class="card-body">
                <div class="content-grid content-grid-3">
                    <a href="/settings" class="btn btn-secondary btn-block">
                        <i class="bi bi-gear"></i>
                        Paramètres
                    </a>
                    <a href="/characters" class="btn btn-secondary btn-block">
                        <i class="bi bi-people"></i>
                        Mes personnages
                    </a>
                    <a href="/campaigns" class="btn btn-secondary btn-block">
                        <i class="bi bi-map"></i>
                        Mes campagnes
                    </a>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success" style="margin-top: var(--spacing-lg);">
                <i class="bi bi-check-circle"></i>
                @successMessage
            </div>
        }
    }
</div>

@code {
    [Inject] private ProfileApiClient ProfileClient { get; set; } = default!;
    [Inject] private ILogger<Profile> Logger { get; set; } = default!;

    private ProfileResponse? profile;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        errorMessage = string.Empty;
        try
        {
            profile = await ProfileClient.GetProfileAsync();
            if (profile == null)
            {
                errorMessage = "Impossible de charger les informations du profil.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading profile");
            errorMessage = "Une erreur s'est produite lors du chargement du profil.";
        }
    }

    private async Task HandleSaveAsync(UpdateProfileRequest request)
    {
        successMessage = string.Empty;
        errorMessage = string.Empty;

        try
        {
            var updatedProfile = await ProfileClient.UpdateProfileAsync(request);

            if (updatedProfile != null)
            {
                profile = updatedProfile;
                successMessage = "Profil mis à jour avec succès !";
            }
            else
            {
                errorMessage = "Erreur lors de la mise à jour du profil.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating profile");
            errorMessage = "Erreur lors de la mise à jour du profil.";
        }
    }

    private async Task HandleAvatarUploadAsync(IBrowserFile file)
    {
        successMessage = string.Empty;
        errorMessage = string.Empty;

        try
        {
            var avatarUrl = await ProfileClient.UploadAvatarAsync(file);

            if (avatarUrl != null)
            {
                if (profile != null)
                {
                    profile.AvatarUrl = avatarUrl;
                }
                successMessage = "Avatar mis à jour avec succès !";
                await LoadProfileAsync();
            }
            else
            {
                errorMessage = "Erreur lors de l'upload de l'avatar.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error uploading avatar");
            errorMessage = "Erreur lors de l'upload de l'avatar.";
        }
    }
}
