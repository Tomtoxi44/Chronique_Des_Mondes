@page "/profile"
@using Cdm.Web.Services
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@layout MainLayout
@attribute [Authorize]

<PageTitle>Mon Profil - Chronique des Mondes</PageTitle>

<FluentStack Orientation="Orientation.Vertical" Style="gap: 24px;">
    <!-- Page Header -->
    <FluentStack Orientation="Orientation.Vertical" Style="gap: 4px;">
        <FluentLabel Typo="Typography.H4">Mon Profil</FluentLabel>
        <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">Gerez vos informations personnelles</FluentLabel>
    </FluentStack>

    @if (profile == null && string.IsNullOrEmpty(errorMessage))
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" 
                         HorizontalAlignment="HorizontalAlignment.Center"
                         Style="padding: 48px; gap: 16px;">
                <FluentProgressRing />
                <FluentLabel>Chargement du profil...</FluentLabel>
            </FluentStack>
        </FluentCard>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <FluentMessageBar Title="Erreur de chargement" Intent="MessageIntent.Error" Style="width: 100%;">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 16px;">
                <span>@errorMessage</span>
                <FluentButton Appearance="Appearance.Outline" 
                              IconStart="@(new Icons.Regular.Size20.ArrowClockwise())"
                              OnClick="@LoadProfileAsync">
                    Reessayer
                </FluentButton>
            </FluentStack>
        </FluentMessageBar>
    }
    else if (profile != null)
    {
        <!-- Profile Header Card -->
        <FluentCard Style="background: linear-gradient(135deg, var(--accent-fill-rest) 0%, var(--accent-fill-hover) 100%);">
            <AuthorizeView>
                <Authorized>
                    <FluentStack Orientation="Orientation.Horizontal" 
                                 VerticalAlignment="VerticalAlignment.Center"
                                 Wrap="true"
                                 Style="gap: 24px; padding: 16px;">
                        @if (!string.IsNullOrEmpty(profile.AvatarUrl))
                        {
                            <FluentPersona Image="@profile.AvatarUrl"
                                           Name="@profile.Nickname"
                                           ImageSize="100px" />
                        }
                        else
                        {
                            <FluentPersona Name="@profile.Nickname"
                                           ImageSize="100px" />
                        }
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                            <FluentLabel Typo="Typography.H3" Style="color: white;">@profile.Nickname</FluentLabel>
                            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 4px; color: white; opacity: 0.9;">
                                <FluentIcon Value="@(new Icons.Regular.Size16.Mail())" />
                                <FluentLabel Style="color: white;">@profile.Email</FluentLabel>
                            </FluentStack>
                            @if (!string.IsNullOrEmpty(profile.Username))
                            {
                                <FluentBadge Appearance="Appearance.Accent">
                                    @@ @profile.Username
                                </FluentBadge>
                            }
                        </FluentStack>
                    </FluentStack>
                </Authorized>
            </AuthorizeView>
        </FluentCard>

        <!-- Role Management -->
        <RoleManager />

        <!-- Account Information -->
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Info())" Color="Color.Accent" />
                    <FluentLabel Typo="Typography.H5">Informations du compte</FluentLabel>
                </FluentStack>

                <FluentGrid Spacing="3">
                    <FluentGridItem xs="12" md="6">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 4px;">
                            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Membre depuis</FluentLabel>
                            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                                <FluentIcon Value="@(new Icons.Regular.Size16.Calendar())" Color="Color.Accent" />
                                <FluentLabel Typo="Typography.Body">@profile.CreatedAt.ToString("dd MMMM yyyy")</FluentLabel>
                            </FluentStack>
                        </FluentStack>
                    </FluentGridItem>
                    
                    @if (profile.LastLoginAt.HasValue)
                    {
                        <FluentGridItem xs="12" md="6">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 4px;">
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Derniere connexion</FluentLabel>
                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                                    <FluentIcon Value="@(new Icons.Regular.Size16.Clock())" Color="Color.Accent" />
                                    <FluentLabel Typo="Typography.Body">@profile.LastLoginAt.Value.ToString("dd MMMM yyyy a HH:mm")</FluentLabel>
                                </FluentStack>
                            </FluentStack>
                        </FluentGridItem>
                    }
                </FluentGrid>
            </FluentStack>
        </FluentCard>

        <!-- Quick Actions -->
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Flash())" Color="Color.Accent" />
                    <FluentLabel Typo="Typography.H5">Actions rapides</FluentLabel>
                </FluentStack>

                <FluentGrid Spacing="3">
                    <FluentGridItem xs="12" sm="4">
                        <FluentButton Appearance="Appearance.Outline" 
                                      Href="/settings"
                                      IconStart="@(new Icons.Regular.Size20.Settings())"
                                      Style="width: 100%;">
                            Parametres
                        </FluentButton>
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="4">
                        <FluentButton Appearance="Appearance.Outline" 
                                      Href="/characters"
                                      IconStart="@(new Icons.Regular.Size20.People())"
                                      Style="width: 100%;">
                            Mes personnages
                        </FluentButton>
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="4">
                        <FluentButton Appearance="Appearance.Outline" 
                                      Href="/campaigns"
                                      IconStart="@(new Icons.Regular.Size20.BookOpen())"
                                      Style="width: 100%;">
                            Mes campagnes
                        </FluentButton>
                    </FluentGridItem>
                </FluentGrid>
            </FluentStack>
        </FluentCard>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <FluentMessageBar Title="Succes" Intent="MessageIntent.Success" Style="width: 100%;">
                @successMessage
            </FluentMessageBar>
        }
    }
</FluentStack>

@code {
    [Inject] private ProfileApiClient ProfileClient { get; set; } = default!;
    [Inject] private ILogger<Profile> Logger { get; set; } = default!;

    private ProfileResponse? profile;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        errorMessage = string.Empty;
        try
        {
            profile = await ProfileClient.GetProfileAsync();
            if (profile == null)
            {
                errorMessage = "Impossible de charger les informations du profil.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading profile");
            errorMessage = "Une erreur s'est produite lors du chargement du profil.";
        }
    }

    private async Task HandleSaveAsync(UpdateProfileRequest request)
    {
        successMessage = string.Empty;
        errorMessage = string.Empty;

        try
        {
            var updatedProfile = await ProfileClient.UpdateProfileAsync(request);

            if (updatedProfile != null)
            {
                profile = updatedProfile;
                successMessage = "Profil mis a jour avec succes !";
            }
            else
            {
                errorMessage = "Erreur lors de la mise a jour du profil.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating profile");
            errorMessage = "Erreur lors de la mise a jour du profil.";
        }
    }

    private async Task HandleAvatarUploadAsync(IBrowserFile file)
    {
        successMessage = string.Empty;
        errorMessage = string.Empty;

        try
        {
            var avatarUrl = await ProfileClient.UploadAvatarAsync(file);

            if (avatarUrl != null)
            {
                if (profile != null)
                {
                    profile.AvatarUrl = avatarUrl;
                }
                successMessage = "Avatar mis a jour avec succes !";
                await LoadProfileAsync();
            }
            else
            {
                errorMessage = "Erreur lors de l'upload de l'avatar.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error uploading avatar");
            errorMessage = "Erreur lors de l'upload de l'avatar.";
        }
    }
}
