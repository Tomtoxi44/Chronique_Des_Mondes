@page "/Error"
@using System.Diagnostics

<PageTitle>Erreur - Chronique des Mondes</PageTitle>

<div class="error-page">
    <div class="error-container">
        <div class="error-icon">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        
        <h1 class="error-title">Une erreur est survenue</h1>
        <p class="error-message">
            Quelque chose s'est mal passé lors du traitement de votre requête.
            Nos scribes travaillent à résoudre ce problème.
        </p>

        @if (ShowRequestId)
        {
            <div class="error-details">
                <span class="error-label">ID de requête :</span>
                <code class="error-code">@requestId</code>
            </div>
        }

        <div class="error-actions">
            <a href="/" class="btn btn-primary">
                <i class="bi bi-house-door"></i>
                Retour à l'accueil
            </a>
            <button type="button" class="btn btn-secondary" onclick="history.back()">
                <i class="bi bi-arrow-left"></i>
                Page précédente
            </button>
        </div>
    </div>
</div>

<style>
    .error-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--spacing-xl);
        background: var(--color-background-primary);
    }
    
    .error-container {
        text-align: center;
        max-width: 500px;
    }
    
    .error-icon {
        width: 120px;
        height: 120px;
        margin: 0 auto var(--spacing-xl);
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(139, 41, 66, 0.1);
        border: 2px solid rgba(139, 41, 66, 0.3);
        border-radius: 50%;
        font-size: 3rem;
        color: var(--color-crimson);
    }
    
    .error-title {
        font-family: var(--font-display);
        font-size: var(--font-size-h1);
        font-weight: var(--font-weight-bold);
        color: var(--color-text-primary);
        margin: 0 0 var(--spacing-md) 0;
    }
    
    .error-message {
        font-size: var(--font-size-lg);
        color: var(--color-text-secondary);
        margin: 0 0 var(--spacing-xl) 0;
        line-height: 1.6;
    }
    
    .error-details {
        background: var(--color-background-secondary);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: var(--spacing-md);
        margin-bottom: var(--spacing-xl);
    }
    
    .error-label {
        font-size: var(--font-size-small);
        color: var(--color-text-tertiary);
        display: block;
        margin-bottom: var(--spacing-xs);
    }
    
    .error-code {
        font-family: monospace;
        font-size: var(--font-size-small);
        color: var(--color-gold);
        background: var(--color-background-elevated);
        padding: var(--spacing-xs) var(--spacing-sm);
        border-radius: var(--radius-sm);
    }
    
    .error-actions {
        display: flex;
        justify-content: center;
        gap: var(--spacing-md);
        flex-wrap: wrap;
    }
</style>

@code{
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private string? requestId;
    private bool ShowRequestId => !string.IsNullOrEmpty(requestId);

    protected override void OnInitialized()
    {
        requestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
