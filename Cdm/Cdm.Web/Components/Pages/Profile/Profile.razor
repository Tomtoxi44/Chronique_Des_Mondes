@page "/profile"
@attribute [Authorize]

<PageTitle>@L["Profile_Title"] — Chronique des Mondes</PageTitle>

<AppPageHeader Title="@L["Profile_Title"]" Icon="bi-person-circle" />

@if (IsLoading)
{
    <AppLoadingSpinner Label="@L["Common_Loading"]" />
}
else
{
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-error" style="margin-bottom: var(--spacing-lg);">
            <i class="bi bi-exclamation-triangle-fill"></i>
            @ErrorMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="alert alert-success" style="margin-bottom: var(--spacing-lg);">
            <i class="bi bi-check-circle-fill"></i>
            @SuccessMessage
        </div>
    }

    <div style="display: grid; grid-template-columns: 280px 1fr; gap: var(--spacing-xl); max-width: 900px;">

        <!-- Avatar & info -->
        <div class="cdm-card" style="text-align: center;">
            <div class="profile-avatar-large" style="margin: 0 auto var(--spacing-md);">
                @if (!string.IsNullOrEmpty(UserProfile?.AvatarUrl))
                {
                    <img src="@UserProfile.AvatarUrl" alt="Avatar" class="avatar-img-large" />
                }
                else
                {
                    <span class="avatar-initials-large">@UserInitials</span>
                }
            </div>
            <h3 class="card-title">@(UserProfile?.Nickname ?? UserName)</h3>
            <p style="color: var(--color-text-muted); font-size: var(--font-size-sm);">@UserProfile?.Email</p>
            @if (UserProfile?.CreatedAt != null)
            {
                <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-sm);">
                    <i class="bi bi-calendar3"></i>
                    @L["Profile_MemberSince"] @UserProfile.CreatedAt.ToString("MMMM yyyy")
                </p>
            }
        </div>

        <!-- Formulaire -->
        <div class="cdm-card">
            <h3 class="card-title" style="margin-bottom: var(--spacing-lg);">Informations du profil</h3>
            <EditForm Model="UpdateModel" OnValidSubmit="HandleSave" FormName="profile-edit">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label class="form-label">@L["Profile_Username"]</label>
                    <InputText @bind-Value="UpdateModel.Username" class="form-control"
                               placeholder="nom_utilisateur" />
                    <ValidationMessage For="() => UpdateModel.Username" class="form-error" />
                    <span class="form-hint">3-30 caractères, utilisé comme identifiant public</span>
                </div>

                <div class="form-actions" style="margin-top: var(--spacing-lg);">
                    <button type="submit" class="btn btn-primary" disabled="@IsSaving">
                        @if (IsSaving) { <AppLoadingSpinner Inline="true" Size="sm" /> }
                        else { <i class="bi bi-check-circle"></i> }
                        @(IsSaving ? L["Common_Saving"] : L["Profile_Save"])
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}
