@* World description editor (extracted from WorldDetail): plain-text draft with
   dirty tracking and its own save state. Notifies the parent with the updated world. *@
@namespace Cdm.Web.Components.Pages.Worlds
@using Cdm.Business.Abstraction.DTOs
@inject Cdm.Web.Services.ApiClients.WorldApiClient WorldClient

<div class="editor-section">
    <div class="world-section-header">
        <div>
            <h2 class="world-section-title">
                <i class="bi bi-pencil" style="color: var(--theme-primary, var(--color-primary)); margin-right: var(--spacing-xs);"></i>
                Description — @World.Name
            </h2>
        </div>
        <div style="display: flex; gap: var(--spacing-sm); align-items: center;">
            @if (!string.IsNullOrEmpty(SaveMessage))
            {
                <span style="font-size: var(--font-size-xs); color: @(SaveSuccess ? "var(--color-success)" : "var(--color-error)");">
                    @SaveMessage
                </span>
            }
            <button class="btn btn-primary btn-sm" @onclick="SaveDescription" disabled="@IsSaving">
                @if (IsSaving)
                {
                    <i class="bi bi-hourglass-split"></i>
                }
                else
                {
                    <i class="bi bi-floppy"></i>
                }
                Enregistrer
            </button>
        </div>
    </div>

    <div class="description-editor-container" style="flex: 1; min-height: 0;">
        <div class="description-editor-toolbar">
            <span class="description-editor-hint">
                <i class="bi bi-info-circle"></i>
                Texte brut — les retours à la ligne sont préservés
            </span>
            @if (DescriptionDirty)
            {
                <span style="font-size: var(--font-size-xs); color: var(--color-warning);">Modifications non sauvegardées</span>
            }
        </div>
        <textarea class="description-editor-textarea"
                  placeholder="Décrivez votre monde : son histoire, sa géographie, ses factions, ses mystères..."
                  value="@DescriptionDraft"
                  @oninput="OnDescriptionInput"></textarea>
    </div>
</div>

@code {
    [Parameter] public int WorldId { get; set; }
    [Parameter] public WorldDto World { get; set; } = default!;

    /// <summary>Raised with the updated world after a successful save.</summary>
    [Parameter] public EventCallback<WorldDto> OnSaved { get; set; }

    private string DescriptionDraft = string.Empty;
    private bool DescriptionDirty;
    private bool IsSaving;
    private string? SaveMessage;
    private bool SaveSuccess;

    private int _loadedWorldId;

    protected override void OnParametersSet()
    {
        // Seed the draft once per world; never clobber in-progress edits.
        if (World != null && _loadedWorldId != World.Id)
        {
            _loadedWorldId = World.Id;
            DescriptionDraft = World.Description ?? string.Empty;
            DescriptionDirty = false;
            SaveMessage = null;
        }
    }

    private void OnDescriptionInput(ChangeEventArgs e)
    {
        DescriptionDraft = e.Value?.ToString() ?? string.Empty;
        DescriptionDirty = true;
        SaveMessage = null;
    }

    private async Task SaveDescription()
    {
        if (World == null) return;
        IsSaving = true;
        SaveMessage = null;
        try
        {
            var result = await WorldClient.UpdateWorldAsync(
                WorldId,
                new UpdateWorldRequest(World.Name, DescriptionDraft, World.IsActive, World.GameType));

            if (result != null)
            {
                DescriptionDirty = false;
                SaveSuccess = true;
                SaveMessage = "Description sauvegardée.";
                if (OnSaved.HasDelegate)
                {
                    await OnSaved.InvokeAsync(result);
                }
            }
            else
            {
                SaveSuccess = false;
                SaveMessage = "Erreur lors de la sauvegarde.";
            }
        }
        finally
        {
            IsSaving = false;
        }
    }
}
