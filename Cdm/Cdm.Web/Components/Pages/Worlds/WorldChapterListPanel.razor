@* Chapter list of a campaign with drag & drop reordering (extracted from WorldDetail).
   Owns the drag state; hands the reordered list back so the parent can refresh its nav. *@
@namespace Cdm.Web.Components.Pages.Worlds
@using Cdm.Business.Abstraction.DTOs
@inject Cdm.Web.Services.ApiClients.ChapterApiClient ChapterClient
@inject Microsoft.Extensions.Localization.IStringLocalizer<Cdm.Web.Resources.AppStrings> L

<div class="cdm-card">
    <AppSectionTitle Title="Chapitres" Icon="bi-journals">
        <Actions>
            @if (IsReordering)
            {
                <span style="font-size: var(--font-size-xs); color: var(--color-text-muted);">Enregistrement...</span>
            }
            <a href="/worlds/@WorldId?campaignId=@CampaignId&section=new-chapter" class="btn btn-ghost btn-sm">
                <i class="bi bi-plus"></i>
                @L["Chapters_Create"]
            </a>
        </Actions>
    </AppSectionTitle>

    @if (Chapters is { Count: > 0 })
    {
        <div class="chapter-drag-list">
            @foreach (var ch in Chapters.OrderBy(c => c.ChapterNumber))
            {
                var chIcon = ch.IsCompleted ? "bi-check-circle-fill" : ch.IsActive ? "bi-circle-fill" : "bi-circle";
                var isDragOver = _dragOverChapterId == ch.Id;
                <div class="chapter-drag-row @(isDragOver ? "drag-over" : "")"
                     draggable="true"
                     @ondragstart="() => OnChapterDragStart(ch)"
                     @ondragover:preventDefault
                     @ondragover="() => OnChapterDragOver(ch)"
                     @ondragleave="OnChapterDragLeave"
                     @ondrop="() => OnChapterDrop(ch)">
                    <i class="bi bi-grip-vertical drag-handle"></i>
                    <a href="/worlds/@WorldId?campaignId=@CampaignId&chapterId=@ch.Id" class="chapter-drag-link">
                        <i class="bi @chIcon" style="color: @(ch.IsCompleted ? "var(--color-success)" : ch.IsActive ? "var(--theme-primary, var(--color-primary))" : "var(--color-text-muted)");"></i>
                        <span style="flex: 1;">Ch. @ch.ChapterNumber — @ch.Title</span>
                        @if (ch.IsCompleted)
                        {
                            <span class="status-badge status-completed">@L["Common_Completed"]</span>
                        }
                        else if (ch.IsActive)
                        {
                            <span class="status-badge status-active">@L["Common_InProgress"]</span>
                        }
                    </a>
                </div>
            }
        </div>
        <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-sm);">
            <i class="bi bi-grip-vertical"></i> Glisser-déposer pour réordonner
        </p>
    }
    else
    {
        <p style="color: var(--color-text-muted); font-style: italic; font-size: var(--font-size-sm);">
            Aucun chapitre pour le moment.
        </p>
    }
</div>

@code {
    [Parameter] public int WorldId { get; set; }
    [Parameter] public int CampaignId { get; set; }

    /// <summary>The campaign's chapters (shared list owned by the parent).</summary>
    [Parameter] public List<ChapterDto> Chapters { get; set; } = new();

    /// <summary>Raised with the renumbered list after a reorder, so the parent can refresh its nav.</summary>
    [Parameter] public EventCallback<List<ChapterDto>> OnReordered { get; set; }

    private ChapterDto? _draggedChapter;
    private int? _dragOverChapterId;
    private bool IsReordering;

    private void OnChapterDragStart(ChapterDto chapter) => _draggedChapter = chapter;

    private void OnChapterDragOver(ChapterDto target) => _dragOverChapterId = target.Id;

    private void OnChapterDragLeave() => _dragOverChapterId = null;

    private async Task OnChapterDrop(ChapterDto target)
    {
        if (_draggedChapter == null || _draggedChapter.Id == target.Id || Chapters == null) return;

        // Reorder list in memory
        var ordered = Chapters.OrderBy(c => c.ChapterNumber).ToList();
        var from = ordered.IndexOf(_draggedChapter);
        var to = ordered.IndexOf(target);
        if (from < 0 || to < 0) return;

        ordered.RemoveAt(from);
        ordered.Insert(to, _draggedChapter);

        // Renumber starting at 1
        IsReordering = true;
        _draggedChapter = null;
        _dragOverChapterId = null;

        var tasks = new List<Task>();
        for (int i = 0; i < ordered.Count; i++)
        {
            var ch = ordered[i];
            var newNumber = i + 1;
            if (ch.ChapterNumber != newNumber)
            {
                ch.ChapterNumber = newNumber;
                var dto = new CreateChapterDto
                {
                    CampaignId = ch.CampaignId,
                    ChapterNumber = newNumber,
                    Title = ch.Title,
                    Content = ch.Content
                };
                tasks.Add(ChapterClient.UpdateChapterAsync(ch.Id, dto).ContinueWith(_ => { }));
            }
        }

        Chapters = ordered;
        StateHasChanged();

        await Task.WhenAll(tasks);
        IsReordering = false;

        if (OnReordered.HasDelegate)
        {
            await OnReordered.InvokeAsync(ordered);
        }
    }
}
