@page "/worlds/{WorldId:int}"
@attribute [Authorize]
@implements IDisposable

<PageTitle>@(World?.Name ?? "Monde") — Chronique des Mondes</PageTitle>

@if (IsLoading)
{
    <div style="padding: var(--spacing-xl);">
        <AppLoadingSpinner Label="@L["Common_Loading"]" />
    </div>
}
else if (World == null)
{
    <AppEmptyState Icon="bi-globe2"
                   Title="@L["Worlds_NotFound"]"
                   Message="@L["Worlds_NotFoundMessage"]">
        <ActionContent>
            <a href="/worlds" class="btn btn-primary">
                <i class="bi bi-arrow-left"></i>
                @L["Common_Back"]
            </a>
        </ActionContent>
    </AppEmptyState>
}
else
{
    <AppThemeWrapper GameType="@World.GameType">

        @* ──────────────────────────────────────────────────────────
           SECTION: VUE D'ENSEMBLE (par défaut)
           ────────────────────────────────────────────────────────── *@
        @if ((Section == null || Section == "new-campaign") && !SelectedCampaignId.HasValue)
        {
            <AppPageHeader Title="@World.Name"
                           Icon="bi-globe2"
                           Breadcrumbs="@Breadcrumbs">
                <Actions>
                    <button class="btn btn-ghost" @onclick="ConfirmDeleteWorld">
                        <i class="bi bi-trash3"></i>
                        @L["Common_Delete"]
                    </button>
                </Actions>
            </AppPageHeader>

            <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: var(--spacing-md); margin-bottom: var(--spacing-xl);">
                <AppStatCard Value="@Campaigns.Count.ToString()" Label="@L["Worlds_Campaigns"]" Icon="bi-map" />
                <AppStatCard Value="@World.CharacterCount.ToString()" Label="@L["Worlds_Characters"]" Icon="bi-people" />
            </div>

            <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                <h3 class="card-title">@L["Worlds_Information"]</h3>
                <div class="info-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-md); margin-top: var(--spacing-md);">
                    <div>
                        <span class="info-label">@L["Worlds_GameType"]</span>
                        <div style="margin-top: var(--spacing-xs);"><AppGameBadge GameType="@World.GameType" /></div>
                    </div>
                    <div>
                        <span class="info-label">@L["Worlds_CreatedAt"]</span>
                        <span class="info-value">@World.CreatedAt.ToString("d MMM yyyy")</span>
                    </div>
                    @if (World.UpdatedAt.HasValue)
                    {
                        <div>
                            <span class="info-label">@L["Worlds_UpdatedAt"]</span>
                            <span class="info-value">@World.UpdatedAt.Value.ToString("d MMM yyyy")</span>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(World.Description))
            {
                <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                    <h3 class="card-title">Description</h3>
                    <p style="color: var(--color-text-secondary); line-height: 1.7; white-space: pre-wrap; margin: var(--spacing-md) 0 0;">@World.Description</p>
                    <a href="/worlds/@WorldId?section=description" class="btn btn-ghost btn-sm" style="margin-top: var(--spacing-md);">
                        <i class="bi bi-pencil"></i> Modifier
                    </a>
                </div>
            }
            else
            {
                <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <h3 class="card-title">Description</h3>
                        <a href="/worlds/@WorldId?section=description" class="btn btn-ghost btn-sm">
                            <i class="bi bi-plus"></i> Ajouter une description
                        </a>
                    </div>
                    <p style="color: var(--color-text-muted); font-style: italic; margin-top: var(--spacing-sm);">Aucune description. Cliquez pour écrire.</p>
                </div>
            }

            @if (Campaigns.Count > 0 || ShowNewCampaignForm)
            {
                <div class="cdm-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-md);">
                        <h3 class="card-title">@L["Worlds_Campaigns"]</h3>
                        <button class="btn btn-ghost btn-sm" @onclick="() => ShowNewCampaignForm = !ShowNewCampaignForm">
                            <i class="bi bi-plus"></i>
                            @L["Campaigns_Create"]
                        </button>
                    </div>

                    @if (ShowNewCampaignForm)
                    {
                        <div style="background: var(--color-bg-secondary); border-radius: var(--radius-md); padding: var(--spacing-md); margin-bottom: var(--spacing-md); border: 1px solid var(--theme-card-border, var(--color-border));">
                            <h4 style="margin: 0 0 var(--spacing-md); font-size: var(--font-size-sm); color: var(--color-text-secondary);">Nouvelle campagne</h4>
                            @if (!string.IsNullOrEmpty(CampaignCreateError))
                            {
                                <div class="alert alert-error" style="margin-bottom: var(--spacing-sm); padding: var(--spacing-sm) var(--spacing-md);">@CampaignCreateError</div>
                            }
                            <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                                <label class="form-label">Nom *</label>
                                <input type="text" class="form-control" @bind="NewCampaign.Name" placeholder="La Quête des Éclats..." />
                            </div>
                            <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" rows="2" @bind="NewCampaign.Description" placeholder="Décrivez cette campagne..."></textarea>
                            </div>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-sm); margin-bottom: var(--spacing-sm);">
                                <div class="form-group">
                                    <label class="form-label">Visibilité</label>
                                    <select class="form-control" @bind="NewCampaign.Visibility">
                                        <option value="@Visibility.Private">Privée</option>
                                        <option value="@Visibility.Public">Publique</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Joueurs max</label>
                                    <input type="number" class="form-control" min="1" max="20" @bind="NewCampaign.MaxPlayers" />
                                </div>
                            </div>
                            <div style="display: flex; gap: var(--spacing-sm);">
                                <button class="btn btn-primary btn-sm" @onclick="CreateCampaignInline" disabled="@IsSaving">
                                    <i class="bi bi-check"></i> Créer
                                </button>
                                <button class="btn btn-ghost btn-sm" @onclick="() => { ShowNewCampaignForm = false; CampaignCreateError = null; }">
                                    @L["Common_Cancel"]
                                </button>
                            </div>
                        </div>
                    }

                    @foreach (var campaign in Campaigns)
                    {
                        <a href="/worlds/@WorldId?campaignId=@campaign.Id" class="campaign-row">
                            <div style="display: flex; align-items: center; gap: var(--spacing-sm);">
                                <i class="bi bi-map" style="color: var(--color-text-muted);"></i>
                                <span>@campaign.Name</span>
                            </div>
                            <span class="status-badge @GetStatusClass(campaign.Status)">@GetStatusLabel(campaign.Status)</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <AppEmptyState Icon="bi-map"
                               Title="Aucune campagne"
                               Message="Ce monde n'a pas encore de campagne.">
                    <ActionContent>
                        <button class="btn btn-primary" @onclick="() => ShowNewCampaignForm = true">
                            <i class="bi bi-plus"></i>
                            @L["Campaigns_Create"]
                        </button>
                    </ActionContent>
                </AppEmptyState>
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: DESCRIPTION EDITOR
           ────────────────────────────────────────────────────────── *@
        @if (Section == "description")
        {
            <div style="display: flex; flex-direction: column; height: calc(100vh - var(--topbar-height) - 2rem); padding: var(--spacing-lg) var(--spacing-xl) var(--spacing-xl);">
                <div class="world-section-header">
                    <div>
                        <h2 class="world-section-title">
                            <i class="bi bi-pencil" style="color: var(--theme-primary, var(--color-primary)); margin-right: var(--spacing-xs);"></i>
                            Description — @World.Name
                        </h2>
                    </div>
                    <div style="display: flex; gap: var(--spacing-sm); align-items: center;">
                        @if (!string.IsNullOrEmpty(SaveMessage))
                        {
                            <span style="font-size: var(--font-size-xs); color: @(SaveSuccess ? "var(--color-success)" : "var(--color-error)");">
                                @SaveMessage
                            </span>
                        }
                        <button class="btn btn-primary btn-sm" @onclick="SaveDescription" disabled="@IsSaving">
                            @if (IsSaving)
                            {
                                <i class="bi bi-hourglass-split"></i>
                            }
                            else
                            {
                                <i class="bi bi-floppy"></i>
                            }
                            Enregistrer
                        </button>
                    </div>
                </div>

                <div class="description-editor-container" style="flex: 1; min-height: 0;">
                    <div class="description-editor-toolbar">
                        <span class="description-editor-hint">
                            <i class="bi bi-info-circle"></i>
                            Texte brut — les retours à la ligne sont préservés
                        </span>
                        @if (DescriptionDirty)
                        {
                            <span style="font-size: var(--font-size-xs); color: var(--color-warning);">Modifications non sauvegardées</span>
                        }
                    </div>
                    <textarea class="description-editor-textarea"
                              placeholder="Décrivez votre monde : son histoire, sa géographie, ses factions, ses mystères..."
                              value="@DescriptionDraft"
                              @oninput="OnDescriptionInput"></textarea>
                </div>
            </div>
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: DÉTAIL CAMPAGNE
           ────────────────────────────────────────────────────────── *@
        @if (SelectedCampaignId.HasValue && SelectedChapterId == null && Section == null)
        {
            @if (SelectedCampaign == null)
            {
                <div style="padding: var(--spacing-xl);">
                    <AppLoadingSpinner Label="@L["Common_Loading"]" />
                </div>
            }
            else
            {
                <AppPageHeader Title="@(IsCampaignEditing ? "Modifier la campagne" : SelectedCampaign.Name)"
                               Subtitle="@(IsCampaignEditing ? null : SelectedCampaign.Description)"
                               Icon="bi-map"
                               Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new(SelectedCampaign.Name) })">
                    <Actions>
                        @if (!IsCampaignEditing)
                        {
                            <span class="status-badge @GetStatusClass(SelectedCampaign.Status)">@GetStatusLabel(SelectedCampaign.Status)</span>
                            <button class="btn btn-ghost" @onclick="() => IsCampaignEditing = true">
                                <i class="bi bi-pencil"></i>
                                Modifier
                            </button>
                        }
                        <button class="btn btn-ghost" @onclick="() => ConfirmDeleteCampaign(SelectedCampaign)">
                            <i class="bi bi-trash3"></i>
                            @L["Common_Delete"]
                        </button>
                    </Actions>
                </AppPageHeader>

                @if (IsCampaignEditing)
                {
                    <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                        <h3 class="card-title" style="margin-bottom: var(--spacing-md);">Modifier la campagne</h3>
                        <div class="form-group">
                            <label class="form-label">Nom *</label>
                            <input type="text" class="form-control" @bind="CampaignEditName" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="3" @bind="CampaignEditDescription" placeholder="Décrivez cette campagne..."></textarea>
                        </div>
                        <div style="display: flex; gap: var(--spacing-sm); margin-top: var(--spacing-md);">
                            <button class="btn btn-primary btn-sm" @onclick="SaveCampaignEdit" disabled="@IsSaving">
                                <i class="bi bi-floppy"></i> Enregistrer
                            </button>
                            <button class="btn btn-ghost btn-sm" @onclick="() => { IsCampaignEditing = false; CampaignEditName = SelectedCampaign.Name; CampaignEditDescription = SelectedCampaign.Description ?? string.Empty; }">
                                @L["Common_Cancel"]
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                        <h3 class="card-title">Informations</h3>
                    <div class="info-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-md); margin-top: var(--spacing-md);">
                        <div>
                            <span class="info-label">Visibilité</span>
                            <span class="info-value">@(SelectedCampaign.Visibility == Visibility.Public ? "Publique" : "Privée")</span>
                        </div>
                        <div>
                            <span class="info-label">Joueurs max</span>
                            <span class="info-value">@SelectedCampaign.MaxPlayers</span>
                        </div>
                        <div>
                            <span class="info-label">@L["Worlds_CreatedAt"]</span>
                            <span class="info-value">@SelectedCampaign.CreatedAt.ToString("d MMM yyyy")</span>
                        </div>
                    </div>
                    </div>
                }

                <!-- Chapitres -->
                <div class="cdm-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-md);">
                        <h3 class="card-title">Chapitres</h3>
                        <button class="btn btn-ghost btn-sm" @onclick="() => ShowNewChapterForm = !ShowNewChapterForm">
                            <i class="bi bi-plus"></i>
                            @L["Chapters_Create"]
                        </button>
                    </div>

                    @if (ShowNewChapterForm)
                    {
                        <div style="background: var(--color-bg-secondary); border-radius: var(--radius-md); padding: var(--spacing-md); margin-bottom: var(--spacing-md); border: 1px solid var(--theme-card-border, var(--color-border));">
                            <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                                <label class="form-label">Titre du chapitre</label>
                                <input type="text" class="form-control" @bind="NewChapter.Title" placeholder="Titre du chapitre..." />
                            </div>
                            <div style="display: flex; gap: var(--spacing-sm);">
                                <button class="btn btn-primary btn-sm" @onclick="CreateChapter" disabled="@IsSaving">
                                    <i class="bi bi-check"></i> Créer
                                </button>
                                <button class="btn btn-ghost btn-sm" @onclick="() => ShowNewChapterForm = false">
                                    @L["Common_Cancel"]
                                </button>
                            </div>
                        </div>
                    }

                    @if (CampaignChapters.TryGetValue(SelectedCampaign.Id, out var chapters) && chapters.Count > 0)
                    {
                        @foreach (var ch in chapters.OrderBy(c => c.ChapterNumber))
                        {
                            var chIcon = ch.IsCompleted ? "bi-check-circle-fill" : ch.IsActive ? "bi-circle-fill" : "bi-circle";
                            <a href="/worlds/@WorldId?campaignId=@SelectedCampaign.Id&chapterId=@ch.Id" class="chapter-list-row">
                                <i class="bi @chIcon" style="color: @(ch.IsCompleted ? "var(--color-success)" : ch.IsActive ? "var(--theme-primary, var(--color-primary))" : "var(--color-text-muted)");"></i>
                                <span style="flex: 1;">Ch. @ch.ChapterNumber — @ch.Title</span>
                                @if (ch.IsCompleted)
                                {
                                    <span class="status-badge status-completed">Terminé</span>
                                }
                                else if (ch.IsActive)
                                {
                                    <span class="status-badge status-active">En cours</span>
                                }
                            </a>
                        }
                    }
                    else
                    {
                        <p style="color: var(--color-text-muted); font-style: italic; font-size: var(--font-size-sm);">
                            Aucun chapitre pour le moment.
                        </p>
                    }
                </div>
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: CONTENU CHAPITRE
           ────────────────────────────────────────────────────────── *@
        @if (SelectedCampaignId.HasValue && SelectedChapterId.HasValue && Section == null)
        {
            @if (SelectedChapter == null)
            {
                <div style="padding: var(--spacing-xl);">
                    <AppLoadingSpinner Label="@L["Common_Loading"]" />
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; height: calc(100vh - var(--topbar-height) - 2rem); padding: var(--spacing-lg) var(--spacing-xl) var(--spacing-xl);">
                    <div class="world-section-header">
                        <div>
                            <h2 class="world-section-title">
                                Ch. @SelectedChapter.ChapterNumber — @SelectedChapter.Title
                            </h2>
                            @if (SelectedChapter.IsCompleted)
                            {
                                <span class="status-badge status-completed">Terminé</span>
                            }
                            else if (SelectedChapter.IsActive)
                            {
                                <span class="status-badge status-active">En cours</span>
                            }
                        </div>
                        <div style="display: flex; gap: var(--spacing-sm); align-items: center;">
                            @if (!string.IsNullOrEmpty(SaveMessage))
                            {
                                <span style="font-size: var(--font-size-xs); color: @(SaveSuccess ? "var(--color-success)" : "var(--color-error)");">@SaveMessage</span>
                            }
                            <button class="btn btn-primary btn-sm" @onclick="SaveChapterContent" disabled="@IsSaving">
                                <i class="bi bi-floppy"></i> Enregistrer
                            </button>
                        </div>
                    </div>

                    <div class="description-editor-container" style="flex: 1; min-height: 0;">
                        <div class="description-editor-toolbar">
                            <span class="description-editor-hint">
                                <i class="bi bi-book"></i>
                                Contenu du chapitre
                            </span>
                            @if (ChapterContentDirty)
                            {
                                <span style="font-size: var(--font-size-xs); color: var(--color-warning);">Modifications non sauvegardées</span>
                            }
                        </div>
                        <textarea class="description-editor-textarea"
                                  placeholder="Rédigez le contenu de ce chapitre : synopsis, notes de session, événements clés..."
                                  value="@ChapterContentDraft"
                                  @oninput="OnChapterContentInput"></textarea>
                    </div>
                </div>
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: ÉVÉNEMENTS
           ────────────────────────────────────────────────────────── *@
        @if (Section == "events")
        {
            <AppPageHeader Title="Événements"
                           Icon="bi-lightning"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new("Événements") })" />

            <p style="color: var(--color-text-secondary); margin-bottom: var(--spacing-lg);">
                Les événements sont des modificateurs actifs qui affectent tous les personnages de ce monde.
            </p>

            <div style="display: flex; justify-content: flex-end; margin-bottom: var(--spacing-md);">
                <button class="btn btn-primary btn-sm" @onclick="() => ShowNewEventForm = !ShowNewEventForm">
                    <i class="bi bi-plus"></i> Créer un événement
                </button>
            </div>

            @if (ShowNewEventForm)
            {
                <div class="cdm-card" style="margin-bottom: var(--spacing-lg); border: 1px solid var(--theme-card-border, var(--color-border));">
                    <h4 class="card-title" style="margin-bottom: var(--spacing-md);">Nouvel événement de monde</h4>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Nom <span style="color:var(--color-error)">*</span></label>
                        <input type="text" class="form-control" @bind="NewEvent.Name" placeholder="Nom de l'événement..." />
                    </div>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3" @bind="NewEvent.Description" placeholder="Description narrative de l'événement..."></textarea>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-sm); margin-bottom: var(--spacing-sm);">
                        <div class="form-group">
                            <label class="form-label">Type d'effet</label>
                            <select class="form-control" @bind="NewEvent.EffectType">
                                <option value="@EventEffectType.Narrative">Narratif</option>
                                <option value="@EventEffectType.StatModifier">Modificateur de stat</option>
                                <option value="@EventEffectType.HealthModifier">Modificateur de PV</option>
                                <option value="@EventEffectType.DiceModifier">Modificateur de dé</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Durée</label>
                            <select class="form-control" @bind="NewEvent.IsPermanent">
                                <option value="true">Permanent</option>
                                <option value="false">Temporaire</option>
                            </select>
                        </div>
                    </div>
                    @if (NewEvent.EffectType != EventEffectType.Narrative)
                    {
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-sm); margin-bottom: var(--spacing-sm);">
                            <div class="form-group">
                                <label class="form-label">Stat ciblée</label>
                                <input type="text" class="form-control" @bind="NewEvent.TargetStat" placeholder="ex: Force, PV..." />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Valeur modificateur</label>
                                <input type="number" class="form-control" @bind="NewEvent.ModifierValue" />
                            </div>
                        </div>
                    }
                    <div style="display: flex; gap: var(--spacing-sm);">
                        <button class="btn btn-primary btn-sm" @onclick="CreateEvent" disabled="@IsSaving">
                            <i class="bi bi-check"></i> Créer
                        </button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => ShowNewEventForm = false">@L["Common_Cancel"]</button>
                    </div>
                </div>
            }

            @if (IsLoadingEvents)
            {
                <AppLoadingSpinner Label="Chargement des événements..." />
            }
            else if (WorldEvents.Count == 0)
            {
                <AppEmptyState Icon="bi-lightning"
                               Title="Aucun événement"
                               Message="Aucun événement actif dans ce monde pour l'instant." />
            }
            else
            {
                @foreach (var ev in WorldEvents.OrderByDescending(e => e.CreatedAt))
                {
                    <div class="cdm-card" style="margin-bottom: var(--spacing-sm); border-left: 3px solid @(ev.IsActive ? "var(--theme-primary, var(--color-primary))" : "var(--color-border)");">
                        <div style="display: flex; align-items: flex-start; gap: var(--spacing-md);">
                            <div style="flex: 1; min-width: 0;">
                                <div style="display: flex; align-items: center; gap: var(--spacing-sm); margin-bottom: var(--spacing-xs);">
                                    <span style="font-weight: 600; color: var(--color-text-primary);">@ev.Name</span>
                                    @if (ev.IsActive)
                                    {
                                        <span class="status-badge status-active">Actif</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-paused">Inactif</span>
                                    }
                                    <span class="status-badge" style="background: var(--color-bg-secondary);">@GetEffectLabel(ev.EffectType)</span>
                                    <span class="status-badge" style="background: var(--color-bg-secondary);">@(ev.IsPermanent ? "Permanent" : "Temporaire")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(ev.Description))
                                {
                                    <p style="color: var(--color-text-secondary); font-size: var(--font-size-sm); margin: 0;">@ev.Description</p>
                                }
                                @if (ev.EffectType != EventEffectType.Narrative && ev.ModifierValue.HasValue)
                                {
                                    <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-xs);">
                                        @ev.TargetStat : @(ev.ModifierValue > 0 ? "+" : "")@ev.ModifierValue
                                    </p>
                                }
                            </div>
                            <div style="display: flex; gap: var(--spacing-xs); flex-shrink: 0;">
                                <button class="btn btn-ghost btn-sm" @onclick="() => ToggleEventActive(ev)" title="@(ev.IsActive ? "Désactiver" : "Activer")">
                                    <i class="bi @(ev.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                                <button class="btn btn-ghost btn-sm" @onclick="() => DeleteEvent(ev.Id)" style="color: var(--color-error);" title="Supprimer">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: SUCCÈS
           ────────────────────────────────────────────────────────── *@
        @if (Section == "achievements")
        {
            <AppPageHeader Title="Succès"
                           Icon="bi-trophy"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new("Succès") })" />

            <p style="color: var(--color-text-secondary); margin-bottom: var(--spacing-lg);">
                Les succès récompensent les accomplissements des joueurs dans ce monde.
            </p>

            <div style="display: flex; justify-content: flex-end; margin-bottom: var(--spacing-md);">
                <button class="btn btn-primary btn-sm" @onclick="() => ShowNewAchievementForm = !ShowNewAchievementForm">
                    <i class="bi bi-plus"></i> Créer un succès
                </button>
            </div>

            @if (ShowNewAchievementForm)
            {
                <div class="cdm-card" style="margin-bottom: var(--spacing-lg); border: 1px solid var(--theme-card-border, var(--color-border));">
                    <h4 class="card-title" style="margin-bottom: var(--spacing-md);">Nouveau succès de monde</h4>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Nom <span style="color:var(--color-error)">*</span></label>
                        <input type="text" class="form-control" @bind="NewAchievement.Name" placeholder="Nom du succès..." />
                    </div>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Description <span style="color:var(--color-error)">*</span></label>
                        <textarea class="form-control" rows="3" @bind="NewAchievement.Description" placeholder="Décrivez ce succès et comment l'obtenir..."></textarea>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-sm); margin-bottom: var(--spacing-sm);">
                        <div class="form-group">
                            <label class="form-label">Rareté</label>
                            <select class="form-control" @bind="NewAchievement.Rarity">
                                <option value="@AchievementRarity.Common">Commun</option>
                                <option value="@AchievementRarity.Rare">Rare</option>
                                <option value="@AchievementRarity.Epic">Épique</option>
                                <option value="@AchievementRarity.Legendary">Légendaire</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Visibilité</label>
                            <select class="form-control" @bind="NewAchievement.IsSecret">
                                <option value="false">Visible</option>
                                <option value="true">Secret</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Récompense (optionnel)</label>
                        <input type="text" class="form-control" @bind="NewAchievement.RewardDescription" placeholder="Description de la récompense..." />
                    </div>
                    <div style="display: flex; gap: var(--spacing-sm);">
                        <button class="btn btn-primary btn-sm" @onclick="CreateAchievement" disabled="@IsSaving">
                            <i class="bi bi-check"></i> Créer
                        </button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => ShowNewAchievementForm = false">@L["Common_Cancel"]</button>
                    </div>
                </div>
            }

            @if (IsLoadingAchievements)
            {
                <AppLoadingSpinner Label="Chargement des succès..." />
            }
            else if (WorldAchievements.Count == 0)
            {
                <AppEmptyState Icon="bi-trophy"
                               Title="Aucun succès"
                               Message="Aucun succès défini pour ce monde." />
            }
            else
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--spacing-md);">
                    @foreach (var ach in WorldAchievements.OrderBy(a => a.Rarity).ThenBy(a => a.Name))
                    {
                        <div class="cdm-card" style="@GetRarityBorderStyle(ach.Rarity)">
                            <div style="display: flex; align-items: flex-start; gap: var(--spacing-sm); justify-content: space-between;">
                                <div style="flex: 1; min-width: 0;">
                                    <div style="display: flex; align-items: center; gap: var(--spacing-xs); margin-bottom: var(--spacing-xs); flex-wrap: wrap;">
                                        <i class="bi bi-trophy" style="color: @GetRarityColor(ach.Rarity);"></i>
                                        <span style="font-weight: 600; color: var(--color-text-primary); font-size: var(--font-size-sm);">@ach.Name</span>
                                        <span class="status-badge @GetRarityClass(ach.Rarity)">@GetRarityLabel(ach.Rarity)</span>
                                        @if (ach.IsSecret)
                                        {
                                            <span class="status-badge" style="background: var(--color-bg-secondary);"><i class="bi bi-eye-slash"></i> Secret</span>
                                        }
                                    </div>
                                    <p style="color: var(--color-text-secondary); font-size: var(--font-size-xs); margin: 0;">@ach.Description</p>
                                    @if (!string.IsNullOrWhiteSpace(ach.RewardDescription))
                                    {
                                        <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-xs);">
                                            <i class="bi bi-gift"></i> @ach.RewardDescription
                                        </p>
                                    }
                                    @if (ach.UnlockCount > 0)
                                    {
                                        <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-xs);">
                                            @ach.UnlockCount débloqué(s)
                                        </p>
                                    }
                                </div>
                                <button class="btn btn-ghost btn-sm" @onclick="() => DeleteAchievement(ach.Id)"
                                        style="color: var(--color-error); flex-shrink: 0;" title="Supprimer">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: INVITATIONS
           ────────────────────────────────────────────────────────── *@
        @if (Section == "invitations")
        {
            <AppPageHeader Title="Invitations"
                           Icon="bi-person-plus"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new("Invitations") })" />

            @if (Campaigns.Count == 0)
            {
                <AppEmptyState Icon="bi-person-plus"
                               Title="Aucune campagne"
                               Message="Créez d'abord une campagne pour pouvoir inviter des joueurs." />
            }
            else
            {
                <p style="color: var(--color-text-secondary); margin-bottom: var(--spacing-lg);">
                    Générez un lien d'invitation par campagne. Les joueurs peuvent rejoindre en cliquant sur le lien.
                </p>
                @foreach (var campaign in Campaigns)
                {
                    var token = campaign.InviteToken;
                    var inviteUrl = token != null ? $"{Nav.BaseUri}join?token={token}" : null;
                    <div class="invite-row">
                        <div style="flex: 1; min-width: 0;">
                            <div style="font-weight: 600; font-size: var(--font-size-sm); margin-bottom: var(--spacing-xs);">
                                <i class="bi bi-map" style="color: var(--color-text-muted); margin-right: var(--spacing-xs);"></i>
                                @campaign.Name
                            </div>
                            @if (inviteUrl != null)
                            {
                                <div class="invite-token-box">@inviteUrl</div>
                            }
                            else
                            {
                                <span style="font-size: var(--font-size-xs); color: var(--color-text-muted); font-style: italic;">Aucun lien généré</span>
                            }
                        </div>
                        <div style="display: flex; gap: var(--spacing-xs); flex-shrink: 0;">
                            <button class="btn btn-ghost btn-sm" @onclick="() => GenerateInviteToken(campaign.Id)" disabled="@IsGeneratingToken">
                                <i class="bi bi-arrow-repeat"></i>
                                @(token == null ? "Générer" : "Régénérer")
                            </button>
                            @if (inviteUrl != null)
                            {
                                <button class="btn btn-ghost btn-sm" @onclick="() => CopyToClipboard(inviteUrl)" title="Copier le lien">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
            }
        }

    </AppThemeWrapper>
}

<AppConfirmDialog @ref="DeleteWorldDialog"
                  Title="@L["Worlds_DeleteConfirmTitle"]"
                  Message="@L["Worlds_DeleteConfirm"]"
                  ConfirmLabel="@L["Common_Delete"]"
                  CancelLabel="@L["Common_Cancel"]"
                  OnConfirm="DeleteWorldAsync" />

<AppConfirmDialog @ref="DeleteCampaignDialog"
                  Title="Supprimer la campagne ?"
                  Message="Cette action est irréversible. Tous les chapitres seront supprimés."
                  ConfirmLabel="@L["Common_Delete"]"
                  CancelLabel="@L["Common_Cancel"]"
                  OnConfirm="DeleteCampaignAsync" />

