@page "/worlds/{WorldId:int}"
@attribute [Authorize]
@using Cdm.Web.Extensions
@implements IDisposable

<PageTitle>@(World?.Name ?? "Monde") — Chronique des Mondes</PageTitle>

@if (IsLoading)
{
    <div style="padding: var(--spacing-xl);">
        <AppLoadingSpinner Label="@L["Common_Loading"]" />
    </div>
}
else if (World == null)
{
    <AppEmptyState Icon="bi-globe2"
                   Title="@L["Worlds_NotFound"]"
                   Message="@L["Worlds_NotFoundMessage"]">
        <ActionContent>
            <a href="/worlds" class="btn btn-primary">
                <i class="bi bi-arrow-left"></i>
                @L["Common_Back"]
            </a>
        </ActionContent>
    </AppEmptyState>
}
else
{
    <AppThemeWrapper GameType="@(_previewGameType ?? World.GameType)">

        @* ──────────────────────────────────────────────────────────
           SECTION: VUE D'ENSEMBLE (par défaut)
           ────────────────────────────────────────────────────────── *@
        @if (Section == null && !SelectedCampaignId.HasValue)
        {
            <WorldOverviewPanel WorldId="WorldId" World="World" Campaigns="Campaigns" IsOwner="IsOwner"
                                IsSharing="IsSharingWorld" OnToggleShared="ToggleWorldShared"
                                OnDelete="ConfirmDeleteWorld">
                <SettingsCard>
                    <WorldSettingsCard WorldId="WorldId" World="World" IsOwner="IsOwner"
                                       OnSaved="OnWorldSettingsSaved"
                                       OnPreviewGameTypeChanged="@(gt => _previewGameType = gt)" />
                </SettingsCard>
            </WorldOverviewPanel>
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: DESCRIPTION EDITOR
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && Section == "description")
        {
            <WorldDescriptionEditor WorldId="WorldId" World="World" OnSaved="OnWorldDescriptionSaved" />
        }

        @if (IsOwner && Section == "new-campaign" && !SelectedCampaignId.HasValue)
        {
            <WorldNewCampaignForm WorldId="WorldId" World="World" OnCreated="OnCampaignCreated" />
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: DÉTAIL CAMPAGNE
           ────────────────────────────────────────────────────────── *@
        @if (SelectedCampaignId.HasValue && SelectedChapterId == null && Section == null)
        {
            @if (SelectedCampaign == null)
            {
                <div style="padding: var(--spacing-xl);">
                    <AppLoadingSpinner Label="@L["Common_Loading"]" />
                </div>
            }
            else
            {
                <AppPageHeader Title="@SelectedCampaign.Name"
                               Icon="bi-map"
                               Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new(SelectedCampaign.Name) })">
                    <Actions>
                        <span class="status-badge @SelectedCampaign.Status.ToCssClass()">@L[SelectedCampaign.Status.ToLabelKey()]</span>
                        @if (IsOwner)
                        {
                            @if (!IsCampaignEditing)
                            {
                                <button class="btn btn-ghost btn-sm" @onclick="() => IsCampaignEditing = true">
                                    <i class="bi bi-pencil"></i>
                                    Modifier
                                </button>
                            }
                            <button class="btn @(SelectedCampaign.IsShared ? "btn-primary" : "btn-ghost") btn-sm" @onclick="ToggleCampaignShared" disabled="@IsSharingCampaign"
                                    title="@(SelectedCampaign.IsShared ? "Retirer de la marketplace" : "Publier sur la marketplace")">
                                <i class="bi @(SelectedCampaign.IsShared ? "bi-share-fill" : "bi-share")"></i>
                                @(SelectedCampaign.IsShared ? "Publiée" : "Publier")
                            </button>
                            <button class="btn btn-ghost btn-sm" @onclick="() => ConfirmDeleteCampaign(SelectedCampaign)">
                                <i class="bi bi-trash3"></i>
                                @L["Common_Delete"]
                            </button>
                        }
                    </Actions>
                </AppPageHeader>

                @if (IsOwner && IsCampaignEditing)
                {
                    <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                        <AppSectionTitle Title="Modifier la campagne" Icon="bi-pencil-square" />
                        <div class="form-group">
                            <label class="form-label">Nom *</label>
                            <input type="text" class="form-control" @bind="CampaignEditName" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="3" @bind="CampaignEditDescription" placeholder="Décrivez cette campagne..."></textarea>
                        </div>
                        <div style="display: flex; gap: var(--spacing-sm); margin-top: var(--spacing-md);">
                            <button class="btn btn-primary btn-sm" @onclick="SaveCampaignEdit" disabled="@IsSaving">
                                <i class="bi bi-floppy"></i> Enregistrer
                            </button>
                            <button class="btn btn-ghost btn-sm" @onclick="() => { IsCampaignEditing = false; CampaignEditName = SelectedCampaign.Name; CampaignEditDescription = SelectedCampaign.Description ?? string.Empty; }">
                                @L["Common_Cancel"]
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Tab bar -->
                    <div class="campaign-tabs" style="margin-bottom: var(--spacing-md);">
                        @if (IsOwner)
                        {
                            <button class="campaign-tab-btn @(CampaignTab == "chapitres" ? "active" : "")" @onclick='() => CampaignTab = "chapitres"'>
                                <i class="bi bi-book"></i> Chapitres
                            </button>
                            <button class="campaign-tab-btn @(CampaignTab == "session" ? "active" : "")" @onclick='() => CampaignTab = "session"'>
                                <i class="bi bi-play-circle"></i> Session
                                @if (_campaignHasActiveSession)
                                {
                                    <span class="tab-dot-active"></span>
                                }
                            </button>
                        }
                        <button class="campaign-tab-btn @(CampaignTab == "infos" ? "active" : "")" @onclick='() => CampaignTab = "infos"'>
                            <i class="bi bi-info-circle"></i> Infos
                        </button>
                    </div>

                    <!-- Chapitres tab -->
                    @if (IsOwner && CampaignTab == "chapitres")
                    {
                        <WorldChapterListPanel WorldId="WorldId" CampaignId="SelectedCampaign!.Id"
                                               Chapters="@(CampaignChapters.TryGetValue(SelectedCampaign!.Id, out var tabChapters) ? tabChapters : new())"
                                               OnReordered="OnChaptersReordered" />
                    }

                    <!-- Session tab -->
                    @if (IsOwner && CampaignTab == "session")
                    {
                        <WorldSessionLaunchPanel WorldId="WorldId" CampaignId="SelectedCampaign!.Id" />
                    }

                    <!-- Infos tab -->
                    @if (CampaignTab == "infos" || !IsOwner)
                    {
                        <div class="cdm-card">
                            <AppSectionTitle Title="Informations" Icon="bi-info-circle" />
                            <div class="info-grid">
                                <div>
                                    <span class="info-label">Visibilité</span>
                                    <span class="info-value">@(SelectedCampaign.Visibility == Visibility.Public ? "Publique" : "Privée")</span>
                                </div>
                                <div>
                                    <span class="info-label">Joueurs max</span>
                                    <span class="info-value">@SelectedCampaign.MaxPlayers</span>
                                </div>
                                <div>
                                    <span class="info-label">@L["Worlds_CreatedAt"]</span>
                                    <span class="info-value">@SelectedCampaign.CreatedAt.ToString("d MMM yyyy")</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: NOUVEAU CHAPITRE (formulaire dédié)
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && SelectedCampaignId.HasValue && Section == "new-chapter")
        {
            <WorldNewChapterForm WorldId="WorldId" World="World"
                                 CampaignId="SelectedCampaignId!.Value"
                                 Campaign="@Campaigns.FirstOrDefault(c => c.Id == SelectedCampaignId!.Value)"
                                 Chapters="@(CampaignChapters.TryGetValue(SelectedCampaignId!.Value, out var newChapterSiblings) ? newChapterSiblings : new())"
                                 OnCreated="OnChapterCreated" />
        }


        @* ──────────────────────────────────────────────────────────
           SECTION: CONTENU CHAPITRE
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && SelectedCampaignId.HasValue && SelectedChapterId.HasValue && Section == null)
        {
            @if (SelectedChapter == null)
            {
                <div style="padding: var(--spacing-xl);">
                    <AppLoadingSpinner Label="@L["Common_Loading"]" />
                </div>
            }
            else
            {
                <WorldChapterEditorPanel Chapter="SelectedChapter" CampaignId="SelectedCampaignId!.Value"
                                         IsDnD="IsWorldDnD5e" WorldCharacters="WorldCharacters"
                                         OnSaved="OnChapterSaved" />
            }
        }


        @* ──────────────────────────────────────────────────────────
           SECTION: ÉVÉNEMENTS
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && Section == "events")
        {
            <AppPageHeader Title="Événements"
                           Icon="bi-lightning"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new("Événements") })" />

            @* Contenu événements (composant extrait, auto-chargeant) *@
            <WorldEventsPanel WorldId="WorldId" />
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: SUCCÈS
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && Section == "achievements")
        {
            <AppPageHeader Title="Succès"
                           Icon="bi-trophy"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new("Succès") })" />

            @* Contenu succès (composant extrait, auto-chargeant) *@
            <WorldAchievementsPanel WorldId="WorldId" />
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: INVITATIONS
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && Section == "invitations")
        {
            <AppPageHeader Title="Invitations"
                           Icon="bi-person-plus"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new("Invitations") })" />

            @* Lien d'invitation monde (composant extrait) *@
            <WorldInvitePanel WorldId="WorldId" />

            @* Joueurs actuels (composant extrait) *@
            <WorldPlayersPanel IsLoading="IsLoadingWorldCharacters"
                               Players="WorldCharacters"
                               OnRemove="RemoveWorldCharacter" />

            @* Invitations par campagne *@
            @* Invitations par campagne (composant extrait) *@
            <WorldCampaignInvitesPanel Campaigns="Campaigns"
                                       IsGenerating="IsGeneratingToken"
                                       OnGenerate="GenerateInviteToken" />
        }

    </AppThemeWrapper>
}

<AppConfirmDialog @ref="DeleteWorldDialog"
                  Title="@L["Worlds_DeleteConfirmTitle"]"
                  Message="@L["Worlds_DeleteConfirm"]"
                  ConfirmLabel="@L["Common_Delete"]"
                  CancelLabel="@L["Common_Cancel"]"
                  OnConfirm="DeleteWorldAsync" />

<AppConfirmDialog @ref="DeleteCampaignDialog"
                  Title="Supprimer la campagne ?"
                  Message="Cette action est irréversible. Tous les chapitres seront supprimés."
                  ConfirmLabel="@L["Common_Delete"]"
                  CancelLabel="@L["Common_Cancel"]"
                  OnConfirm="DeleteCampaignAsync" />

