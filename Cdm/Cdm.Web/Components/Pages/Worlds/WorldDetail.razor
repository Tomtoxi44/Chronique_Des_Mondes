@page "/worlds/{WorldId:int}"
@attribute [Authorize]
@implements IDisposable

<PageTitle>@(World?.Name ?? "Monde") — Chronique des Mondes</PageTitle>

@if (IsLoading)
{
    <div style="padding: var(--spacing-xl);">
        <AppLoadingSpinner Label="@L["Common_Loading"]" />
    </div>
}
else if (World == null)
{
    <AppEmptyState Icon="bi-globe2"
                   Title="@L["Worlds_NotFound"]"
                   Message="@L["Worlds_NotFoundMessage"]">
        <ActionContent>
            <a href="/worlds" class="btn btn-primary">
                <i class="bi bi-arrow-left"></i>
                @L["Common_Back"]
            </a>
        </ActionContent>
    </AppEmptyState>
}
else
{
    <AppThemeWrapper GameType="@(IsWorldEditing ? WorldEditGameType : World.GameType)">

        @* ──────────────────────────────────────────────────────────
           SECTION: VUE D'ENSEMBLE (par défaut)
           ────────────────────────────────────────────────────────── *@
        @if (Section == null && !SelectedCampaignId.HasValue)
        {
            <AppPageHeader Title="@World.Name"
                           Icon="bi-globe2"
                           Breadcrumbs="@Breadcrumbs">
                <Actions>
                    @if (IsOwner)
                    {
                        <button class="btn btn-ghost" @onclick="ConfirmDeleteWorld">
                            <i class="bi bi-trash3"></i>
                            @L["Common_Delete"]
                        </button>
                    }
                </Actions>
            </AppPageHeader>

            <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: var(--spacing-md); margin-bottom: var(--spacing-xl);">
                <AppStatCard Value="@Campaigns.Count.ToString()" Label="@L["Worlds_Campaigns"]" Icon="bi-map" />
                <AppStatCard Value="@World.CharacterCount.ToString()" Label="@L["Worlds_Characters"]" Icon="bi-people" />
            </div>

            <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                @if (IsOwner && IsWorldEditing)
                {
                    <div style="margin-bottom: var(--spacing-md); display: flex; justify-content: space-between; align-items: center;">
                        <h3 class="card-title">Modifier les paramètres</h3>
                        <button class="btn btn-ghost btn-sm" @onclick="() => IsWorldEditing = false">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Nom du monde *</label>
                        <input type="text" class="form-control" @bind="WorldEditName" placeholder="Nom du monde..." />
                    </div>

                    <div class="form-group" style="margin-top: var(--spacing-md);">
                        <label class="form-label">@L["Worlds_GameType"]</label>
                        <div class="game-type-grid" style="grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: var(--spacing-sm); margin-top: var(--spacing-xs);">
                            @foreach (var gt in GameTypeOptions)
                            {
                                <button type="button"
                                        class="game-type-card @(WorldEditGameType == gt.Value ? "selected" : "")"
                                        style="padding: var(--spacing-sm); @(WorldEditGameType == gt.Value ? "border-color: var(--theme-card-border, var(--color-primary)); background: var(--theme-badge-bg, rgba(99,102,241,0.1));" : "")"
                                        @onclick="() => WorldEditGameType = gt.Value">
                                    <i class="bi @gt.Icon game-type-icon" style="font-size: 1.2rem; @(WorldEditGameType == gt.Value ? "color: var(--theme-primary, var(--color-primary));" : "")"></i>
                                    <span class="game-type-label" style="font-size: var(--font-size-xs);">@gt.Label</span>
                                </button>
                            }
                        </div>
                    </div>

                    <div style="display: flex; gap: var(--spacing-sm); margin-top: var(--spacing-md);">
                        <button class="btn btn-primary btn-sm" @onclick="SaveWorldSettings" disabled="@(IsSaving || string.IsNullOrWhiteSpace(WorldEditName))">
                            <i class="bi bi-floppy"></i> Enregistrer
                        </button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => IsWorldEditing = false">
                            @L["Common_Cancel"]
                        </button>
                    </div>
                }
                else
                {
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <h3 class="card-title">@L["Worlds_Information"]</h3>
                        @if (IsOwner)
                        {
                            <button class="btn btn-ghost btn-sm" @onclick="BeginWorldEdit">
                                <i class="bi bi-pencil"></i>
                            </button>
                        }
                    </div>
                    <div class="info-grid" style="margin-top: var(--spacing-md);">
                        <div>
                            <span class="info-label">@L["Worlds_GameType"]</span>
                            <div style="margin-top: var(--spacing-xs);"><AppGameBadge GameType="@World.GameType" /></div>
                        </div>
                        <div>
                            <span class="info-label">@L["Worlds_CreatedAt"]</span>
                            <span class="info-value">@World.CreatedAt.ToString("d MMM yyyy")</span>
                        </div>
                        @if (World.UpdatedAt.HasValue)
                        {
                            <div>
                                <span class="info-label">@L["Worlds_UpdatedAt"]</span>
                                <span class="info-value">@World.UpdatedAt.Value.ToString("d MMM yyyy")</span>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(World.Description))
            {
                <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                    <h3 class="card-title">Description</h3>
                    <p style="color: var(--color-text-secondary); line-height: 1.7; white-space: pre-wrap; margin: var(--spacing-md) 0 0;">@World.Description</p>
                    @if (IsOwner)
                    {
                        <a href="/worlds/@WorldId?section=description" class="btn btn-ghost btn-sm" style="margin-top: var(--spacing-md);">
                            <i class="bi bi-pencil"></i> Modifier
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <h3 class="card-title">Description</h3>
                        @if (IsOwner)
                        {
                            <a href="/worlds/@WorldId?section=description" class="btn btn-ghost btn-sm">
                                <i class="bi bi-plus"></i> Ajouter une description
                            </a>
                        }
                    </div>
                    <p style="color: var(--color-text-muted); font-style: italic; margin-top: var(--spacing-sm);">@(IsOwner ? "Aucune description. Cliquez pour écrire." : "Aucune description.")</p>
                </div>
            }

            @if (Campaigns.Count > 0)
            {
                <div class="cdm-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-md);">
                        <h3 class="card-title">@L["Worlds_Campaigns"]</h3>
                        @if (IsOwner)
                        {
                            <a href="/worlds/@WorldId?section=new-campaign" class="btn btn-ghost btn-sm">
                                <i class="bi bi-plus"></i>
                                @L["Campaigns_Create"]
                            </a>
                        }
                    </div>

                    @foreach (var campaign in Campaigns)
                    {
                        <a href="/worlds/@WorldId?campaignId=@campaign.Id" class="campaign-row">
                            <div style="display: flex; align-items: center; gap: var(--spacing-sm);">
                                <i class="bi bi-map" style="color: var(--color-text-muted);"></i>
                                <span>@campaign.Name</span>
                            </div>
                            <span class="status-badge @GetStatusClass(campaign.Status)">@GetStatusLabel(campaign.Status)</span>
                        </a>
                    }
                </div>
            }
            else if (IsOwner)
            {
                <AppEmptyState Icon="bi-map"
                               Title="Aucune campagne"
                               Message="Ce monde n'a pas encore de campagne.">
                    <ActionContent>
                        <a href="/worlds/@WorldId?section=new-campaign" class="btn btn-primary">
                            <i class="bi bi-plus"></i>
                            @L["Campaigns_Create"]
                        </a>
                    </ActionContent>
                </AppEmptyState>
            }
            else
            {
                <AppEmptyState Icon="bi-map"
                               Title="Aucune campagne"
                               Message="Ce monde n'a pas encore de campagne." />
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: DESCRIPTION EDITOR
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && Section == "description")
        {
            <div class="editor-section">
                <div class="world-section-header">
                    <div>
                        <h2 class="world-section-title">
                            <i class="bi bi-pencil" style="color: var(--theme-primary, var(--color-primary)); margin-right: var(--spacing-xs);"></i>
                            Description — @World.Name
                        </h2>
                    </div>
                    <div style="display: flex; gap: var(--spacing-sm); align-items: center;">
                        @if (!string.IsNullOrEmpty(SaveMessage))
                        {
                            <span style="font-size: var(--font-size-xs); color: @(SaveSuccess ? "var(--color-success)" : "var(--color-error)");">
                                @SaveMessage
                            </span>
                        }
                        <button class="btn btn-primary btn-sm" @onclick="SaveDescription" disabled="@IsSaving">
                            @if (IsSaving)
                            {
                                <i class="bi bi-hourglass-split"></i>
                            }
                            else
                            {
                                <i class="bi bi-floppy"></i>
                            }
                            Enregistrer
                        </button>
                    </div>
                </div>

                <div class="description-editor-container" style="flex: 1; min-height: 0;">
                    <div class="description-editor-toolbar">
                        <span class="description-editor-hint">
                            <i class="bi bi-info-circle"></i>
                            Texte brut — les retours à la ligne sont préservés
                        </span>
                        @if (DescriptionDirty)
                        {
                            <span style="font-size: var(--font-size-xs); color: var(--color-warning);">Modifications non sauvegardées</span>
                        }
                    </div>
                    <textarea class="description-editor-textarea"
                              placeholder="Décrivez votre monde : son histoire, sa géographie, ses factions, ses mystères..."
                              value="@DescriptionDraft"
                              @oninput="OnDescriptionInput"></textarea>
                </div>
            </div>
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: NOUVELLE CAMPAGNE (formulaire dédié)
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && Section == "new-campaign" && !SelectedCampaignId.HasValue)
        {
            <AppPageHeader Title="@L["Campaigns_Create"]"
                           Icon="bi-map"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new(L["Campaigns_Create"]) })" />

            <div style="max-width: 560px;">
                @if (!string.IsNullOrEmpty(CampaignCreateError))
                {
                    <div class="alert alert-error" style="margin-bottom: var(--spacing-md);">@CampaignCreateError</div>
                }
                <div class="cdm-card">
                    <div class="form-group" style="margin-bottom: var(--spacing-md);">
                        <label class="form-label">Nom *</label>
                        <input type="text" class="form-control" @bind="NewCampaign.Name" placeholder="La Quête des Éclats..." />
                    </div>
                    <div class="form-group" style="margin-bottom: var(--spacing-md);">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3" @bind="NewCampaign.Description" placeholder="Décrivez cette campagne..."></textarea>
                    </div>
                    <div class="form-two-col" style="margin-bottom: var(--spacing-md);">
                        <div class="form-group">
                            <label class="form-label">Visibilité</label>
                            <select class="form-control" @bind="NewCampaign.Visibility">
                                <option value="@Visibility.Private">Privée</option>
                                <option value="@Visibility.Public">Publique</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Joueurs max</label>
                            <input type="number" class="form-control" min="1" max="20" @bind="NewCampaign.MaxPlayers" />
                        </div>
                    </div>
                    <div style="display: flex; gap: var(--spacing-sm);">
                        <button class="btn btn-primary" @onclick="CreateCampaignInline" disabled="@IsSaving">
                            <i class="bi bi-check"></i> @L["Common_Create"]
                        </button>
                        <a href="/worlds/@WorldId" class="btn btn-ghost">@L["Common_Cancel"]</a>
                    </div>
                </div>
            </div>
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: DÉTAIL CAMPAGNE
           ────────────────────────────────────────────────────────── *@
        @if (SelectedCampaignId.HasValue && SelectedChapterId == null && Section == null)
        {
            @if (SelectedCampaign == null)
            {
                <div style="padding: var(--spacing-xl);">
                    <AppLoadingSpinner Label="@L["Common_Loading"]" />
                </div>
            }
            else
            {
                <AppPageHeader Title="@SelectedCampaign.Name"
                               Icon="bi-map"
                               Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new(SelectedCampaign.Name) })">
                    <Actions>
                        <span class="status-badge @GetStatusClass(SelectedCampaign.Status)">@GetStatusLabel(SelectedCampaign.Status)</span>
                        @if (IsOwner)
                        {
                            @if (!IsCampaignEditing)
                            {
                                <button class="btn btn-ghost btn-sm" @onclick="() => IsCampaignEditing = true">
                                    <i class="bi bi-pencil"></i>
                                    Modifier
                                </button>
                            }
                            <button class="btn btn-ghost btn-sm" @onclick="() => ConfirmDeleteCampaign(SelectedCampaign)">
                                <i class="bi bi-trash3"></i>
                                @L["Common_Delete"]
                            </button>
                        }
                    </Actions>
                </AppPageHeader>

                @if (IsOwner && IsCampaignEditing)
                {
                    <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                        <h3 class="card-title" style="margin-bottom: var(--spacing-md);">Modifier la campagne</h3>
                        <div class="form-group">
                            <label class="form-label">Nom *</label>
                            <input type="text" class="form-control" @bind="CampaignEditName" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="3" @bind="CampaignEditDescription" placeholder="Décrivez cette campagne..."></textarea>
                        </div>
                        <div style="display: flex; gap: var(--spacing-sm); margin-top: var(--spacing-md);">
                            <button class="btn btn-primary btn-sm" @onclick="SaveCampaignEdit" disabled="@IsSaving">
                                <i class="bi bi-floppy"></i> Enregistrer
                            </button>
                            <button class="btn btn-ghost btn-sm" @onclick="() => { IsCampaignEditing = false; CampaignEditName = SelectedCampaign.Name; CampaignEditDescription = SelectedCampaign.Description ?? string.Empty; }">
                                @L["Common_Cancel"]
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Tab bar -->
                    <div class="campaign-tabs" style="margin-bottom: var(--spacing-md);">
                        @if (IsOwner)
                        {
                            <button class="campaign-tab-btn @(CampaignTab == "chapitres" ? "active" : "")" @onclick='() => CampaignTab = "chapitres"'>
                                <i class="bi bi-book"></i> Chapitres
                            </button>
                            <button class="campaign-tab-btn @(CampaignTab == "session" ? "active" : "")" @onclick='() => CampaignTab = "session"'>
                                <i class="bi bi-play-circle"></i> Session
                                @if (ActiveSession != null)
                                {
                                    <span class="tab-dot-active"></span>
                                }
                            </button>
                        }
                        <button class="campaign-tab-btn @(CampaignTab == "infos" ? "active" : "")" @onclick='() => CampaignTab = "infos"'>
                            <i class="bi bi-info-circle"></i> Infos
                        </button>
                    </div>

                    <!-- Chapitres tab -->
                    @if (IsOwner && CampaignTab == "chapitres")
                    {
                        <div class="cdm-card">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-md);">
                                <div style="display: flex; align-items: center; gap: var(--spacing-sm);">
                                    <h3 class="card-title">Chapitres</h3>
                                    @if (IsReordering)
                                    {
                                        <span style="font-size: var(--font-size-xs); color: var(--color-text-muted);">Enregistrement...</span>
                                    }
                                </div>
                                <a href="/worlds/@WorldId?campaignId=@SelectedCampaign.Id&section=new-chapter" class="btn btn-ghost btn-sm">
                                    <i class="bi bi-plus"></i>
                                    @L["Chapters_Create"]
                                </a>
                            </div>

                            @if (CampaignChapters.TryGetValue(SelectedCampaign.Id, out var tabChapters) && tabChapters.Count > 0)
                            {
                                <div class="chapter-drag-list">
                                    @foreach (var ch in tabChapters.OrderBy(c => c.ChapterNumber))
                                    {
                                        var chIcon = ch.IsCompleted ? "bi-check-circle-fill" : ch.IsActive ? "bi-circle-fill" : "bi-circle";
                                        var isDragOver = _dragOverChapterId == ch.Id;
                                        <div class="chapter-drag-row @(isDragOver ? "drag-over" : "")"
                                             draggable="true"
                                             @ondragstart="() => OnChapterDragStart(ch)"
                                             @ondragover:preventDefault
                                             @ondragover="() => OnChapterDragOver(ch)"
                                             @ondragleave="OnChapterDragLeave"
                                             @ondrop="() => OnChapterDrop(ch)">
                                            <i class="bi bi-grip-vertical drag-handle"></i>
                                            <a href="/worlds/@WorldId?campaignId=@SelectedCampaign.Id&chapterId=@ch.Id" class="chapter-drag-link">
                                                <i class="bi @chIcon" style="color: @(ch.IsCompleted ? "var(--color-success)" : ch.IsActive ? "var(--theme-primary, var(--color-primary))" : "var(--color-text-muted)");"></i>
                                                <span style="flex: 1;">Ch. @ch.ChapterNumber — @ch.Title</span>
                                                @if (ch.IsCompleted)
                                                {
                                                    <span class="status-badge status-completed">Terminé</span>
                                                }
                                                else if (ch.IsActive)
                                                {
                                                    <span class="status-badge status-active">En cours</span>
                                                }
                                            </a>
                                        </div>
                                    }
                                </div>
                                <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-sm);">
                                    <i class="bi bi-grip-vertical"></i> Glisser-déposer pour réordonner
                                </p>
                            }
                            else
                            {
                                <p style="color: var(--color-text-muted); font-style: italic; font-size: var(--font-size-sm);">
                                    Aucun chapitre pour le moment.
                                </p>
                            }
                        </div>
                    }

                    <!-- Session tab -->
                    @if (IsOwner && CampaignTab == "session")
                    {
                        <div class="cdm-card" style="border-top: 2px solid var(--theme-primary, var(--color-primary));">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-sm);">
                                <div>
                                    <h3 class="card-title" style="margin: 0;">Session de jeu</h3>
                                    <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin: var(--spacing-xs) 0 0;">
                                        Lancez une session pour commencer à jouer cette campagne.
                                    </p>
                                </div>
                                @if (ActiveSession == null && !IsStartSessionPanelOpen)
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="OpenStartSessionPanel">
                                        <i class="bi bi-play-fill"></i>
                                        Lancer une session
                                    </button>
                                }
                                else if (ActiveSession != null)
                                {
                                    <a href="/sessions/@ActiveSession.Id/gm" class="btn btn-primary btn-sm">
                                        <i class="bi bi-play-fill"></i>
                                        Reprendre la session
                                    </a>
                                }
                            </div>

                            @if (IsLoadingSession)
                            {
                                <AppLoadingSpinner Label="Vérification..." />
                            }
                            else if (ActiveSession != null)
                            {
                                <div style="background: rgba(var(--color-success-rgb, 16,185,129),0.1); border: 1px solid var(--color-success); border-radius: 6px; padding: var(--spacing-sm) var(--spacing-md);">
                                    <span class="status-badge status-active" style="margin-right: var(--spacing-sm);">Session active</span>
                                    <span style="font-size: var(--font-size-sm); color: var(--color-text-secondary);">Démarrée le @ActiveSession.StartedAt.ToLocalTime().ToString("dd/MM à HH:mm")</span>
                                </div>
                            }
                            else if (IsStartSessionPanelOpen)
                            {
                                <div style="border-top: 1px solid var(--color-border); padding-top: var(--spacing-md); margin-top: var(--spacing-sm);">
                                    @if (!string.IsNullOrEmpty(SessionStartError))
                                    {
                                        <div class="alert alert-error" style="margin-bottom: var(--spacing-sm);">@SessionStartError</div>
                                    }

                                    <div class="form-group" style="margin-bottom: var(--spacing-md);">
                                        <label class="form-label">Message de bienvenue (optionnel)</label>
                                        <input type="text" class="form-control" @bind="SessionWelcomeMessage" placeholder="Bienvenue dans cette session..." />
                                    </div>

                                    @if (SessionParticipants.Count > 0)
                                    {
                                        <div class="form-group" style="margin-bottom: var(--spacing-md);">
                                            <label class="form-label">Joueurs à inviter</label>
                                            @foreach (var wc in SessionParticipants)
                                            {
                                                <label style="display: flex; align-items: center; gap: var(--spacing-sm); padding: var(--spacing-xs) 0; cursor: pointer;">
                                                    <input type="checkbox"
                                                           checked="@SelectedWorldCharacterIds.Contains(wc.Id)"
                                                           @onchange="() => ToggleParticipant(wc.Id)" />
                                                    <span style="font-size: var(--font-size-sm);">@wc.CharacterName</span>
                                                </label>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <p style="color: var(--color-text-muted); font-size: var(--font-size-sm); margin-bottom: var(--spacing-md);">
                                            <i class="bi bi-info-circle"></i>
                                            Aucun joueur n'a encore rejoint ce monde.
                                        </p>
                                    }

                                    <div style="display: flex; gap: var(--spacing-sm);">
                                        <button class="btn btn-primary btn-sm" @onclick="StartSession" disabled="@IsStartingSession">
                                            @if (IsStartingSession)
                                            {
                                                <i class="bi bi-hourglass-split"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-play-fill"></i>
                                            }
                                            Démarrer
                                        </button>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => IsStartSessionPanelOpen = false">
                                            Annuler
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- Infos tab -->
                    @if (CampaignTab == "infos" || !IsOwner)
                    {
                        <div class="cdm-card">
                            <h3 class="card-title">Informations</h3>
                            <div class="info-grid" style="margin-top: var(--spacing-md);">
                                <div>
                                    <span class="info-label">Visibilité</span>
                                    <span class="info-value">@(SelectedCampaign.Visibility == Visibility.Public ? "Publique" : "Privée")</span>
                                </div>
                                <div>
                                    <span class="info-label">Joueurs max</span>
                                    <span class="info-value">@SelectedCampaign.MaxPlayers</span>
                                </div>
                                <div>
                                    <span class="info-label">@L["Worlds_CreatedAt"]</span>
                                    <span class="info-value">@SelectedCampaign.CreatedAt.ToString("d MMM yyyy")</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: NOUVEAU CHAPITRE (formulaire dédié)
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && SelectedCampaignId.HasValue && Section == "new-chapter")
        {
            var parentCampaign = Campaigns.FirstOrDefault(c => c.Id == SelectedCampaignId.Value);
            <AppPageHeader Title="@L["Chapters_Create"]"
                           Icon="bi-book"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new(parentCampaign?.Name ?? "Campagne", $"/worlds/{WorldId}?campaignId={SelectedCampaignId}"), new(L["Chapters_Create"]) })" />

            <div style="max-width: 480px;">
                <div class="cdm-card">
                    <div style="display: grid; grid-template-columns: 80px 1fr; gap: var(--spacing-md); margin-bottom: var(--spacing-md);">
                        <div class="form-group">
                            <label class="form-label">N°</label>
                            <input type="number" class="form-control" @bind="NewChapter.ChapterNumber" min="1" style="text-align: center;" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Titre du chapitre *</label>
                            <input type="text" class="form-control" @bind="NewChapter.Title" placeholder="Titre du chapitre..." />
                        </div>
                    </div>
                    <div style="display: flex; gap: var(--spacing-sm);">
                        <button class="btn btn-primary" @onclick="CreateChapter" disabled="@IsSaving">
                            <i class="bi bi-check"></i> @L["Common_Create"]
                        </button>
                        <a href="/worlds/@WorldId?campaignId=@SelectedCampaignId" class="btn btn-ghost">@L["Common_Cancel"]</a>
                    </div>
                </div>
            </div>
        }


        @* ──────────────────────────────────────────────────────────
           SECTION: CONTENU CHAPITRE
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && SelectedCampaignId.HasValue && SelectedChapterId.HasValue && Section == null)
        {
            @if (SelectedChapter == null)
            {
                <div style="padding: var(--spacing-xl);">
                    <AppLoadingSpinner Label="@L["Common_Loading"]" />
                </div>
            }
            else
            {
                <!-- Chapter header -->
                <div class="world-section-header">
                    <div>
                        <h2 class="world-section-title">
                            Ch. @SelectedChapter.ChapterNumber — @SelectedChapter.Title
                        </h2>
                        <div style="display: flex; gap: var(--spacing-xs); margin-top: 4px; flex-wrap: wrap;">
                            @if (SelectedChapter.IsCompleted)
                            {
                                <span class="status-badge status-completed">Terminé</span>
                            }
                            else if (SelectedChapter.IsActive)
                            {
                                <span class="status-badge status-active">En cours</span>
                            }
                        </div>
                    </div>
                    @if (ChapterTab == "contenu")
                    {
                        <div style="display: flex; gap: var(--spacing-sm); align-items: center;">
                            @if (!string.IsNullOrEmpty(SaveMessage))
                            {
                                <span style="font-size: var(--font-size-xs); color: @(SaveSuccess ? "var(--color-success)" : "var(--color-error)");">@SaveMessage</span>
                            }
                            @if (ChapterContentDirty && !ChapterPreviewMode)
                            {
                                <span style="font-size: var(--font-size-xs); color: var(--color-warning);">Non sauvegardé</span>
                            }
                            <button class="btn btn-ghost btn-sm" @onclick="ToggleChapterPreview" title="@(ChapterPreviewMode ? "Éditer" : "Prévisualiser")">
                                <i class="bi @(ChapterPreviewMode ? "bi-pencil" : "bi-eye")"></i>
                                @(ChapterPreviewMode ? "Éditer" : "Aperçu")
                            </button>
                            @if (!ChapterPreviewMode)
                            {
                                <button class="btn btn-primary btn-sm" @onclick="SaveChapterContent" disabled="@IsSaving">
                                    <i class="bi bi-floppy"></i> Enregistrer
                                </button>
                            }
                        </div>
                    }
                </div>

                <!-- Chapter tab bar -->
                <div class="campaign-tabs" style="margin-bottom: var(--spacing-md);">
                    <button class="campaign-tab-btn @(ChapterTab == "contenu" ? "active" : "")" @onclick='() => SwitchToChapterTab("contenu")'>
                        <i class="bi bi-pencil-square"></i> Contenu
                        @if (ChapterContentDirty)
                        {
                            <span class="tab-dot-active" style="background: var(--color-warning);"></span>
                        }
                    </button>
                    <button class="campaign-tab-btn @(ChapterTab == "pnj" ? "active" : "")" @onclick='() => SwitchToChapterTab("pnj")'>
                        <i class="bi bi-people"></i> PNJ
                        @if (ChapterNpcs.Count > 0)
                        {
                            <span style="background: var(--color-bg-secondary); color: var(--color-text-muted); font-size: 10px; padding: 1px 6px; border-radius: 10px; font-weight: 600;">@ChapterNpcs.Count</span>
                        }
                    </button>
                </div>

                <!-- Contenu tab -->
                @if (ChapterTab == "contenu")
                {
                    @if (ChapterPreviewMode)
                    {
                        <div class="chapter-preview">
                            @if (string.IsNullOrWhiteSpace(ChapterContentDraft))
                            {
                                <span style="color: var(--color-text-muted); font-style: italic;">Aucun contenu rédigé.</span>
                            }
                            else
                            {
                                @RenderChapterContent(ChapterContentDraft)
                            }
                        </div>
                    }
                    else
                    {
                        <div class="description-editor-container" style="flex: 1; min-height: 0;">
                            <div class="description-editor-toolbar">
                                <span class="description-editor-hint">
                                    <i class="bi bi-book"></i>
                                    Contenu du chapitre &middot; Tapez <strong>@@</strong> pour mentionner un PNJ
                                </span>
                            </div>
                            <textarea id="chapter-content-editor"
                                      class="description-editor-textarea"
                                      placeholder="Rédigez le contenu de ce chapitre... Tapez @@ pour mentionner un PNJ."
                                      value="@ChapterContentDraft"
                                      @oninput="OnChapterContentInput"></textarea>
                        </div>
                    }
                }

                <!-- PNJ tab -->
                @if (ChapterTab == "pnj")
                {
                    <div class="cdm-card">
                        <div class="npc-panel-header">
                            <div>
                                <h3 class="card-title" style="margin: 0;">Personnages non-joueurs</h3>
                                <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin: var(--spacing-xs) 0 0;">
                                    PNJ de ce chapitre — visibles uniquement par le MJ
                                </p>
                            </div>
                            @if (!ShowNpcForm)
                            {
                                <button class="btn btn-ghost btn-sm" @onclick="ShowAddNpc">
                                    <i class="bi bi-plus"></i> Ajouter
                                </button>
                            }
                        </div>

                        @if (ShowNpcForm)
                        {
                            <div style="background: var(--color-surface-alt, var(--color-bg-secondary)); border-radius: 6px; padding: var(--spacing-md); margin-bottom: var(--spacing-md);">
                                <div class="form-two-col" style="margin-bottom: var(--spacing-sm);">
                                    <div class="form-group">
                                        <label class="form-label">Prénom</label>
                                        <input type="text" class="form-control" @bind="NewNpc.FirstName" placeholder="Prénom..." />
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Nom</label>
                                        <input type="text" class="form-control" @bind="NewNpc.Name" placeholder="Nom de famille..." />
                                    </div>
                                </div>
                                <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                                    <label class="form-label">Âge</label>
                                    <input type="number" class="form-control" @bind="NewNpc.Age" placeholder="Âge..." style="max-width: 120px;" />
                                </div>
                                <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                                    <label class="form-label">Description</label>
                                    <textarea class="form-control" rows="2" @bind="NewNpc.Description" placeholder="Description narrative..."></textarea>
                                </div>
                                <div class="form-group" style="margin-bottom: var(--spacing-md);">
                                    <label class="form-label">Description physique</label>
                                    <textarea class="form-control" rows="2" @bind="NewNpc.PhysicalDescription" placeholder="Apparence physique..."></textarea>
                                </div>
                                <div style="display: flex; gap: var(--spacing-sm);">
                                    <button class="btn btn-primary btn-sm" @onclick="CreateNpc" disabled="@IsSavingNpc">
                                        <i class="bi bi-check"></i> Créer
                                    </button>
                                    <button class="btn btn-ghost btn-sm" @onclick="() => ShowNpcForm = false">Annuler</button>
                                </div>
                            </div>
                        }

                        @if (ChapterNpcs.Count > 0)
                        {
                            <div class="npc-list">
                                @foreach (var npc in ChapterNpcs)
                                {
                                    var isExpanded = ExpandedNpcIds.Contains(npc.Id);
                                    var isEditing = EditingNpcId == npc.Id;
                                    var rawInitials = ((npc.FirstName?.Length > 0 ? npc.FirstName[0].ToString() : "") +
                                                       (npc.Name?.Length > 0 ? npc.Name[0].ToString() : "")).Trim();
                                    var npcInitials = string.IsNullOrEmpty(rawInitials) ? "?" : rawInitials;

                                    <div class="npc-card">
                                        <div class="npc-card-header" @onclick="() => ToggleNpcExpand(npc.Id)">
                                            <div class="npc-card-avatar">@npcInitials</div>
                                            <div class="npc-card-info">
                                                <div class="npc-card-name">@npc.DisplayName</div>
                                                @if (npc.Age.HasValue || !string.IsNullOrEmpty(npc.Description))
                                                {
                                                    <div class="npc-card-meta">
                                                        @if (npc.Age.HasValue) { <span>@npc.Age ans</span> }
                                                        @if (!string.IsNullOrEmpty(npc.Description))
                                                        {
                                                            <span style="margin-left: 4px;">· @(npc.Description.Length > 50 ? npc.Description[..50] + "…" : npc.Description)</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                            <div class="npc-card-actions" @onclick:stopPropagation="true">
                                                <button class="btn btn-ghost btn-sm" title="Modifier" @onclick="() => StartEditNpc(npc)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-ghost btn-sm" style="color: var(--color-error);" title="Supprimer" @onclick="() => ConfirmDeleteNpc(npc)">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                                <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down")" style="color: var(--color-text-muted); font-size: var(--font-size-xs);"></i>
                                            </div>
                                        </div>

                                        @if (isExpanded)
                                        {
                                            <div class="npc-card-body">
                                                @if (isEditing)
                                                {
                                                    <div class="form-two-col" style="margin-bottom: var(--spacing-sm);">
                                                        <div class="form-group">
                                                            <label class="form-label">Prénom</label>
                                                            <input type="text" class="form-control" @bind="EditingNpcDraft.FirstName" />
                                                        </div>
                                                        <div class="form-group">
                                                            <label class="form-label">Nom</label>
                                                            <input type="text" class="form-control" @bind="EditingNpcDraft.Name" />
                                                        </div>
                                                    </div>
                                                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                                                        <label class="form-label">Âge</label>
                                                        <input type="number" class="form-control" @bind="EditingNpcDraft.Age" style="max-width: 120px;" />
                                                    </div>
                                                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                                                        <label class="form-label">Description</label>
                                                        <textarea class="form-control" rows="3" @bind="EditingNpcDraft.Description"></textarea>
                                                    </div>
                                                    <div class="form-group" style="margin-bottom: var(--spacing-md);">
                                                        <label class="form-label">Description physique</label>
                                                        <textarea class="form-control" rows="2" @bind="EditingNpcDraft.PhysicalDescription"></textarea>
                                                    </div>
                                                    <div style="display: flex; gap: var(--spacing-sm);">
                                                        <button class="btn btn-primary btn-sm" @onclick="SaveEditNpc" disabled="@IsSavingEditNpc">
                                                            <i class="bi bi-check"></i> Sauvegarder
                                                        </button>
                                                        <button class="btn btn-ghost btn-sm" @onclick="CancelEditNpc">Annuler</button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    @if (!string.IsNullOrEmpty(npc.Description))
                                                    {
                                                        <div class="npc-card-body-label">Description</div>
                                                        <p class="npc-description">@npc.Description</p>
                                                    }
                                                    @if (!string.IsNullOrEmpty(npc.PhysicalDescription))
                                                    {
                                                        <div class="npc-card-body-label">Apparence</div>
                                                        <p class="npc-description" style="font-style: italic;">@npc.PhysicalDescription</p>
                                                    }
                                                    @if (string.IsNullOrEmpty(npc.Description) && string.IsNullOrEmpty(npc.PhysicalDescription))
                                                    {
                                                        <p style="color: var(--color-text-muted); font-style: italic; font-size: var(--font-size-sm); margin: 0;">
                                                            Aucune description renseignée.
                                                        </p>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else if (!ShowNpcForm)
                        {
                            <div style="text-align: center; padding: var(--spacing-xl) 0; color: var(--color-text-muted);">
                                <i class="bi bi-people" style="font-size: 2rem; display: block; margin-bottom: var(--spacing-sm);"></i>
                                <p style="font-size: var(--font-size-sm); margin: 0;">Aucun PNJ pour ce chapitre.</p>
                                <p style="font-size: var(--font-size-xs); margin: 4px 0 0;">Cliquez sur <strong>Ajouter</strong> pour créer votre premier PNJ.</p>
                            </div>
                        }
                    </div>
                }
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: ÉVÉNEMENTS
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && Section == "events")
        {
            <AppPageHeader Title="Événements"
                           Icon="bi-lightning"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new("Événements") })" />

            <p style="color: var(--color-text-secondary); margin-bottom: var(--spacing-lg);">
                Les événements sont des modificateurs actifs qui affectent tous les personnages de ce monde.
            </p>

            <div style="display: flex; justify-content: flex-end; margin-bottom: var(--spacing-md);">
                <button class="btn btn-primary btn-sm" @onclick="() => ShowNewEventForm = !ShowNewEventForm">
                    <i class="bi bi-plus"></i> Créer un événement
                </button>
            </div>

            @if (ShowNewEventForm)
            {
                <div class="cdm-card" style="margin-bottom: var(--spacing-lg); border: 1px solid var(--theme-card-border, var(--color-border));">
                    <h4 class="card-title" style="margin-bottom: var(--spacing-md);">Nouvel événement de monde</h4>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Nom <span style="color:var(--color-error)">*</span></label>
                        <input type="text" class="form-control" @bind="NewEvent.Name" placeholder="Nom de l'événement..." />
                    </div>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3" @bind="NewEvent.Description" placeholder="Description narrative de l'événement..."></textarea>
                    </div>
                    <div class="form-two-col" style="margin-bottom: var(--spacing-sm);">
                        <div class="form-group">
                            <label class="form-label">Type d'effet</label>
                            <select class="form-control" @bind="NewEvent.EffectType">
                                <option value="@EventEffectType.Narrative">Narratif</option>
                                <option value="@EventEffectType.StatModifier">Modificateur de stat</option>
                                <option value="@EventEffectType.HealthModifier">Modificateur de PV</option>
                                <option value="@EventEffectType.DiceModifier">Modificateur de dé</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Durée</label>
                            <select class="form-control" @bind="NewEvent.IsPermanent">
                                <option value="true">Permanent</option>
                                <option value="false">Temporaire</option>
                            </select>
                        </div>
                    </div>
                    @if (NewEvent.EffectType != EventEffectType.Narrative)
                    {
                        <div class="form-two-col" style="margin-bottom: var(--spacing-sm);">
                            <div class="form-group">
                                <label class="form-label">Stat ciblée</label>
                                <input type="text" class="form-control" @bind="NewEvent.TargetStat" placeholder="ex: Force, PV..." />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Valeur modificateur</label>
                                <input type="number" class="form-control" @bind="NewEvent.ModifierValue" />
                            </div>
                        </div>
                    }
                    <div style="display: flex; gap: var(--spacing-sm);">
                        <button class="btn btn-primary btn-sm" @onclick="CreateEvent" disabled="@IsSaving">
                            <i class="bi bi-check"></i> Créer
                        </button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => ShowNewEventForm = false">@L["Common_Cancel"]</button>
                    </div>
                </div>
            }

            @if (IsLoadingEvents)
            {
                <AppLoadingSpinner Label="Chargement des événements..." />
            }
            else if (WorldEvents.Count == 0)
            {
                <AppEmptyState Icon="bi-lightning"
                               Title="Aucun événement"
                               Message="Aucun événement actif dans ce monde pour l'instant." />
            }
            else
            {
                @foreach (var ev in WorldEvents.OrderByDescending(e => e.CreatedAt))
                {
                    <div class="cdm-card" style="margin-bottom: var(--spacing-sm); border-left: 3px solid @(ev.IsActive ? "var(--theme-primary, var(--color-primary))" : "var(--color-border)");">
                        <div style="display: flex; align-items: flex-start; gap: var(--spacing-md);">
                            <div style="flex: 1; min-width: 0;">
                                <div style="display: flex; align-items: center; gap: var(--spacing-sm); margin-bottom: var(--spacing-xs);">
                                    <span style="font-weight: 600; color: var(--color-text-primary);">@ev.Name</span>
                                    @if (ev.IsActive)
                                    {
                                        <span class="status-badge status-active">Actif</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-paused">Inactif</span>
                                    }
                                    <span class="status-badge" style="background: var(--color-bg-secondary);">@GetEffectLabel(ev.EffectType)</span>
                                    <span class="status-badge" style="background: var(--color-bg-secondary);">@(ev.IsPermanent ? "Permanent" : "Temporaire")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(ev.Description))
                                {
                                    <p style="color: var(--color-text-secondary); font-size: var(--font-size-sm); margin: 0;">@ev.Description</p>
                                }
                                @if (ev.EffectType != EventEffectType.Narrative && ev.ModifierValue.HasValue)
                                {
                                    <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-xs);">
                                        @ev.TargetStat : @(ev.ModifierValue > 0 ? "+" : "")@ev.ModifierValue
                                    </p>
                                }
                            </div>
                            <div style="display: flex; gap: var(--spacing-xs); flex-shrink: 0;">
                                <button class="btn btn-ghost btn-sm" @onclick="() => ToggleEventActive(ev)" title="@(ev.IsActive ? "Désactiver" : "Activer")">
                                    <i class="bi @(ev.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                                <button class="btn btn-ghost btn-sm" @onclick="() => DeleteEvent(ev.Id)" style="color: var(--color-error);" title="Supprimer">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: SUCCÈS
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && Section == "achievements")
        {
            <AppPageHeader Title="Succès"
                           Icon="bi-trophy"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new("Succès") })" />

            <p style="color: var(--color-text-secondary); margin-bottom: var(--spacing-lg);">
                Les succès récompensent les accomplissements des joueurs dans ce monde.
            </p>

            <div style="display: flex; justify-content: flex-end; margin-bottom: var(--spacing-md);">
                <button class="btn btn-primary btn-sm" @onclick="() => ShowNewAchievementForm = !ShowNewAchievementForm">
                    <i class="bi bi-plus"></i> Créer un succès
                </button>
            </div>

            @if (ShowNewAchievementForm)
            {
                <div class="cdm-card" style="margin-bottom: var(--spacing-lg); border: 1px solid var(--theme-card-border, var(--color-border));">
                    <h4 class="card-title" style="margin-bottom: var(--spacing-md);">Nouveau succès de monde</h4>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Nom <span style="color:var(--color-error)">*</span></label>
                        <input type="text" class="form-control" @bind="NewAchievement.Name" placeholder="Nom du succès..." />
                    </div>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Description <span style="color:var(--color-error)">*</span></label>
                        <textarea class="form-control" rows="3" @bind="NewAchievement.Description" placeholder="Décrivez ce succès et comment l'obtenir..."></textarea>
                    </div>
                    <div class="form-two-col" style="margin-bottom: var(--spacing-sm);">
                        <div class="form-group">
                            <label class="form-label">Rareté</label>
                            <select class="form-control" @bind="NewAchievement.Rarity">
                                <option value="@AchievementRarity.Common">Commun</option>
                                <option value="@AchievementRarity.Rare">Rare</option>
                                <option value="@AchievementRarity.Epic">Épique</option>
                                <option value="@AchievementRarity.Legendary">Légendaire</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Visibilité</label>
                            <select class="form-control" @bind="NewAchievement.IsSecret">
                                <option value="false">Visible</option>
                                <option value="true">Secret</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group" style="margin-bottom: var(--spacing-sm);">
                        <label class="form-label">Récompense (optionnel)</label>
                        <input type="text" class="form-control" @bind="NewAchievement.RewardDescription" placeholder="Description de la récompense..." />
                    </div>
                    <div style="display: flex; gap: var(--spacing-sm);">
                        <button class="btn btn-primary btn-sm" @onclick="CreateAchievement" disabled="@IsSaving">
                            <i class="bi bi-check"></i> Créer
                        </button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => ShowNewAchievementForm = false">@L["Common_Cancel"]</button>
                    </div>
                </div>
            }

            @if (IsLoadingAchievements)
            {
                <AppLoadingSpinner Label="Chargement des succès..." />
            }
            else if (WorldAchievements.Count == 0)
            {
                <AppEmptyState Icon="bi-trophy"
                               Title="Aucun succès"
                               Message="Aucun succès défini pour ce monde." />
            }
            else
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--spacing-md);">
                    @foreach (var ach in WorldAchievements.OrderBy(a => a.Rarity).ThenBy(a => a.Name))
                    {
                        <div class="cdm-card" style="@GetRarityBorderStyle(ach.Rarity)">
                            <div style="display: flex; align-items: flex-start; gap: var(--spacing-sm); justify-content: space-between;">
                                <div style="flex: 1; min-width: 0;">
                                    <div style="display: flex; align-items: center; gap: var(--spacing-xs); margin-bottom: var(--spacing-xs); flex-wrap: wrap;">
                                        <i class="bi bi-trophy" style="color: @GetRarityColor(ach.Rarity);"></i>
                                        <span style="font-weight: 600; color: var(--color-text-primary); font-size: var(--font-size-sm);">@ach.Name</span>
                                        <span class="status-badge @GetRarityClass(ach.Rarity)">@GetRarityLabel(ach.Rarity)</span>
                                        @if (ach.IsSecret)
                                        {
                                            <span class="status-badge" style="background: var(--color-bg-secondary);"><i class="bi bi-eye-slash"></i> Secret</span>
                                        }
                                    </div>
                                    <p style="color: var(--color-text-secondary); font-size: var(--font-size-xs); margin: 0;">@ach.Description</p>
                                    @if (!string.IsNullOrWhiteSpace(ach.RewardDescription))
                                    {
                                        <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-xs);">
                                            <i class="bi bi-gift"></i> @ach.RewardDescription
                                        </p>
                                    }
                                    @if (ach.UnlockCount > 0)
                                    {
                                        <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-xs);">
                                            @ach.UnlockCount débloqué(s)
                                        </p>
                                    }
                                </div>
                                <button class="btn btn-ghost btn-sm" @onclick="() => DeleteAchievement(ach.Id)"
                                        style="color: var(--color-error); flex-shrink: 0;" title="Supprimer">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @* ──────────────────────────────────────────────────────────
           SECTION: INVITATIONS
           ────────────────────────────────────────────────────────── *@
        @if (IsOwner && Section == "invitations")
        {
            <AppPageHeader Title="Invitations"
                           Icon="bi-person-plus"
                           Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new("Invitations") })" />

            @* Lien d'invitation monde *@
            <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                <div class="world-section-header">
                    <div>
                        <h3 class="card-title" style="margin: 0;">Lien d'invitation au monde</h3>
                        <p style="color: var(--color-text-secondary); font-size: var(--font-size-sm); margin: var(--spacing-xs) 0 0;">
                            Partagez ce lien pour inviter des joueurs à rejoindre le monde avec leur personnage. Valable 30 jours.
                        </p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(WorldInviteToken))
                {
                    var worldInviteUrl = $"{Nav.BaseUri}worlds/join/{WorldInviteToken}";
                    var qrUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=180x180&data={Uri.EscapeDataString(worldInviteUrl)}&bgcolor=1a1a2e&color=d4af37";
                    <div class="invite-token-box" style="margin: var(--spacing-md) 0;">@worldInviteUrl</div>
                    <div style="display: flex; gap: var(--spacing-md); align-items: flex-start; flex-wrap: wrap;">
                        <div style="display: flex; gap: var(--spacing-sm);">
                            <button class="btn btn-ghost btn-sm" @onclick="() => CopyToClipboard(worldInviteUrl)" title="Copier le lien">
                                <i class="bi bi-clipboard"></i>
                                Copier
                            </button>
                            <button class="btn btn-ghost btn-sm" @onclick="GenerateWorldInviteToken" disabled="@IsGeneratingWorldToken">
                                <i class="bi bi-arrow-repeat"></i>
                                Régénérer
                            </button>
                        </div>
                        <div style="display: flex; flex-direction: column; align-items: center; gap: var(--spacing-xs);">
                            <img src="@qrUrl" alt="QR Code d'invitation" width="120" height="120"
                                 style="border-radius: var(--radius-md); border: 2px solid var(--color-border);" />
                            <span style="font-size: var(--font-size-xs); color: var(--color-text-muted);">Scanner pour rejoindre</span>
                        </div>
                    </div>
                }
                else
                {
                    <button class="btn btn-primary btn-sm" style="margin-top: var(--spacing-md);" @onclick="GenerateWorldInviteToken" disabled="@IsGeneratingWorldToken">
                        <i class="bi bi-link-45deg"></i>
                        @(IsGeneratingWorldToken ? "Génération..." : "Générer un lien d'invitation")
                    </button>
                }
            </div>

            @* Joueurs actuels *@
            <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
                <h3 class="card-title" style="margin-bottom: var(--spacing-md);">Joueurs dans le monde</h3>
                @if (IsLoadingWorldCharacters)
                {
                    <AppLoadingSpinner Label="Chargement..." />
                }
                else if (WorldCharacters.Count == 0)
                {
                    <AppEmptyState Icon="bi-people"
                                   Title="Aucun joueur"
                                   Message="Aucun joueur n'a encore rejoint ce monde. Partagez le lien ci-dessus." />
                }
                else
                {
                    <div class="character-list">
                        @foreach (var wc in WorldCharacters)
                        {
                            <div class="invite-row">
                                <div class="character-avatar-mini">
                                    @wc.CharacterName.Substring(0, 1).ToUpperInvariant()
                                </div>
                                <div style="flex: 1; min-width: 0;">
                                    <div style="font-weight: 600; font-size: var(--font-size-sm);">@wc.CharacterName</div>
                                    <div style="font-size: var(--font-size-xs); color: var(--color-text-muted);">
                                        Rejoint le @wc.JoinedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                                <button class="btn btn-ghost btn-sm" style="color: var(--color-danger);"
                                        @onclick="() => RemoveWorldCharacter(wc.CharacterId)"
                                        title="Retirer du monde">
                                    <i class="bi bi-person-x"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>

            @* Invitations par campagne *@
            <div class="cdm-card">
                <h3 class="card-title" style="margin-bottom: var(--spacing-sm);">Liens d'invitation par campagne</h3>
                <p style="color: var(--color-text-secondary); font-size: var(--font-size-sm); margin-bottom: var(--spacing-md);">
                    Générez un lien par campagne pour rejoindre directement cette campagne.
                </p>
                @if (Campaigns.Count == 0)
                {
                    <p style="color: var(--color-text-muted); font-size: var(--font-size-sm); font-style: italic;">Aucune campagne dans ce monde.</p>
                }
                else
                {
                    @foreach (var campaign in Campaigns)
                    {
                        var token = campaign.InviteToken;
                        var inviteUrl = token != null ? $"{Nav.BaseUri}join?token={token}" : null;
                        <div class="invite-row">
                            <div style="flex: 1; min-width: 0;">
                                <div style="font-weight: 600; font-size: var(--font-size-sm); margin-bottom: var(--spacing-xs);">
                                    <i class="bi bi-map" style="color: var(--color-text-muted); margin-right: var(--spacing-xs);"></i>
                                    @campaign.Name
                                </div>
                                @if (inviteUrl != null)
                                {
                                    <div class="invite-token-box">@inviteUrl</div>
                                }
                                else
                                {
                                    <span style="font-size: var(--font-size-xs); color: var(--color-text-muted); font-style: italic;">Aucun lien généré</span>
                                }
                            </div>
                            <div style="display: flex; gap: var(--spacing-xs); flex-shrink: 0;">
                                <button class="btn btn-ghost btn-sm" @onclick="() => GenerateInviteToken(campaign.Id)" disabled="@IsGeneratingToken">
                                    <i class="bi bi-arrow-repeat"></i>
                                    @(token == null ? "Générer" : "Régénérer")
                                </button>
                                @if (inviteUrl != null)
                                {
                                    <button class="btn btn-ghost btn-sm" @onclick="() => CopyToClipboard(inviteUrl)" title="Copier le lien">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        }

    </AppThemeWrapper>
}

<AppConfirmDialog @ref="DeleteWorldDialog"
                  Title="@L["Worlds_DeleteConfirmTitle"]"
                  Message="@L["Worlds_DeleteConfirm"]"
                  ConfirmLabel="@L["Common_Delete"]"
                  CancelLabel="@L["Common_Cancel"]"
                  OnConfirm="DeleteWorldAsync" />

<AppConfirmDialog @ref="DeleteCampaignDialog"
                  Title="Supprimer la campagne ?"
                  Message="Cette action est irréversible. Tous les chapitres seront supprimés."
                  ConfirmLabel="@L["Common_Delete"]"
                  CancelLabel="@L["Common_Cancel"]"
                  OnConfirm="DeleteCampaignAsync" />

<AppConfirmDialog @ref="DeleteNpcDialog"
                  Title="Supprimer ce PNJ ?"
                  Message="@($"Voulez-vous supprimer {NpcToDelete?.DisplayName ?? "ce PNJ"} ?")"
                  ConfirmLabel="@L["Common_Delete"]"
                  CancelLabel="@L["Common_Cancel"]"
                  OnConfirm="DeleteNpc" />

