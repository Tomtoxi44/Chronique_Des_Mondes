@page "/worlds/{Id:int}"
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Shared
@using Cdm.Web.Services.ApiClients
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@inject WorldApiClient WorldApiClient
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@inject IStringLocalizer<AppStrings> L
@rendermode InteractiveServer

<PageTitle>@(_world?.Name ?? L["Worlds_Title"]) — @L["AppName"]</PageTitle>

@if (_isLoading)
{
    <LoadingState Message="@L["Common_Loading"]" />
}
else if (_world == null)
{
    <ErrorState Title="@L["Worlds_NotFound"]" 
                Message="@L["Worlds_NotFoundMessage"]" 
                OnRetry="@(() => NavigationManager.NavigateTo("/worlds"))" />
}
else
{
    <PageHeader Title="@_world.Name" Subtitle="@($"Créé le {_world.CreatedAt:dd/MM/yyyy}")">
        <Actions>
            <GameTypeBadge GameType="@_world.GameType" />
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size20.Edit())"
                          OnClick="@(() => NavigationManager.NavigateTo($"/worlds/edit/{_world.Id}"))">
                @L["Common_Edit"]
            </FluentButton>
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size20.Delete())"
                          Color="Color.Error"
                          OnClick="HandleDelete">
                @L["Common_Delete"]
            </FluentButton>
        </Actions>
    </PageHeader>

    <!-- Stats -->
    <div class="cdm-grid-stats" style="margin-bottom: var(--spacing-xl);">
        <StatCard Icon="📜" Value="@_world.CampaignCount.ToString()" Label="@L["Home_Stats_Campaigns"]" />
        <StatCard Icon="⚔️" Value="@_world.CharacterCount.ToString()" Label="@L["Home_Stats_Characters"]" />
        <StatCard Icon="@(_world.IsActive ? "✅" : "⏸️")" Value="@(_world.IsActive ? "Actif" : "Inactif")" Label="Statut" />
    </div>

    <!-- Description -->
    @if (!string.IsNullOrEmpty(_world.Description))
    {
        <div class="cdm-content-card" style="margin-bottom: var(--spacing-lg);">
            <FluentLabel Typo="Typography.H5" Style="margin-bottom: var(--spacing-sm);">Description</FluentLabel>
            <p style="color: var(--color-text-secondary); line-height: 1.6; margin: 0;">@_world.Description</p>
        </div>
    }

    <!-- Characters -->
    <div class="cdm-content-card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-md);">
            <FluentLabel Typo="Typography.H5">@L["Characters_Title"]</FluentLabel>
            <FluentButton Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size20.Add())"
                          OnClick="@(() => NavigationManager.NavigateTo("/characters/create"))">
                @L["Characters_Create"]
            </FluentButton>
        </div>

        @if (_isLoadingCharacters)
        {
            <LoadingState Message="@L["Common_Loading"]" />
        }
        else if (_characters == null || !_characters.Any())
        {
            <EmptyState Icon="⚔️" Title="Aucun personnage" Message="Aucun personnage dans ce monde" />
        }
        else
        {
            <FluentLabel>@_characters.Count personnage(s) trouvé(s)</FluentLabel>
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private WorldDto? _world;
    private List<object> _characters = new();
    private bool _isLoading = true;
    private bool _isLoadingCharacters = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadWorldAsync();
        await LoadCharactersAsync();
    }

    private async Task LoadWorldAsync()
    {
        _isLoading = true;
        try
        {
            _world = await WorldApiClient.GetWorldByIdAsync(Id);
        }
        catch (Exception ex)
        {
            MessageService.ShowMessageBar($"Erreur: {ex.Message}", MessageIntent.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadCharactersAsync()
    {
        _isLoadingCharacters = true;
        try
        {
            _characters = await WorldApiClient.GetWorldCharactersAsync(Id);
        }
        catch (Exception ex)
        {
            MessageService.ShowMessageBar($"Erreur de chargement des personnages: {ex.Message}", MessageIntent.Error);
        }
        finally
        {
            _isLoadingCharacters = false;
        }
    }

    private async Task HandleDelete()
    {
        if (_world == null) return;

        var success = await WorldApiClient.DeleteWorldAsync(_world.Id);
        if (success)
        {
            MessageService.ShowMessageBar("Monde supprimé avec succès", MessageIntent.Success);
            NavigationManager.NavigateTo("/worlds");
        }
        else
        {
            MessageService.ShowMessageBar("Erreur lors de la suppression", MessageIntent.Error);
        }
    }
}
