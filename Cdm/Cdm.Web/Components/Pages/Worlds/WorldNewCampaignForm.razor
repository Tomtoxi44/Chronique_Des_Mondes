@* "New campaign" form (extracted from WorldDetail): owns its draft, error and save
   state; hands the created campaign back to the parent, which owns the list + navigation. *@
@namespace Cdm.Web.Components.Pages.Worlds
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Components.Shared
@inject Cdm.Web.Services.ApiClients.CampaignApiClient CampaignClient
@inject Microsoft.Extensions.Localization.IStringLocalizer<Cdm.Web.Resources.AppStrings> L

<AppPageHeader Title="@L["Campaigns_Create"]"
               Icon="bi-map"
               Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new(L["Campaigns_Create"]) })" />

<div style="max-width: 560px;">
    @if (!string.IsNullOrEmpty(CampaignCreateError))
    {
        <div class="alert alert-error" style="margin-bottom: var(--spacing-md);">@CampaignCreateError</div>
    }
    <div class="cdm-card">
        <div class="form-group" style="margin-bottom: var(--spacing-md);">
            <label class="form-label">Nom *</label>
            <input type="text" class="form-control" @bind="NewCampaign.Name" placeholder="La Quête des Éclats..." />
        </div>
        <div class="form-group" style="margin-bottom: var(--spacing-md);">
            <label class="form-label">Description</label>
            <textarea class="form-control" rows="3" @bind="NewCampaign.Description" placeholder="Décrivez cette campagne..."></textarea>
        </div>
        <div class="form-two-col" style="margin-bottom: var(--spacing-md);">
            <div class="form-group">
                <label class="form-label">Visibilité</label>
                <select class="form-control" @bind="NewCampaign.Visibility">
                    <option value="@Visibility.Private">Privée</option>
                    <option value="@Visibility.Public">Publique</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Joueurs max</label>
                <input type="number" class="form-control" min="1" max="20" @bind="NewCampaign.MaxPlayers" />
            </div>
        </div>
        <div style="display: flex; gap: var(--spacing-sm);">
            <button class="btn btn-primary" @onclick="Create" disabled="@IsSaving">
                <i class="bi bi-check"></i> @L["Common_Create"]
            </button>
            <a href="/worlds/@WorldId" class="btn btn-ghost">@L["Common_Cancel"]</a>
        </div>
    </div>
</div>

@code {
    [Parameter] public int WorldId { get; set; }
    [Parameter] public WorldDto World { get; set; } = default!;

    /// <summary>Raised with the newly created campaign; the parent owns the list and navigation.</summary>
    [Parameter] public EventCallback<CampaignDto> OnCreated { get; set; }

    private CreateCampaignDto NewCampaign = new();
    private string? CampaignCreateError;
    private bool IsSaving;

    private async Task Create()
    {
        if (World == null) return;
        IsSaving = true;
        CampaignCreateError = null;

        NewCampaign.WorldId = WorldId;
        var result = await CampaignClient.CreateCampaignAsync(NewCampaign);
        if (result != null)
        {
            NewCampaign = new CreateCampaignDto();
            if (OnCreated.HasDelegate)
            {
                await OnCreated.InvokeAsync(result);
            }
        }
        else
        {
            CampaignCreateError = "Erreur lors de la création de la campagne.";
        }

        IsSaving = false;
    }
}
