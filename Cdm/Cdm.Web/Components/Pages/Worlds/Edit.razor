@page "/worlds/edit/{Id:int}"
@using System.ComponentModel.DataAnnotations
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Components.Layout
@using Cdm.Web.Services.ApiClients
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@inject WorldApiClient WorldApiClient
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@inject IStringLocalizer<AppStrings> L
@rendermode InteractiveServer

<PageTitle>@L["Common_Edit"] @(_world?.Name ?? L["Worlds_Title"]) — @L["AppName"]</PageTitle>

@if (_isLoading)
{
    <LoadingState Message="@L["Common_Loading"]" />
}
else if (_world == null)
{
    <ErrorState Title="@L["Worlds_NotFound"]" 
                Message="@L["Worlds_NotFoundMessage"]" 
                OnRetry="@(() => NavigationManager.NavigateTo("/worlds"))" />
}
else
{
    <div style="max-width: 800px; margin: 0 auto;">
        <PageHeader Title="@L["Worlds_Edit"]" Subtitle="@L["Worlds_EditSubtitle"]" />

        <div class="cdm-content-card">
            <EditForm Model="@_model" OnValidSubmit="HandleSubmit" class="auth-form">
                <DataAnnotationsValidator />
                
                <div class="auth-form-group">
                    <FluentTextField @bind-Value="_model.Name"
                                     Label="@L["Worlds_Name"]"
                                     Placeholder="Ex: Le Royaume Oublié"
                                     Required
                                     Style="width: 100%;" />
                    <ValidationMessage For="@(() => _model.Name)" />
                </div>

                <div class="auth-form-group">
                    <FluentTextArea @bind-Value="_model.Description"
                                    Label="Description"
                                    Placeholder="Décrivez votre monde..."
                                    Rows="5"
                                    Style="width: 100%;" />
                </div>

                <div class="auth-form-group" style="display: flex; align-items: center; gap: 12px;">
                    <FluentCheckbox @bind-Value="_model.IsActive" Label="Monde actif" />
                    <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-muted); font-size: 12px;">
                        Les mondes inactifs ne sont pas visibles aux joueurs
                    </FluentLabel>
                </div>

                <FluentMessageBar Title="Information" Intent="MessageIntent.Info" Style="margin-bottom: var(--spacing-md);">
                    Le type de jeu ne peut pas être modifié après la création. Monde actuel: <strong>@GetGameTypeDisplay()</strong>
                </FluentMessageBar>

                <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: var(--spacing-md);">
                    <FluentButton Appearance="Appearance.Outline"
                                  OnClick="@(() => NavigationManager.NavigateTo($"/worlds/{Id}"))"
                                  Disabled="@_isSubmitting">
                        @L["Common_Cancel"]
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Accent"
                                  Type="ButtonType.Submit"
                                  Loading="@_isSubmitting"
                                  Disabled="@_isSubmitting"
                                  IconStart="@(new Icons.Regular.Size20.Save())">
                        @L["Common_Save"]
                    </FluentButton>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private WorldDto? _world;
    private UpdateWorldModel _model = new();
    private bool _isLoading = true;
    private bool _isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadWorldAsync();
    }

    private async Task LoadWorldAsync()
    {
        _isLoading = true;
        try
        {
            _world = await WorldApiClient.GetWorldByIdAsync(Id);
            
            if (_world != null)
            {
                _model.Name = _world.Name;
                _model.Description = _world.Description ?? string.Empty;
                _model.IsActive = _world.IsActive;
            }
        }
        catch (Exception ex)
        {
            MessageService.ShowMessageBar($"Erreur: {ex.Message}", MessageIntent.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (_world == null) return;

        _isSubmitting = true;
        try
        {
            var request = new UpdateWorldRequest(
                _model.Name,
                _model.Description,
                _model.IsActive
            );

            var result = await WorldApiClient.UpdateWorldAsync(Id, request);

            if (result != null)
            {
                MessageService.ShowMessageBar("Monde mis à jour avec succès !", MessageIntent.Success);
                NavigationManager.NavigateTo($"/worlds/{Id}");
            }
            else
            {
                MessageService.ShowMessageBar("Erreur lors de la mise à jour du monde", MessageIntent.Error);
            }
        }
        catch (Exception ex)
        {
            MessageService.ShowMessageBar($"Erreur: {ex.Message}", MessageIntent.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string GetGameTypeDisplay()
    {
        if (_world == null) return string.Empty;
        
        return _world.GameType switch
        {
            GameType.Generic => "Générique",
            GameType.DnD5e => "D&D 5e",
            GameType.Skyrim => "Skyrim",
            GameType.Custom => "Personnalisé",
            GameType.Empty => "Vide",
            GameType.Pathfinder => "Pathfinder",
            GameType.CallOfCthulhu => "Call of Cthulhu",
            GameType.Warhammer => "Warhammer",
            GameType.Cyberpunk => "Cyberpunk",
            _ => _world.GameType.ToString()
        };
    }

    public class UpdateWorldModel
    {
        [Required(ErrorMessage = "Le nom du monde est requis")]
        [StringLength(100, ErrorMessage = "Le nom ne peut pas dépasser 100 caractères")]
        public string Name { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;

        public bool IsActive { get; set; } = true;
    }
}
