@* Événements d'un monde : création + liste + activation/suppression.
   Composant auto-chargeant extrait de WorldDetail. *@
@namespace Cdm.Web.Components.Pages.Worlds
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Resources
@using Microsoft.Extensions.Localization
@inject Cdm.Web.Services.ApiClients.EventApiClient EventClient
@inject IStringLocalizer<AppStrings> L

<p style="color: var(--color-text-secondary); margin-bottom: var(--spacing-lg);">
    Les événements sont des modificateurs actifs qui affectent tous les personnages de ce monde.
</p>

<div style="display: flex; justify-content: flex-end; margin-bottom: var(--spacing-md);">
    <button class="btn btn-primary btn-sm" @onclick="() => ShowNewEventForm = !ShowNewEventForm">
        <i class="bi bi-plus"></i> Créer un événement
    </button>
</div>

@if (ShowNewEventForm)
{
    <div class="cdm-card" style="margin-bottom: var(--spacing-lg); border: 1px solid var(--theme-card-border, var(--color-border));">
        <AppSectionTitle Title="Nouvel événement de monde" Icon="bi-lightning-charge" />
        <div class="form-group" style="margin-bottom: var(--spacing-sm);">
            <label class="form-label">Nom <span style="color:var(--color-error)">*</span></label>
            <input type="text" class="form-control" @bind="NewEvent.Name" placeholder="Nom de l'événement..." />
        </div>
        <div class="form-group" style="margin-bottom: var(--spacing-sm);">
            <label class="form-label">Description</label>
            <textarea class="form-control" rows="3" @bind="NewEvent.Description" placeholder="Description narrative de l'événement..."></textarea>
        </div>
        <div class="form-two-col" style="margin-bottom: var(--spacing-sm);">
            <div class="form-group">
                <label class="form-label">Type d'effet</label>
                <select class="form-control" @bind="NewEvent.EffectType">
                    <option value="@EventEffectType.Narrative">Narratif</option>
                    <option value="@EventEffectType.StatModifier">Modificateur de stat</option>
                    <option value="@EventEffectType.HealthModifier">Modificateur de PV</option>
                    <option value="@EventEffectType.DiceModifier">Modificateur de dé</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Durée</label>
                <select class="form-control" @bind="NewEvent.IsPermanent">
                    <option value="true">Permanent</option>
                    <option value="false">Temporaire</option>
                </select>
            </div>
        </div>
        @if (NewEvent.EffectType != EventEffectType.Narrative)
        {
            <div class="form-two-col" style="margin-bottom: var(--spacing-sm);">
                <div class="form-group">
                    <label class="form-label">Stat ciblée</label>
                    <input type="text" class="form-control" @bind="NewEvent.TargetStat" placeholder="ex: Force, PV..." />
                </div>
                <div class="form-group">
                    <label class="form-label">Valeur modificateur</label>
                    <input type="number" class="form-control" @bind="NewEvent.ModifierValue" />
                </div>
            </div>
        }
        <div style="display: flex; gap: var(--spacing-sm);">
            <button class="btn btn-primary btn-sm" @onclick="CreateEvent" disabled="@IsSaving">
                <i class="bi bi-check"></i> Créer
            </button>
            <button class="btn btn-ghost btn-sm" @onclick="() => ShowNewEventForm = false">@L["Common_Cancel"]</button>
        </div>
    </div>
}

@if (IsLoadingEvents)
{
    <AppLoadingSpinner Label="Chargement des événements..." />
}
else if (WorldEvents.Count == 0)
{
    <AppEmptyState Icon="bi-lightning"
                   Title="Aucun événement"
                   Message="Aucun événement actif dans ce monde pour l'instant." />
}
else
{
    @foreach (var ev in WorldEvents.OrderByDescending(e => e.CreatedAt))
    {
        <div class="cdm-card" style="margin-bottom: var(--spacing-sm); border-left: 3px solid @(ev.IsActive ? "var(--theme-primary, var(--color-primary))" : "var(--color-border)");">
            <div style="display: flex; align-items: flex-start; gap: var(--spacing-md);">
                <div style="flex: 1; min-width: 0;">
                    <div style="display: flex; align-items: center; gap: var(--spacing-sm); margin-bottom: var(--spacing-xs);">
                        <span style="font-weight: 600; color: var(--color-text-primary);">@ev.Name</span>
                        @if (ev.IsActive)
                        {
                            <span class="status-badge status-active">@L["Common_Active"]</span>
                        }
                        else
                        {
                            <span class="status-badge status-paused">@L["Common_Inactive"]</span>
                        }
                        <span class="status-badge" style="background: var(--color-bg-secondary);">@GetEffectLabel(ev.EffectType)</span>
                        <span class="status-badge" style="background: var(--color-bg-secondary);">@(ev.IsPermanent ? "Permanent" : "Temporaire")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(ev.Description))
                    {
                        <p style="color: var(--color-text-secondary); font-size: var(--font-size-sm); margin: 0;">@ev.Description</p>
                    }
                    @if (ev.EffectType != EventEffectType.Narrative && ev.ModifierValue.HasValue)
                    {
                        <p style="color: var(--color-text-muted); font-size: var(--font-size-xs); margin-top: var(--spacing-xs);">
                            @ev.TargetStat : @(ev.ModifierValue > 0 ? "+" : "")@ev.ModifierValue
                        </p>
                    }
                </div>
                <div style="display: flex; gap: var(--spacing-xs); flex-shrink: 0;">
                    <button class="btn btn-ghost btn-sm" @onclick="() => ToggleEventActive(ev)" title="@(ev.IsActive ? "Désactiver" : "Activer")">
                        <i class="bi @(ev.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                    </button>
                    <button class="btn btn-ghost btn-sm" @onclick="() => DeleteEvent(ev.Id)" style="color: var(--color-error);" title="Supprimer">
                        <i class="bi bi-trash3"></i>
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int WorldId { get; set; }

    private List<EventDto> WorldEvents = new();
    private bool IsLoadingEvents;
    private bool ShowNewEventForm;
    private bool IsSaving;
    private CreateEventDto NewEvent = new() { Level = EventLevel.World, EffectType = EventEffectType.Narrative, IsPermanent = true };

    protected override async Task OnInitializedAsync()
    {
        IsLoadingEvents = true;
        WorldEvents = await EventClient.GetEventsByWorldAsync(WorldId);
        IsLoadingEvents = false;
    }

    private async Task CreateEvent()
    {
        IsSaving = true;
        NewEvent.WorldId = WorldId;
        NewEvent.Level = EventLevel.World;
        var result = await EventClient.CreateEventAsync(NewEvent);
        if (result != null)
        {
            WorldEvents.Insert(0, result);
            ShowNewEventForm = false;
            NewEvent = new() { Level = EventLevel.World, EffectType = EventEffectType.Narrative, IsPermanent = true };
        }
        IsSaving = false;
    }

    private async Task DeleteEvent(int eventId)
    {
        var ok = await EventClient.DeleteEventAsync(eventId);
        if (ok)
            WorldEvents.RemoveAll(e => e.Id == eventId);
    }

    private async Task ToggleEventActive(EventDto ev)
    {
        var result = await EventClient.SetEventActiveAsync(ev.Id, !ev.IsActive);
        if (result != null)
        {
            var idx = WorldEvents.FindIndex(e => e.Id == result.Id);
            if (idx >= 0) WorldEvents[idx] = result;
        }
    }

    private static string GetEffectLabel(EventEffectType type) => type switch
    {
        EventEffectType.StatModifier => "Modificateur de stat",
        EventEffectType.HealthModifier => "Modificateur de PV",
        EventEffectType.DiceModifier => "Modificateur de dé",
        EventEffectType.Narrative => "Narratif",
        _ => type.ToString()
    };
}
