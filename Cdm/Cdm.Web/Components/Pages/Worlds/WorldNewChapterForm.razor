@* "New chapter" form (extracted from WorldDetail): owns its draft and save state,
   pre-numbers the chapter from the existing list, and hands the result to the parent. *@
@namespace Cdm.Web.Components.Pages.Worlds
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Web.Components.Shared
@inject Cdm.Web.Services.ApiClients.ChapterApiClient ChapterClient
@inject Microsoft.Extensions.Localization.IStringLocalizer<Cdm.Web.Resources.AppStrings> L

<AppPageHeader Title="@L["Chapters_Create"]"
               Icon="bi-book"
               Breadcrumbs="@(new List<BreadcrumbItem> { new(L["Worlds_Title"], "/worlds"), new(World.Name, $"/worlds/{WorldId}"), new(Campaign?.Name ?? "Campagne", $"/worlds/{WorldId}?campaignId={CampaignId}"), new(L["Chapters_Create"]) })" />

<div style="max-width: 480px;">
    <div class="cdm-card">
        <div style="display: grid; grid-template-columns: 80px 1fr; gap: var(--spacing-md); margin-bottom: var(--spacing-md);">
            <div class="form-group">
                <label class="form-label">N°</label>
                <input type="number" class="form-control" @bind="NewChapter.ChapterNumber" min="1" style="text-align: center;" />
            </div>
            <div class="form-group">
                <label class="form-label">Titre du chapitre *</label>
                <input type="text" class="form-control" @bind="NewChapter.Title" placeholder="Titre du chapitre..." />
            </div>
        </div>
        <div style="display: flex; gap: var(--spacing-sm);">
            <button class="btn btn-primary" @onclick="Create" disabled="@IsSaving">
                <i class="bi bi-check"></i> @L["Common_Create"]
            </button>
            <a href="/worlds/@WorldId?campaignId=@CampaignId" class="btn btn-ghost">@L["Common_Cancel"]</a>
        </div>
    </div>
</div>

@code {
    [Parameter] public int WorldId { get; set; }
    [Parameter] public WorldDto World { get; set; } = default!;
    [Parameter] public int CampaignId { get; set; }
    [Parameter] public CampaignDto? Campaign { get; set; }

    /// <summary>Existing chapters, used only to pre-fill the next number.</summary>
    [Parameter] public List<ChapterDto> Chapters { get; set; } = new();

    /// <summary>Raised with the created chapter; the parent owns the list and navigation.</summary>
    [Parameter] public EventCallback<ChapterDto> OnCreated { get; set; }

    private CreateChapterDto NewChapter = new();
    private bool IsSaving;

    private int _seededCampaignId;

    protected override void OnParametersSet()
    {
        // Seed once per campaign; never renumber a draft being typed.
        if (_seededCampaignId != CampaignId)
        {
            _seededCampaignId = CampaignId;
            NewChapter = new CreateChapterDto
            {
                ChapterNumber = Chapters.Count > 0 ? Chapters.Max(c => c.ChapterNumber) + 1 : 1
            };
        }
    }

    private async Task Create()
    {
        IsSaving = true;
        NewChapter.CampaignId = CampaignId;
        var result = await ChapterClient.CreateChapterAsync(NewChapter);
        if (result != null)
        {
            NewChapter = new CreateChapterDto();
            if (OnCreated.HasDelegate)
            {
                await OnCreated.InvokeAsync(result);
            }
        }
        IsSaving = false;
    }
}
