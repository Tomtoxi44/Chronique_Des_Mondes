@page "/worlds/create"
@using System.ComponentModel.DataAnnotations
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Components.Layout
@using Cdm.Web.Services.ApiClients
@using Microsoft.AspNetCore.Authorization
@layout AppLayout
@attribute [Authorize]
@inject WorldApiClient WorldApiClient
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@rendermode InteractiveServer

<PageTitle>Nouveau Monde - Chronique des Mondes</PageTitle>

<FluentStack Orientation="Orientation.Vertical" Style="gap: 24px; max-width: 800px; margin: 0 auto;">
    <!-- Breadcrumbs -->
    <FluentBreadcrumb>
        <FluentBreadcrumbItem Href="/">
            <FluentIcon Value="@(new Icons.Regular.Size16.Home())" Style="margin-right: 4px;" /> Accueil
        </FluentBreadcrumbItem>
        <FluentBreadcrumbItem Href="/worlds">
            Mondes
        </FluentBreadcrumbItem>
        <FluentBreadcrumbItem>
            Nouveau
        </FluentBreadcrumbItem>
    </FluentBreadcrumb>

    <!-- Page Header -->
    <FluentStack Orientation="Orientation.Vertical" Style="gap: 4px;">
        <FluentLabel Typo="Typography.H3" Style="color: var(--color-text-primary);">Créer un Nouveau Monde</FluentLabel>
        <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-secondary);">Définissez votre univers de jeu et commencez votre aventure</FluentLabel>
    </FluentStack>

    <!-- Form Card -->
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 24px; padding: 8px;">
            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 20px;">
                    <!-- Name -->
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                            Nom du monde <span style="color: var(--color-error-500);">*</span>
                        </FluentLabel>
                        <FluentTextField @bind-Value="_model.Name"
                                         Placeholder="Ex: Le Royaume Oublié"
                                         Required
                                         Style="width: 100%;" />
                        <ValidationMessage For="@(() => _model.Name)" />
                    </FluentStack>

                    <!-- Game Type -->
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                            Type de jeu <span style="color: var(--color-error-500);">*</span>
                        </FluentLabel>
                        <FluentSelect TOption="string" 
                                      Value="@(_model.GameType.ToString())"
                                      ValueChanged="@((string value) => _model.GameType = Enum.Parse<GameType>(value))"
                                      Style="width: 100%;">
                            <FluentOption Value="@GameType.Empty.ToString()">🌍 Monde vide (lobby)</FluentOption>
                            <FluentOption Value="@GameType.Generic.ToString()">⚔️ Générique</FluentOption>
                            <FluentOption Value="@GameType.DnD5e.ToString()">🎲 D&D 5e</FluentOption>
                            <FluentOption Value="@GameType.Pathfinder.ToString()">📚 Pathfinder</FluentOption>
                            <FluentOption Value="@GameType.CallOfCthulhu.ToString()">🐙 Call of Cthulhu</FluentOption>
                            <FluentOption Value="@GameType.Warhammer.ToString()">⚔️ Warhammer</FluentOption>
                            <FluentOption Value="@GameType.Cyberpunk.ToString()">🤖 Cyberpunk</FluentOption>
                            <FluentOption Value="@GameType.Skyrim.ToString()">🐉 Skyrim</FluentOption>
                            <FluentOption Value="@GameType.Custom.ToString()">✨ Personnalisé</FluentOption>
                        </FluentSelect>
                        <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-muted); font-size: 12px;">
                            @GetGameTypeHelp()
                        </FluentLabel>
                    </FluentStack>

                    <!-- Description -->
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                            Description
                        </FluentLabel>
                        <FluentTextArea @bind-Value="_model.Description"
                                        Placeholder="Décrivez votre monde..."
                                        Rows="5"
                                        Style="width: 100%;" />
                        <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-muted); font-size: 12px;">
                            Une brève description de votre univers (optionnel)
                        </FluentLabel>
                    </FluentStack>

                    <!-- Action Buttons -->
                    <FluentStack Orientation="Orientation.Horizontal" 
                                 HorizontalAlignment="HorizontalAlignment.End"
                                 Style="gap: 12px; margin-top: 8px;">
                        <FluentButton Appearance="Appearance.Outline"
                                      OnClick="@(() => NavigationManager.NavigateTo("/worlds"))"
                                      Disabled="@_isSubmitting">
                            Annuler
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Accent"
                                      Type="ButtonType.Submit"
                                      Loading="@_isSubmitting"
                                      Disabled="@_isSubmitting"
                                      IconStart="@(new Icons.Regular.Size20.Add())">
                            Créer le monde
                        </FluentButton>
                    </FluentStack>
                </FluentStack>
            </EditForm>
        </FluentStack>
    </FluentCard>
</FluentStack>

@code {
    private CreateWorldModel _model = new();
    private bool _isSubmitting = false;

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        try
        {
            var request = new CreateWorldRequest(
                _model.Name,
                _model.Description ?? string.Empty,
                _model.GameType
            );

            var result = await WorldApiClient.CreateWorldAsync(request);

            if (result != null)
            {
                MessageService.ShowMessageBar("Monde créé avec succès !", MessageIntent.Success);
                NavigationManager.NavigateTo($"/worlds/{result.Id}");
            }
            else
            {
                MessageService.ShowMessageBar("Erreur lors de la création du monde", MessageIntent.Error);
            }
        }
        catch (Exception ex)
        {
            MessageService.ShowMessageBar($"Erreur: {ex.Message}", MessageIntent.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string GetGameTypeHelp()
    {
        return _model.GameType switch
        {
            GameType.Empty => "Un monde vide pour servir de lobby d'invitation",
            GameType.Generic => "Système de jeu flexible avec attributs génériques",
            GameType.DnD5e => "Dungeons & Dragons 5ème édition avec classes, races et sorts",
            GameType.Pathfinder => "Système Pathfinder avec compétences et classes",
            GameType.CallOfCthulhu => "Jeu d'horreur lovecraftien",
            GameType.Warhammer => "Univers de Warhammer Fantasy",
            GameType.Cyberpunk => "Futur dystopique cyberpunk",
            GameType.Skyrim => "Univers d'Elder Scrolls avec compétences et races",
            GameType.Custom => "Créez vos propres règles et attributs",
            _ => "Sélectionnez un type de jeu"
        };
    }

    public class CreateWorldModel
    {
        [Required(ErrorMessage = "Le nom du monde est requis")]
        [StringLength(100, ErrorMessage = "Le nom ne peut pas dépasser 100 caractères")]
        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }

        public GameType GameType { get; set; } = GameType.Generic;
    }
}
