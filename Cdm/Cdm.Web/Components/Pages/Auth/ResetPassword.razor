@page "/reset-password"
@layout Layout.BlankLayout

<PageTitle>Nouveau mot de passe — Chronique des Mondes</PageTitle>

<div class="auth-card">
    <div class="auth-branding">
        <img src="/images/LogoCdm.svg" alt="Logo Chronique des Mondes" class="auth-logo" />
        <div class="auth-app-name">@L["AppName"]</div>
        <div class="auth-tagline">@L["AppTagline"]</div>
    </div>

    <h2 class="auth-title">Nouveau mot de passe</h2>

    @if (string.IsNullOrWhiteSpace(Token))
    {
        <div class="alert alert-error" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            Ce lien de réinitialisation est incomplet. Merci de refaire une demande.
        </div>

        <div class="auth-footer-link">
            <a href="/forgot-password">Demander un nouveau lien</a>
        </div>
    }
    else if (IsSuccess)
    {
        <div class="alert alert-success" role="status">
            <i class="bi bi-check-circle-fill"></i>
            Votre mot de passe a bien été modifié. Vous pouvez maintenant vous connecter.
        </div>

        <div class="auth-footer-link">
            <a href="/login">Aller à la connexion</a>
        </div>
    }
    else
    {
        <p class="auth-help-text">
            Choisissez un nouveau mot de passe : au moins 8 caractères, avec une majuscule,
            une minuscule, un chiffre et un caractère spécial.
        </p>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-error" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @ErrorMessage
            </div>
        }

        <EditForm Model="Model" OnValidSubmit="HandleSubmit" FormName="reset-password-form">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="new-password" class="form-label">Nouveau mot de passe</label>
                <div class="input-with-icon">
                    <i class="bi bi-lock input-icon"></i>
                    <InputText id="new-password" @bind-Value="Model.NewPassword" class="form-control with-icon"
                               type="password" placeholder="••••••••" autocomplete="new-password"
                               aria-required="true" aria-describedby="new-password-error" />
                </div>
                <ValidationMessage id="new-password-error" For="() => Model.NewPassword" class="form-error" />
            </div>

            <div class="form-group">
                <label for="confirm-password" class="form-label">Confirmer le mot de passe</label>
                <div class="input-with-icon">
                    <i class="bi bi-lock-fill input-icon"></i>
                    <InputText id="confirm-password" @bind-Value="Model.ConfirmPassword" class="form-control with-icon"
                               type="password" placeholder="••••••••" autocomplete="new-password"
                               aria-required="true" aria-describedby="confirm-password-error" />
                </div>
                <ValidationMessage id="confirm-password-error" For="() => Model.ConfirmPassword" class="form-error" />
            </div>

            <button type="submit" class="btn btn-primary btn-full" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <AppLoadingSpinner Inline="true" Size="sm" />
                }
                else
                {
                    <i class="bi bi-shield-check"></i>
                }
                @(IsLoading ? L["Common_Loading"] : "Enregistrer le mot de passe")
            </button>
        </EditForm>

        <div class="auth-footer-link">
            <a href="/login">Retour à la connexion</a>
        </div>
    }
</div>
