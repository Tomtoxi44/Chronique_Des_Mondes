@page "/register"
@using Cdm.Web.Shared.DTOs.Models
@using Cdm.Web.Shared.DTOs.ViewModels
@using Cdm.Web.Components.Layout
@layout AuthLayout

<PageTitle>@L["Auth_Register"] — @L["AppName"]</PageTitle>

<div class="auth-card-header">
    <h3 class="auth-card-title">@L["Auth_Register"]</h3>
    <p class="auth-card-subtitle">Rejoignez l'aventure</p>
</div>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <FluentMessageBar Title="@L["Common_Error"]" Intent="MessageIntent.Error" Style="width: 100%; margin-bottom: 16px;">
        @ErrorMessage
    </FluentMessageBar>
}

<EditForm Model="@RegisterModel" OnValidSubmit="@HandleRegisterAsync" class="auth-form">
    <DataAnnotationsValidator />
    
    <div class="auth-form-group">
        <FluentTextField @bind-Value="RegisterModel.Email"
                         Label="@L["Auth_Email"]"
                         TextFieldType="TextFieldType.Email"
                         Placeholder="votre@email.com"
                         Required="true"
                         Disabled="@IsLoading"
                         Style="width: 100%;">
            <FluentIcon Value="@(new Icons.Regular.Size20.Mail())" Slot="start" />
        </FluentTextField>
        <FluentValidationMessage For="@(() => RegisterModel.Email)" />
    </div>

    <div class="auth-form-group">
        <FluentTextField @bind-Value="RegisterModel.Nickname"
                         Label="@L["Auth_Nickname"]"
                         Placeholder="Votre nom d'aventurier"
                         Required="true"
                         Disabled="@IsLoading"
                         MaxLength="50"
                         Style="width: 100%;">
            <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Slot="start" />
        </FluentTextField>
        <FluentValidationMessage For="@(() => RegisterModel.Nickname)" />
    </div>

    <div class="auth-form-group">
        <FluentTextField @bind-Value="RegisterModel.Password"
                         Label="@L["Auth_Password"]"
                         TextFieldType="@(ShowPassword ? TextFieldType.Text : TextFieldType.Password)"
                         Placeholder="Choisissez un mot de passe"
                         Required="true"
                         Disabled="@IsLoading"
                         Style="width: 100%;">
            <FluentIcon Value="@(new Icons.Regular.Size20.LockClosed())" Slot="start" />
            <FluentButton Slot="end" 
                          Appearance="Appearance.Stealth"
                          IconStart="@(ShowPassword ? new Icons.Regular.Size20.EyeOff() : new Icons.Regular.Size20.Eye())"
                          OnClick="@TogglePasswordVisibility" />
        </FluentTextField>
        <FluentLabel Typo="Typography.Body" Style="opacity: 0.6; margin-top: 4px; font-size: 12px;">
            @L["Auth_PasswordRequirements"]
        </FluentLabel>
        <FluentValidationMessage For="@(() => RegisterModel.Password)" />
    </div>

    <div class="auth-form-group">
        <FluentTextField @bind-Value="RegisterModel.ConfirmPassword"
                         Label="@L["Auth_ConfirmPassword"]"
                         TextFieldType="@(ShowPassword ? TextFieldType.Text : TextFieldType.Password)"
                         Placeholder="Confirmez votre mot de passe"
                         Required="true"
                         Disabled="@IsLoading"
                         Style="width: 100%;">
            <FluentIcon Value="@(new Icons.Regular.Size20.LockClosed())" Slot="start" />
        </FluentTextField>
        <FluentValidationMessage For="@(() => RegisterModel.ConfirmPassword)" />
    </div>

    <FluentButton Type="ButtonType.Submit"
                  Appearance="Appearance.Accent"
                  Loading="@IsLoading"
                  Disabled="@IsLoading"
                  Style="width: 100%; height: 44px;">
        @if (IsLoading)
        {
            <span>@L["Auth_Register"]...</span>
        }
        else
        {
            <FluentIcon Value="@(new Icons.Regular.Size20.PersonAdd())" Slot="start" />
            <span>@L["Auth_RegisterButton"]</span>
        }
    </FluentButton>
</EditForm>

<div class="auth-card-footer">
    <span class="auth-card-footer-text">@L["Auth_HasAccount"]</span>
    <a href="/login" class="auth-card-footer-link">@L["Auth_Login"]</a>
</div>
