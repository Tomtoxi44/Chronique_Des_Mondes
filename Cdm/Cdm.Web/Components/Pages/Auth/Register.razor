@page "/register"
@layout Layout.BlankLayout

<PageTitle>Inscription — Chronique des Mondes</PageTitle>

<div class="auth-card">
    <div class="auth-branding">
        <img src="/images/LogoCdm.svg" alt="Logo Chronique des Mondes" class="auth-logo" />
        <div class="auth-app-name">@L["AppName"]</div>
        <div class="auth-tagline">@L["AppTagline"]</div>
    </div>

    <h2 class="auth-title">@L["Auth_Register"]</h2>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-error" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            @ErrorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="alert alert-success" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            @SuccessMessage
        </div>
    }

    @if (!RegisterSuccess)
    {
        <EditForm Model="Model" OnValidSubmit="HandleRegister" FormName="register-form">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="nickname" class="form-label">@L["Auth_Nickname"]</label>
                <div class="input-with-icon">
                    <i class="bi bi-person input-icon"></i>
                    <InputText id="nickname" @bind-Value="Model.Nickname" class="form-control with-icon"
                               placeholder="MonPseudo" autocomplete="nickname"
                               aria-required="true" aria-describedby="nickname-error" />
                </div>
                <ValidationMessage id="nickname-error" For="() => Model.Nickname" class="form-error" />
            </div>

            <div class="form-group">
                <label for="email" class="form-label">@L["Auth_Email"]</label>
                <div class="input-with-icon">
                    <i class="bi bi-envelope input-icon"></i>
                    <InputText id="email" @bind-Value="Model.Email" class="form-control with-icon"
                               type="email" placeholder="votre@email.com" autocomplete="email"
                               aria-required="true" aria-describedby="email-error" />
                </div>
                <ValidationMessage id="email-error" For="() => Model.Email" class="form-error" />
            </div>

            <div class="form-group">
                <label for="password" class="form-label">@L["Auth_Password"]</label>
                <div class="input-with-icon">
                    <i class="bi bi-lock input-icon"></i>
                    <InputText id="password" @bind-Value="Model.Password" class="form-control with-icon"
                               type="password" placeholder="••••••••" autocomplete="new-password"
                               aria-required="true" aria-describedby="password-error password-hint" />
                </div>
                <ValidationMessage id="password-error" For="() => Model.Password" class="form-error" />
                <span id="password-hint" class="form-hint">@L["Auth_PasswordRequirements"]</span>
            </div>

            <div class="form-group">
                <label for="confirm-password" class="form-label">@L["Auth_ConfirmPassword"]</label>
                <div class="input-with-icon">
                    <i class="bi bi-lock-fill input-icon"></i>
                    <InputText id="confirm-password" @bind-Value="Model.ConfirmPassword" class="form-control with-icon"
                               type="password" placeholder="••••••••" autocomplete="new-password"
                               aria-required="true" aria-describedby="confirm-password-error" />
                </div>
                <ValidationMessage id="confirm-password-error" For="() => Model.ConfirmPassword" class="form-error" />
            </div>

            <button type="submit" class="btn btn-primary btn-full" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <AppLoadingSpinner Inline="true" Size="sm" />
                }
                else
                {
                    <i class="bi bi-person-plus"></i>
                }
                @(IsLoading ? L["Common_Loading"] : L["Auth_RegisterButton"])
            </button>
        </EditForm>
    }
    else
    {
        <div style="text-align: center; padding: var(--spacing-lg) 0;">
            <a href="/login" class="btn btn-primary btn-full">
                <i class="bi bi-box-arrow-in-right"></i>
                @L["Auth_Login"]
            </a>
        </div>
    }

    <div class="auth-footer-link">
        @L["Auth_HasAccount"] <a href="/login">@L["Auth_Login"]</a>
    </div>
</div>
