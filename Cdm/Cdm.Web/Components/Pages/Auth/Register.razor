@page "/register"
@using Cdm.Web.Shared.DTOs.Models
@using Cdm.Web.Shared.DTOs.ViewModels
@using Cdm.Web.Components.Layout
@layout AuthLayout

<PageTitle>Inscription - Chronique des Mondes</PageTitle>

<FluentCard Style="width: 100%; padding: 32px;">
    <FluentStack Orientation="Orientation.Vertical" Style="gap: 24px;">
        <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Style="gap: 8px;">
            <FluentLabel Typo="Typography.H4">Creer un compte</FluentLabel>
            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">Rejoignez l'aventure</FluentLabel>
        </FluentStack>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <FluentMessageBar Title="Erreur" Intent="MessageIntent.Error" Style="width: 100%;">
                @ErrorMessage
            </FluentMessageBar>
        }

        <EditForm Model="@RegisterModel" OnValidSubmit="@HandleRegisterAsync" style="width: 100%;">
            <DataAnnotationsValidator />
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px; width: 100%;">
                
                <FluentTextField @bind-Value="RegisterModel.Email"
                                 Label="Email"
                                 TextFieldType="TextFieldType.Email"
                                 Placeholder="votre@email.com"
                                 Required="true"
                                 Disabled="@IsLoading"
                                 Style="width: 100%;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Mail())" Slot="start" />
                </FluentTextField>
                <FluentValidationMessage For="@(() => RegisterModel.Email)" />

                <div style="width: 100%;">
                    <FluentTextField @bind-Value="RegisterModel.Nickname"
                                     Label="Pseudo"
                                     Placeholder="Votre nom d'aventurier"
                                     Required="true"
                                     Disabled="@IsLoading"
                                     MaxLength="50"
                                     Style="width: 100%;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Slot="start" />
                    </FluentTextField>
                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.6; margin-top: 4px; font-size: 12px;">
                        Maximum 50 caracteres
                    </FluentLabel>
                    <FluentValidationMessage For="@(() => RegisterModel.Nickname)" />
                </div>

                <div style="width: 100%;">
                    <FluentTextField @bind-Value="RegisterModel.Password"
                                     Label="Mot de passe"
                                     TextFieldType="@(ShowPassword ? TextFieldType.Text : TextFieldType.Password)"
                                     Placeholder="Choisissez un mot de passe"
                                     Required="true"
                                     Disabled="@IsLoading"
                                     Style="width: 100%;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.LockClosed())" Slot="start" />
                        <FluentButton Slot="end" 
                                      Appearance="Appearance.Stealth"
                                      IconStart="@(ShowPassword ? new Icons.Regular.Size20.EyeOff() : new Icons.Regular.Size20.Eye())"
                                      OnClick="@TogglePasswordVisibility"
                                      Title="@(ShowPassword ? "Masquer" : "Afficher")" />
                    </FluentTextField>
                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.6; margin-top: 4px; font-size: 12px;">
                        Min. 8 caracteres, majuscule, minuscule, chiffre, caractere special
                    </FluentLabel>
                    <FluentValidationMessage For="@(() => RegisterModel.Password)" />
                </div>

                <FluentTextField @bind-Value="RegisterModel.ConfirmPassword"
                                 Label="Confirmer le mot de passe"
                                 TextFieldType="@(ShowPassword ? TextFieldType.Text : TextFieldType.Password)"
                                 Placeholder="Confirmez votre mot de passe"
                                 Required="true"
                                 Disabled="@IsLoading"
                                 Style="width: 100%;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.LockClosed())" Slot="start" />
                </FluentTextField>
                <FluentValidationMessage For="@(() => RegisterModel.ConfirmPassword)" />

                <FluentCheckbox @bind-Value="@AcceptTerms">
                    <FluentLabel>
                        J'accepte les <FluentAnchor Href="/terms" Appearance="Appearance.Hypertext">conditions d'utilisation</FluentAnchor>
                        et la <FluentAnchor Href="/privacy" Appearance="Appearance.Hypertext">politique de confidentialite</FluentAnchor>
                    </FluentLabel>
                </FluentCheckbox>

                <FluentButton Type="ButtonType.Submit"
                              Appearance="Appearance.Accent"
                              Loading="@IsLoading"
                              Disabled="@(IsLoading || !AcceptTerms)"
                              Style="width: 100%; height: 44px;">
                    @if (IsLoading)
                    {
                        <span>Inscription...</span>
                    }
                    else
                    {
                        <FluentIcon Value="@(new Icons.Regular.Size20.PersonAdd())" Slot="start" />
                        <span>Creer mon compte</span>
                    }
                </FluentButton>
            </FluentStack>
        </EditForm>

        <FluentDivider Style="width: 100%;" />

        <FluentStack Orientation="Orientation.Horizontal" 
                     HorizontalAlignment="HorizontalAlignment.Center"
                     Style="gap: 8px;">
            <FluentLabel>Deja inscrit ?</FluentLabel>
            <FluentAnchor Href="/login" Appearance="Appearance.Hypertext">
                Se connecter
            </FluentAnchor>
        </FluentStack>
    </FluentStack>
</FluentCard>
