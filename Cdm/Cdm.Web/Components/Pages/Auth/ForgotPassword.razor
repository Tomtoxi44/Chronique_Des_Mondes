@page "/forgot-password"
@layout Layout.BlankLayout

<PageTitle>Mot de passe oublié — Chronique des Mondes</PageTitle>

<div class="auth-card">
    <div class="auth-branding">
        <img src="/images/LogoCdm.svg" alt="Logo Chronique des Mondes" class="auth-logo" />
        <div class="auth-app-name">@L["AppName"]</div>
        <div class="auth-tagline">@L["AppTagline"]</div>
    </div>

    <h2 class="auth-title">Mot de passe oublié</h2>

    @if (IsSubmitted)
    {
        <div class="alert alert-success" role="status">
            <i class="bi bi-envelope-check-fill"></i>
            Si un compte existe pour cette adresse, un email contenant un lien de
            réinitialisation vient d'être envoyé. Le lien est valable 1 heure.
        </div>

        <div class="auth-footer-link">
            <a href="/login">Retour à la connexion</a>
        </div>
    }
    else
    {
        <p class="auth-help-text">
            Saisissez l'adresse e-mail de votre compte : nous vous enverrons un lien
            pour choisir un nouveau mot de passe.
        </p>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-error" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @ErrorMessage
            </div>
        }

        <EditForm Model="Model" OnValidSubmit="HandleSubmit" FormName="forgot-password-form">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email" class="form-label">@L["Auth_Email"]</label>
                <div class="input-with-icon">
                    <i class="bi bi-envelope input-icon"></i>
                    <InputText id="email" @bind-Value="Model.Email" class="form-control with-icon"
                               type="email" placeholder="votre@email.com" autocomplete="email"
                               aria-required="true" aria-describedby="email-error" />
                </div>
                <ValidationMessage id="email-error" For="() => Model.Email" class="form-error" />
            </div>

            <button type="submit" class="btn btn-primary btn-full" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <AppLoadingSpinner Inline="true" Size="sm" />
                }
                else
                {
                    <i class="bi bi-send"></i>
                }
                @(IsLoading ? L["Common_Loading"] : "Envoyer le lien")
            </button>
        </EditForm>

        <div class="auth-footer-link">
            <a href="/login">Retour à la connexion</a>
        </div>
    }
</div>
