@page "/login"
@using Cdm.Web.Shared.DTOs.Models
@using Cdm.Web.Shared.DTOs.ViewModels
@using Cdm.Web.Components.Layout
@layout AuthLayout

<PageTitle>@L["Auth_Login"] — @L["AppName"]</PageTitle>

<div class="auth-card-header">
    <h3 class="auth-card-title">@L["Auth_Login"]</h3>
    <p class="auth-card-subtitle">Bon retour, aventurier !</p>
</div>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <FluentMessageBar Title="@L["Common_Error"]" Intent="MessageIntent.Error" Style="width: 100%; margin-bottom: 16px;">
        @ErrorMessage
    </FluentMessageBar>
}

<EditForm Model="@LoginModel" OnValidSubmit="@HandleLoginAsync" class="auth-form">
    <DataAnnotationsValidator />
    
    <div class="auth-form-group">
        <FluentTextField @bind-Value="LoginModel.Email"
                         Label="@L["Auth_Email"]"
                         TextFieldType="TextFieldType.Email"
                         Placeholder="votre@email.com"
                         Required="true"
                         Disabled="@IsLoading"
                         Style="width: 100%;">
            <FluentIcon Value="@(new Icons.Regular.Size20.Mail())" Slot="start" />
        </FluentTextField>
        <FluentValidationMessage For="@(() => LoginModel.Email)" />
    </div>

    <div class="auth-form-group">
        <FluentTextField @bind-Value="LoginModel.Password"
                         Label="@L["Auth_Password"]"
                         TextFieldType="@(ShowPassword ? TextFieldType.Text : TextFieldType.Password)"
                         Placeholder="Votre mot de passe"
                         Required="true"
                         Disabled="@IsLoading"
                         Style="width: 100%;">
            <FluentIcon Value="@(new Icons.Regular.Size20.LockClosed())" Slot="start" />
            <FluentButton Slot="end" 
                          Appearance="Appearance.Stealth"
                          IconStart="@(ShowPassword ? new Icons.Regular.Size20.EyeOff() : new Icons.Regular.Size20.Eye())"
                          OnClick="@TogglePasswordVisibility" />
        </FluentTextField>
        <FluentValidationMessage For="@(() => LoginModel.Password)" />
    </div>

    <FluentButton Type="ButtonType.Submit"
                  Appearance="Appearance.Accent"
                  Loading="@IsLoading"
                  Disabled="@IsLoading"
                  Style="width: 100%; height: 44px;">
        @if (IsLoading)
        {
            <span>@L["Auth_Login"]...</span>
        }
        else
        {
            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowEnter())" Slot="start" />
            <span>@L["Auth_LoginButton"]</span>
        }
    </FluentButton>
</EditForm>

<div class="auth-card-footer">
    <span class="auth-card-footer-text">@L["Auth_NoAccount"]</span>
    <a href="/register" class="auth-card-footer-link">@L["Auth_Register"]</a>
</div>
