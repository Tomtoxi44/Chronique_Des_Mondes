@page "/login"
@layout Layout.BlankLayout

<PageTitle>Connexion — Chronique des Mondes</PageTitle>

<div class="auth-card">
    <div class="auth-branding">
        <img src="/images/LogoCdm.svg" alt="Logo Chronique des Mondes" class="auth-logo" />
        <div class="auth-app-name">@L["AppName"]</div>
        <div class="auth-tagline">@L["AppTagline"]</div>
    </div>

    <h2 class="auth-title">@L["Auth_Login"]</h2>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-error" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            @ErrorMessage
        </div>
    }

    <EditForm Model="Model" OnValidSubmit="HandleLogin" FormName="login-form">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label for="email" class="form-label">@L["Auth_Email"]</label>
            <div class="input-with-icon">
                <i class="bi bi-envelope input-icon"></i>
                <InputText id="email" @bind-Value="Model.Email" class="form-control with-icon"
                           type="email" placeholder="votre@email.com" autocomplete="email" />
            </div>
            <ValidationMessage For="() => Model.Email" class="form-error" />
        </div>

        <div class="form-group">
            <label for="password" class="form-label">@L["Auth_Password"]</label>
            <div class="input-with-icon">
                <i class="bi bi-lock input-icon"></i>
                <InputText id="password" @bind-Value="Model.Password" class="form-control with-icon"
                           type="password" placeholder="••••••••" autocomplete="current-password" />
            </div>
            <ValidationMessage For="() => Model.Password" class="form-error" />
        </div>

        <button type="submit" class="btn btn-primary btn-full" disabled="@IsLoading">
            @if (IsLoading)
            {
                <AppLoadingSpinner Inline="true" Size="sm" />
            }
            else
            {
                <i class="bi bi-box-arrow-in-right"></i>
            }
            @(IsLoading ? L["Common_Loading"] : L["Auth_LoginButton"])
        </button>
    </EditForm>

    <div class="auth-footer-link">
        @L["Auth_NoAccount"] <a href="/register">@L["Auth_Register"]</a>
    </div>
</div>
