@page "/login"
@using Cdm.Web.Shared.DTOs.Models
@using Cdm.Web.Shared.DTOs.ViewModels
@using Cdm.Web.Components.Layout
@layout AuthLayout

<PageTitle>Connexion - Chronique des Mondes</PageTitle>

<div class="auth-card">
    <div class="auth-card-header">
        <h1 class="auth-card-title">Connexion</h1>
        <p class="auth-card-subtitle">Bon retour, aventurier !</p>
    </div>

    <div class="auth-card-body">
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="auth-alert auth-alert-error">
                <i class="bi bi-exclamation-triangle"></i>
                <span>@ErrorMessage</span>
            </div>
        }

        <EditForm Model="@LoginModel" OnValidSubmit="@HandleLoginAsync" class="auth-form">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email" class="form-label">
                    Email <span class="text-crimson">*</span>
                </label>
                <div class="input-group">
                    <i class="bi bi-envelope input-icon"></i>
                    <InputText 
                        id="email" 
                        @bind-Value="LoginModel.Email" 
                        class="input" 
                        placeholder="votre@email.com"
                        disabled="@IsLoading" />
                </div>
                <ValidationMessage For="@(() => LoginModel.Email)" class="input-error" />
            </div>

            <div class="form-group">
                <label for="password" class="form-label">
                    Mot de passe <span class="text-crimson">*</span>
                </label>
                <div class="input-group">
                    <i class="bi bi-lock input-icon"></i>
                    <InputText 
                        id="password" 
                        type="@(ShowPassword ? "text" : "password")"
                        @bind-Value="LoginModel.Password" 
                        class="input" 
                        placeholder="Votre mot de passe"
                        disabled="@IsLoading" />
                    <button type="button" 
                            class="input-icon-btn" 
                            @onclick="TogglePasswordVisibility"
                            tabindex="-1">
                        <i class="bi bi-@(ShowPassword ? "eye-slash" : "eye")"></i>
                    </button>
                </div>
                <ValidationMessage For="@(() => LoginModel.Password)" class="input-error" />
            </div>

            <div class="auth-form-row">
                <label class="checkbox-wrapper">
                    <input type="checkbox" @bind="RememberMe" class="checkbox" />
                    <span class="checkbox-label">Se souvenir de moi</span>
                </label>
                <a href="/forgot-password" class="auth-form-link">Mot de passe oublié ?</a>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span class="spinner spinner-sm"></span>
                    <span>Connexion...</span>
                }
                else
                {
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Se connecter</span>
                }
            </button>
        </EditForm>
    </div>

    <div class="auth-card-footer">
        <p class="auth-card-footer-text">
            Pas encore de compte ?
            <a href="/register" class="auth-card-footer-link">Créer un compte</a>
        </p>
    </div>
</div>
