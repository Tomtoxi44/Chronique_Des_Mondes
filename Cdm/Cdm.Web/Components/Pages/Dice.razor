@page "/dice"
@using Cdm.Web.Components.Layout
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Lanceur de Des - Chronique des Mondes</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <!-- Page Header -->
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
        <FluentLabel Typo="Typography.PageTitle" Style="color: var(--cdm-text-primary);">
            <FluentIcon Value="@(new Icons.Regular.Size24.Cube())" Style="margin-right: 8px; color: var(--cdm-gold);" />
            Lanceur de Des
        </FluentLabel>
        <FluentLabel Typo="Typography.Body" Style="color: var(--cdm-text-muted);">
            Lancez vos des pour vos parties de JDR
        </FluentLabel>
    </FluentStack>

    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="24" Style="flex-wrap: wrap;">
        <!-- Dice Selection -->
        <FluentCard Style="padding: 24px; flex: 1; min-width: 300px;">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="20">
                <FluentLabel Typo="Typography.H5" Style="color: var(--cdm-gold);">Choix des des</FluentLabel>
                
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(80px, 1fr)); gap: 12px;">
                    @foreach (var die in _diceTypes)
                    {
                        <div class="dice-selector @(die.Selected ? "selected" : "")" @onclick="@(() => ToggleDie(die))">
                            <div class="dice-icon">@die.Label</div>
                            <div class="dice-count">x@die.Count</div>
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="4" Style="margin-top: 4px;">
                                <FluentButton Appearance="Appearance.Stealth" 
                                              Size="ButtonSize.Small"
                                              IconStart="@(new Icons.Regular.Size16.Subtract())"
                                              OnClick="@(() => ChangeDieCount(die, -1))"
                                              OnClick:stopPropagation="true" />
                                <FluentButton Appearance="Appearance.Stealth" 
                                              Size="ButtonSize.Small"
                                              IconStart="@(new Icons.Regular.Size16.Add())"
                                              OnClick="@(() => ChangeDieCount(die, 1))"
                                              OnClick:stopPropagation="true" />
                            </FluentStack>
                        </div>
                    }
                </div>

                <!-- Modifier -->
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
                    <FluentLabel Style="color: var(--cdm-text-secondary);">Modificateur:</FluentLabel>
                    <FluentNumberField @bind-Value="_modifier" Style="width: 100px;" />
                </FluentStack>

                <!-- Roll Button -->
                <FluentButton Appearance="Appearance.Accent" 
                              Style="width: 100%; height: 48px; font-size: 16px;"
                              IconStart="@(new Icons.Regular.Size20.Cube())"
                              OnClick="RollDice"
                              Disabled="@(!HasSelectedDice)">
                    Lancer les des !
                </FluentButton>
            </FluentStack>
        </FluentCard>

        <!-- Results -->
        <FluentCard Style="padding: 24px; flex: 1; min-width: 300px;">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="20">
                <FluentLabel Typo="Typography.H5" Style="color: var(--cdm-gold);">Resultats</FluentLabel>
                
                @if (_lastRoll != null)
                {
                    <!-- Total -->
                    <div style="text-align: center; padding: 24px; background: var(--cdm-bg-dark); border-radius: 8px; border: 2px solid var(--cdm-gold);">
                        <FluentLabel Typo="Typography.Body" Style="color: var(--cdm-text-muted); text-transform: uppercase; letter-spacing: 0.1em; font-size: 12px;">
                            Total
                        </FluentLabel>
                        <div style="font-size: 64px; font-weight: 700; color: var(--cdm-gold); line-height: 1;">
                            @_lastRoll.Total
                        </div>
                        <FluentLabel Typo="Typography.Body" Style="color: var(--cdm-text-muted); margin-top: 8px;">
                            @_lastRoll.Formula
                        </FluentLabel>
                    </div>

                    <!-- Individual Rolls -->
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="flex-wrap: wrap; justify-content: center;">
                        @foreach (var roll in _lastRoll.Rolls)
                        {
                            <div class="dice-result @(roll.IsCritical ? "critical" : "") @(roll.IsFumble ? "fumble" : "")">
                                <span class="dice-type">@roll.DieType</span>
                                <span class="dice-value">@roll.Value</span>
                            </div>
                        }
                        @if (_modifier != 0)
                        {
                            <div class="dice-result modifier">
                                <span class="dice-type">MOD</span>
                                <span class="dice-value">@(_modifier >= 0 ? "+" : "")@_modifier</span>
                            </div>
                        }
                    </FluentStack>
                }
                else
                {
                    <div style="text-align: center; padding: 48px; color: var(--cdm-text-muted);">
                        <FluentIcon Value="@(new Icons.Regular.Size48.Cube())" Style="opacity: 0.3; margin-bottom: 16px;" />
                        <div>Selectionnez des des et lancez !</div>
                    </div>
                }

                <!-- History -->
                @if (_rollHistory.Any())
                {
                    <FluentDivider />
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="color: var(--cdm-text-secondary);">
                        Historique
                    </FluentLabel>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Style="max-height: 200px; overflow-y: auto;">
                        @foreach (var roll in _rollHistory.TakeLast(10).Reverse())
                        {
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" 
                                        Style="padding: 8px; background: var(--cdm-bg-dark); border-radius: 4px;">
                                <span style="color: var(--cdm-text-muted);">@roll.Formula</span>
                                <span style="color: var(--cdm-gold); font-weight: 600;">@roll.Total</span>
                            </FluentStack>
                        }
                    </FluentStack>
                }
            </FluentStack>
        </FluentCard>
    </FluentStack>
</FluentStack>

<style>
    .dice-selector {
        background: var(--cdm-bg-elevated);
        border: 2px solid transparent;
        border-radius: 8px;
        padding: 12px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .dice-selector:hover {
        border-color: var(--cdm-gold);
        background: rgba(201, 162, 39, 0.1);
    }
    
    .dice-selector.selected {
        border-color: var(--cdm-gold);
        background: rgba(201, 162, 39, 0.15);
    }
    
    .dice-icon {
        font-size: 20px;
        font-weight: 700;
        color: var(--cdm-gold);
    }
    
    .dice-count {
        font-size: 12px;
        color: var(--cdm-text-muted);
        margin-top: 4px;
    }
    
    .dice-result {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 8px 12px;
        background: var(--cdm-bg-elevated);
        border-radius: 6px;
        min-width: 50px;
    }
    
    .dice-result .dice-type {
        font-size: 10px;
        color: var(--cdm-text-muted);
        text-transform: uppercase;
    }
    
    .dice-result .dice-value {
        font-size: 20px;
        font-weight: 700;
        color: var(--cdm-text-primary);
    }
    
    .dice-result.critical {
        background: rgba(34, 197, 94, 0.2);
        border: 1px solid rgba(34, 197, 94, 0.5);
    }
    
    .dice-result.critical .dice-value {
        color: #22C55E;
    }
    
    .dice-result.fumble {
        background: rgba(215, 108, 88, 0.2);
        border: 1px solid rgba(215, 108, 88, 0.5);
    }
    
    .dice-result.fumble .dice-value {
        color: var(--cdm-accent-coral);
    }
    
    .dice-result.modifier {
        background: var(--cdm-bg-dark);
        border: 1px dashed var(--cdm-text-muted);
    }
</style>

@code {
    private List<DieType> _diceTypes = new()
    {
        new DieType { Label = "D4", Sides = 4 },
        new DieType { Label = "D6", Sides = 6 },
        new DieType { Label = "D8", Sides = 8 },
        new DieType { Label = "D10", Sides = 10 },
        new DieType { Label = "D12", Sides = 12 },
        new DieType { Label = "D20", Sides = 20 },
        new DieType { Label = "D100", Sides = 100 }
    };

    private int _modifier = 0;
    private RollResult? _lastRoll;
    private List<RollResult> _rollHistory = new();
    private Random _random = new();

    private bool HasSelectedDice => _diceTypes.Any(d => d.Count > 0);

    private void ToggleDie(DieType die)
    {
        if (die.Count == 0)
            die.Count = 1;
        die.Selected = !die.Selected;
    }

    private void ChangeDieCount(DieType die, int delta)
    {
        die.Count = Math.Max(0, Math.Min(20, die.Count + delta));
        if (die.Count > 0)
            die.Selected = true;
        else
            die.Selected = false;
    }

    private void RollDice()
    {
        var rolls = new List<DieRoll>();
        var formula = new List<string>();

        foreach (var die in _diceTypes.Where(d => d.Count > 0))
        {
            formula.Add($"{die.Count}{die.Label}");
            for (int i = 0; i < die.Count; i++)
            {
                var value = _random.Next(1, die.Sides + 1);
                rolls.Add(new DieRoll
                {
                    DieType = die.Label,
                    Sides = die.Sides,
                    Value = value,
                    IsCritical = value == die.Sides,
                    IsFumble = value == 1
                });
            }
        }

        var total = rolls.Sum(r => r.Value) + _modifier;
        var formulaStr = string.Join(" + ", formula);
        if (_modifier != 0)
            formulaStr += _modifier >= 0 ? $" + {_modifier}" : $" - {Math.Abs(_modifier)}";

        _lastRoll = new RollResult
        {
            Formula = formulaStr,
            Total = total,
            Rolls = rolls
        };

        _rollHistory.Add(_lastRoll);
    }

    private class DieType
    {
        public string Label { get; set; } = string.Empty;
        public int Sides { get; set; }
        public int Count { get; set; } = 0;
        public bool Selected { get; set; } = false;
    }

    private class DieRoll
    {
        public string DieType { get; set; } = string.Empty;
        public int Sides { get; set; }
        public int Value { get; set; }
        public bool IsCritical { get; set; }
        public bool IsFumble { get; set; }
    }

    private class RollResult
    {
        public string Formula { get; set; } = string.Empty;
        public int Total { get; set; }
        public List<DieRoll> Rolls { get; set; } = new();
    }
}
