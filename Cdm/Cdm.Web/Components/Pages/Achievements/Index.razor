@page "/achievements"
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Components.Layout
@using Cdm.Web.Services.ApiClients
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@inject AchievementApiClient AchievementApiClient
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Mes Succès - Chronique des Mondes</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <!-- Page Header -->
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Style="flex-wrap: wrap; gap: 16px;">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
            <FluentLabel Typo="Typography.H3" Style="color: var(--color-text-primary);">Mes Succès</FluentLabel>
            <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-secondary);">
                Vos accomplissements à travers les mondes et campagnes
            </FluentLabel>
        </FluentStack>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size20.Trophy())"
                      OnClick="@(() => NavigationManager.NavigateTo("/achievements/manage"))">
            Gérer les Succès
        </FluentButton>
    </FluentStack>

    <!-- Filters -->
    <FluentCard Style="padding: 16px;">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" Style="flex-wrap: wrap;">
            <FluentSearch Placeholder="Rechercher un succès..." @bind-Value="_searchTerm" Style="min-width: 250px;" />
            <FluentSelect TOption="string" @bind-Value="_rarityFilter" Style="min-width: 160px;">
                <FluentOption Value="">Toutes les raretés</FluentOption>
                <FluentOption Value="Common">Commun</FluentOption>
                <FluentOption Value="Rare">Rare</FluentOption>
                <FluentOption Value="Epic">Épique</FluentOption>
                <FluentOption Value="Legendary">Légendaire</FluentOption>
            </FluentSelect>
        </FluentStack>
    </FluentCard>

    @if (_isLoading)
    {
        <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 48px; gap: 16px;">
            <FluentProgressRing Style="width: 48px; height: 48px;" />
            <FluentLabel Typo="Typography.Body">Chargement de vos succès...</FluentLabel>
        </FluentStack>
    }
    else if (!FilteredAchievements.Any())
    {
        <FluentCard Style="padding: 48px; text-align: center;">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="16" HorizontalAlignment="HorizontalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size48.Trophy())" Style="color: var(--cdm-gold); opacity: 0.5;" />
                <FluentLabel Typo="Typography.H4" Style="color: var(--cdm-text-primary);">Aucun succès débloqué</FluentLabel>
                <FluentLabel Typo="Typography.Body" Style="color: var(--cdm-text-muted); max-width: 400px;">
                    Participez à des aventures pour gagner des succès et débloquer des récompenses !
                </FluentLabel>
            </FluentStack>
        </FluentCard>
    }
    else
    {
        <!-- Stats summary -->
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" Style="flex-wrap: wrap;">
            <FluentCard Style="padding: 16px; flex: 1; min-width: 140px; text-align: center;">
                <FluentLabel Typo="Typography.H3" Style="color: var(--cdm-gold);">@_myAchievements.Count</FluentLabel>
                <FluentLabel Style="color: var(--cdm-text-muted); font-size: 13px;">Total</FluentLabel>
            </FluentCard>
            <FluentCard Style="padding: 16px; flex: 1; min-width: 140px; text-align: center;">
                <FluentLabel Typo="Typography.H3" Style="color: #9d9d9d;">@_myAchievements.Count(a => a.Rarity == AchievementRarity.Common)</FluentLabel>
                <FluentLabel Style="color: var(--cdm-text-muted); font-size: 13px;">Communs</FluentLabel>
            </FluentCard>
            <FluentCard Style="padding: 16px; flex: 1; min-width: 140px; text-align: center;">
                <FluentLabel Typo="Typography.H3" Style="color: #0070ff;">@_myAchievements.Count(a => a.Rarity == AchievementRarity.Rare)</FluentLabel>
                <FluentLabel Style="color: var(--cdm-text-muted); font-size: 13px;">Rares</FluentLabel>
            </FluentCard>
            <FluentCard Style="padding: 16px; flex: 1; min-width: 140px; text-align: center;">
                <FluentLabel Typo="Typography.H3" Style="color: #a335ee;">@_myAchievements.Count(a => a.Rarity == AchievementRarity.Epic)</FluentLabel>
                <FluentLabel Style="color: var(--cdm-text-muted); font-size: 13px;">Épiques</FluentLabel>
            </FluentCard>
            <FluentCard Style="padding: 16px; flex: 1; min-width: 140px; text-align: center;">
                <FluentLabel Typo="Typography.H3" Style="color: #ff8000;">@_myAchievements.Count(a => a.Rarity == AchievementRarity.Legendary)</FluentLabel>
                <FluentLabel Style="color: var(--cdm-text-muted); font-size: 13px;">Légendaires</FluentLabel>
            </FluentCard>
        </FluentStack>

        <!-- Achievement grid -->
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px;">
            @foreach (var ua in FilteredAchievements)
            {
                <FluentCard Style="padding: 16px;">
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" VerticalAlignment="VerticalAlignment.Center">
                        @if (!string.IsNullOrEmpty(ua.IconUrl))
                        {
                            <img src="@ua.IconUrl" alt="@ua.AchievementName" style="width: 48px; height: 48px; object-fit: contain;" />
                        }
                        else
                        {
                            <FluentIcon Value="@(new Icons.Regular.Size48.Trophy())" Style="@($"color: {GetRarityColor(ua.Rarity)};")" />
                        }
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                                <FluentLabel Typo="Typography.H6" Style="color: var(--cdm-text-primary);">@ua.AchievementName</FluentLabel>
                                <FluentBadge Style="@($"background: {GetRarityColor(ua.Rarity)}; color: white; font-size: 11px;")">@GetRarityLabel(ua.Rarity)</FluentBadge>
                            </FluentStack>
                            <FluentLabel Typo="Typography.Body" Style="color: var(--cdm-text-muted); font-size: 13px;">@ua.AchievementDescription</FluentLabel>
                            <FluentLabel Style="color: var(--cdm-text-muted); font-size: 12px;">
                                Débloqué le @ua.UnlockedAt.ToString("dd/MM/yyyy")
                                @if (ua.IsManuallyAwarded && !string.IsNullOrEmpty(ua.AwardedByName))
                                {
                                    @($" par {ua.AwardedByName}")
                                }
                            </FluentLabel>
                            @if (!string.IsNullOrEmpty(ua.AwardMessage))
                            {
                                <FluentLabel Style="color: var(--cdm-text-muted); font-size: 12px; font-style: italic;">"@ua.AwardMessage"</FluentLabel>
                            }
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            }
        </div>
    }
</FluentStack>

@code {
    private List<UserAchievementDto> _myAchievements = new();
    private string _searchTerm = string.Empty;
    private string _rarityFilter = string.Empty;
    private bool _isLoading = true;

    private IEnumerable<UserAchievementDto> FilteredAchievements => _myAchievements
        .Where(a => string.IsNullOrEmpty(_searchTerm) || a.AchievementName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(a => string.IsNullOrEmpty(_rarityFilter) || a.Rarity.ToString() == _rarityFilter);

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _myAchievements = await AchievementApiClient.GetMyAchievementsAsync();
        _isLoading = false;
    }

    private string GetRarityColor(AchievementRarity rarity) => rarity switch
    {
        AchievementRarity.Common => "#9d9d9d",
        AchievementRarity.Rare => "#0070ff",
        AchievementRarity.Epic => "#a335ee",
        AchievementRarity.Legendary => "#ff8000",
        _ => "#9d9d9d"
    };

    private string GetRarityLabel(AchievementRarity rarity) => rarity switch
    {
        AchievementRarity.Common => "Commun",
        AchievementRarity.Rare => "Rare",
        AchievementRarity.Epic => "Épique",
        AchievementRarity.Legendary => "Légendaire",
        _ => rarity.ToString()
    };
}
