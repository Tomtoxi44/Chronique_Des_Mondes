@page "/characters/create"
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Shared
@using Cdm.Web.Shared.DTOs.Models
@using System.ComponentModel.DataAnnotations
@layout MainLayout
@rendermode InteractiveServer
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Characters_Create"] — @L["AppName"]</PageTitle>

<PageHeader Title="@L["Characters_Create"]" Subtitle="@L["Characters_CreateSubtitle"]">
    <Actions>
        <FluentButton Appearance="Appearance.Outline" Href="/characters"
                      IconStart="@(new Icons.Regular.Size20.ArrowLeft())">
            @L["Common_Back"]
        </FluentButton>
    </Actions>
</PageHeader>

<AuthorizeView>
    <Authorized Context="authContext">
        <div class="cdm-content-card" style="max-width: 800px;">
            <EditForm Model="@FormModel" OnValidSubmit="@HandleSubmitAsync">
                <DataAnnotationsValidator />
                <div class="auth-form">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <FluentMessageBar Title="@L["Common_Error"]" Intent="MessageIntent.Error" Style="width: 100%;">
                            @ErrorMessage
                        </FluentMessageBar>
                    }

                    <!-- Identity Section -->
                    <div class="cdm-section">
                        <h4 style="display: flex; align-items: center; gap: 8px; margin: 0 0 16px;">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Color="Color.Accent" />
                            @L["Characters_Identity"]
                        </h4>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                            <div class="auth-form-group">
                                <FluentTextField @bind-Value="FormModel.FirstName"
                                                 Label="@L["Characters_FirstName"]"
                                                 Placeholder="@L["Characters_FirstName"]"
                                                 Disabled="@IsSubmitting"
                                                 Style="width: 100%;" />
                                <FluentValidationMessage For="@(() => FormModel.FirstName)" />
                            </div>
                            <div class="auth-form-group">
                                <FluentTextField @bind-Value="FormModel.Name"
                                                 Label="@($"{L["Characters_Name"]} *")"
                                                 Placeholder="@L["Characters_Name"]"
                                                 Required="true"
                                                 Disabled="@IsSubmitting"
                                                 Style="width: 100%;" />
                                <FluentValidationMessage For="@(() => FormModel.Name)" />
                            </div>
                        </div>
                        <div class="auth-form-group" style="max-width: 200px;">
                            <FluentNumberField @bind-Value="FormModel.Age"
                                               Label="@L["Characters_Age"]"
                                               Min="0" Max="9999"
                                               Disabled="@IsSubmitting"
                                               Style="width: 100%;" />
                            <FluentValidationMessage For="@(() => FormModel.Age)" />
                        </div>
                    </div>

                    <!-- Description Section -->
                    <div class="cdm-section">
                        <h4 style="display: flex; align-items: center; gap: 8px; margin: 0 0 16px;">
                            <FluentIcon Value="@(new Icons.Regular.Size20.DocumentText())" Color="Color.Accent" />
                            @L["Characters_Description"]
                        </h4>
                        <div class="auth-form-group">
                            <FluentTextArea @bind-Value="FormModel.Description"
                                            Label="@L["Characters_Description"]"
                                            Placeholder="@L["Characters_DescriptionPlaceholder"]"
                                            Rows="5"
                                            Disabled="@IsSubmitting"
                                            Style="width: 100%;" />
                            <FluentValidationMessage For="@(() => FormModel.Description)" />
                        </div>
                    </div>

                    <!-- Avatar Section -->
                    <div class="cdm-section">
                        <h4 style="display: flex; align-items: center; gap: 8px; margin: 0 0 16px;">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Image())" Color="Color.Accent" />
                            @L["Characters_Avatar"]
                        </h4>
                        <div class="auth-form-group">
                            <FluentTextField @bind-Value="FormModel.AvatarUrl"
                                             Label="@L["Characters_AvatarUrl"]"
                                             Placeholder="https://exemple.com/avatar.jpg"
                                             TextFieldType="TextFieldType.Url"
                                             Disabled="@IsSubmitting"
                                             Style="width: 100%;" />
                            <FluentValidationMessage For="@(() => FormModel.AvatarUrl)" />
                        </div>
                        @if (!string.IsNullOrEmpty(FormModel.AvatarUrl))
                        {
                            <div style="display: flex; justify-content: center; margin-top: 12px;">
                                <FluentPersona Image="@FormModel.AvatarUrl" Name="Aperçu" ImageSize="120px" />
                            </div>
                        }
                    </div>

                    <!-- Form Actions -->
                    <div style="display: flex; justify-content: flex-end; gap: 12px; padding-top: 16px;">
                        <FluentButton Appearance="Appearance.Outline" 
                                      Href="/characters"
                                      IconStart="@(new Icons.Regular.Size20.Dismiss())">
                            @L["Common_Cancel"]
                        </FluentButton>
                        <FluentButton Type="ButtonType.Submit"
                                      Appearance="Appearance.Accent"
                                      Loading="@IsSubmitting"
                                      Disabled="@IsSubmitting"
                                      IconStart="@(new Icons.Regular.Size20.Checkmark())">
                            @(IsSubmitting ? L["Common_Saving"] : L["Characters_Create"])
                        </FluentButton>
                    </div>
                </div>
            </EditForm>
        </div>
    </Authorized>
    
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
