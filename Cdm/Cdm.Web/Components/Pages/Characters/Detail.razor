@page "/characters/{Id:int}"
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Shared
@using Cdm.Web.Shared.DTOs.Models
@layout MainLayout
@rendermode InteractiveServer
@inject IStringLocalizer<AppStrings> L

<PageTitle>@(Character?.Name ?? L["Common_Loading"]) — @L["AppName"]</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (IsLoading)
        {
            <LoadingState Message="@L["Common_Loading"]" />
        }
        else if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <ErrorState Title="@L["Common_Error"]" Message="@ErrorMessage" />
        }
        else if (Character != null)
        {
            <PageHeader Title="@GetCharacterFullName()">
                <Actions>
                    <FluentButton Appearance="Appearance.Accent" 
                                  IconStart="@(new Icons.Regular.Size20.Edit())"
                                  Href="@($"/characters/{Id}/edit")">
                        @L["Common_Edit"]
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Outline" 
                                  IconStart="@(new Icons.Regular.Size20.Delete())"
                                  OnClick="@ConfirmDelete"
                                  Style="color: var(--color-error); border-color: var(--color-error);">
                        @L["Common_Delete"]
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                                  Href="/characters">
                        @L["Common_Back"]
                    </FluentButton>
                </Actions>
            </PageHeader>

            <!-- Character Header Card -->
            <div class="cdm-content-card" style="margin-bottom: var(--spacing-lg);">
                <div style="display: flex; gap: 24px; flex-wrap: wrap;">
                    <div style="display: flex; flex-direction: column; align-items: center;">
                        @if (!string.IsNullOrEmpty(Character.AvatarUrl))
                        {
                            <FluentPersona Image="@Character.AvatarUrl" 
                                           Name="@GetCharacterFullName()"
                                           ImageSize="150px" />
                        }
                        else
                        {
                            <FluentPersona Name="@GetCharacterFullName()"
                                           ImageSize="150px" />
                        }
                    </div>
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 12px;">
                        @if (Character.Age.HasValue)
                        {
                            <FluentBadge Appearance="Appearance.Accent" Style="width: fit-content;">
                                <FluentIcon Value="@(new Icons.Regular.Size16.Calendar())" Style="margin-right: 4px;" />
                                @Character.Age ans
                            </FluentBadge>
                        }
                        <div style="display: flex; gap: 16px; opacity: 0.7; flex-wrap: wrap; font-size: 12px;">
                            <span style="display: flex; align-items: center; gap: 4px;">
                                <FluentIcon Value="@(new Icons.Regular.Size16.Clock())" />
                                @L["Common_CreatedAt"] @Character.CreatedAt.ToString("dd MMMM yyyy")
                            </span>
                            @if (Character.UpdatedAt.HasValue)
                            {
                                <span style="display: flex; align-items: center; gap: 4px;">
                                    <FluentIcon Value="@(new Icons.Regular.Size16.Edit())" />
                                    @L["Common_UpdatedAt"] @Character.UpdatedAt.Value.ToString("dd MMMM yyyy")
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Character.Description))
            {
                <div class="cdm-content-card" style="margin-bottom: var(--spacing-lg);">
                    <h4 style="display: flex; align-items: center; gap: 8px; margin: 0 0 16px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.DocumentText())" Color="Color.Accent" />
                        @L["Characters_Description"]
                    </h4>
                    <p style="white-space: pre-wrap; line-height: 1.6; margin: 0;">@Character.Description</p>
                </div>
            }

            <!-- Future Features -->
            <div class="cdm-content-card">
                <h4 style="display: flex; align-items: center; gap: 8px; margin: 0 0 16px;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Sparkle())" Color="Color.Accent" />
                    @L["Characters_FutureFeatures"]
                </h4>
                <div class="cdm-grid-stats">
                    <StatCard Icon="❤️" Value="—" Label="@L["Characters_Stats"]" />
                    <StatCard Icon="✨" Value="—" Label="@L["Characters_Skills"]" />
                    <StatCard Icon="🎒" Value="—" Label="@L["Characters_Inventory"]" />
                    <StatCard Icon="📖" Value="—" Label="@L["Characters_Journal"]" />
                </div>
            </div>
        }
    </Authorized>
    
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
