@page "/characters"
@using Cdm.Web.Components.Layout
@using Cdm.Web.Components.Shared
@using Cdm.Web.Shared.DTOs.Models
@layout MainLayout
@rendermode InteractiveServer
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Characters_Title"] — @L["AppName"]</PageTitle>

<PageHeader Title="@L["Characters_Title"]" Subtitle="@L["Characters_Subtitle"]">
    <Actions>
        <FluentButton Appearance="Appearance.Accent" 
                      IconStart="@(new Icons.Regular.Size20.Add())"
                      Href="/characters/create">
            @L["Characters_Create"]
        </FluentButton>
    </Actions>
</PageHeader>

<AuthorizeView>
    <Authorized>
        @if (IsLoading)
        {
            <LoadingState Message="@L["Common_Loading"]" />
        }
        else if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <ErrorState Title="@L["Common_Error"]" Message="@ErrorMessage" OnRetry="@LoadCharactersAsync" />
        }
        else if (Characters == null || !Characters.Any())
        {
            <EmptyState Icon="⚔️" Title="@L["Characters_Empty"]" Message="@L["Characters_EmptyMessage"]">
                <Action>
                    <FluentButton Appearance="Appearance.Accent" 
                                  IconStart="@(new Icons.Regular.Size20.Add())"
                                  Href="/characters/create">
                        @L["Characters_Create"]
                    </FluentButton>
                </Action>
            </EmptyState>
        }
        else
        {
            <div class="cdm-grid-cards">
                @foreach (var character in Characters)
                {
                    <div class="cdm-content-card" style="cursor: pointer;" @onclick="() => ViewCharacter(character.Id)">
                        <div style="display: flex; flex-direction: column; align-items: center; gap: 12px; padding: var(--spacing-md);">
                            @if (!string.IsNullOrEmpty(character.AvatarUrl))
                            {
                                <FluentPersona Image="@character.AvatarUrl" 
                                               Name="@GetCharacterFullName(character)"
                                               ImageSize="80px" />
                            }
                            else
                            {
                                <FluentPersona Name="@GetCharacterFullName(character)"
                                               ImageSize="80px" />
                            }
                            
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="text-align: center;">
                                @GetCharacterFullName(character)
                            </FluentLabel>
                            @if (character.Age.HasValue)
                            {
                                <FluentBadge Appearance="Appearance.Neutral">@character.Age ans</FluentBadge>
                            }
                            @if (!string.IsNullOrEmpty(character.Description))
                            {
                                <p style="opacity: 0.7; text-align: center; font-size: 12px; margin: 0;">
                                    @TruncateDescription(character.Description)
                                </p>
                            }
                        </div>
                        <FluentDivider />
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px var(--spacing-md);">
                            <span style="opacity: 0.6; font-size: 12px;">@character.CreatedAt.ToString("dd/MM/yyyy")</span>
                            <div style="display: flex; gap: 4px;">
                                <div @onclick:stopPropagation="true">
                                    <FluentButton Appearance="Appearance.Stealth"
                                                  IconStart="@(new Icons.Regular.Size16.Edit())"
                                                  Title="@L["Common_Edit"]"
                                                  OnClick="@(() => EditCharacter(character.Id))" />
                                </div>
                                <div @onclick:stopPropagation="true">
                                    <FluentButton Appearance="Appearance.Stealth"
                                                  IconStart="@(new Icons.Regular.Size16.Delete())"
                                                  Title="@L["Common_Delete"]"
                                                  OnClick="@(() => ConfirmDelete(character))" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </Authorized>
    
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>
