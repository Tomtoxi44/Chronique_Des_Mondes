@page "/characters/{CharacterId:int}/game-profile"
@using Cdm.Web.Components.Layout
@using Cdm.Web.Services.ApiClients
@using Cdm.Web.Shared.DTOs.Models
@using System.Text.Json
@layout AppLayout
@rendermode InteractiveServer
@inject CharacterApiClient CharacterClient
@inject NavigationManager NavigationManager

<PageTitle>Profil de jeu - Chronique des Mondes</PageTitle>

<FluentStack Orientation="Orientation.Vertical" Style="gap: 24px;">
    <FluentBreadcrumb>
        <FluentBreadcrumbItem Href="/characters">Personnages</FluentBreadcrumbItem>
        <FluentBreadcrumbItem Href="@($"/characters/{CharacterId}")">@_character?.Name</FluentBreadcrumbItem>
        <FluentBreadcrumbItem>Profil de jeu</FluentBreadcrumbItem>
    </FluentBreadcrumb>

    @if (_isLoading)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 48px; gap: 16px;">
                <FluentProgressRing />
                <FluentLabel>Chargement...</FluentLabel>
            </FluentStack>
        </FluentCard>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_error))
        {
            <FluentMessageBar Title="Erreur" Intent="MessageIntent.Error" Style="width: 100%;">@_error</FluentMessageBar>
        }

        @if (!string.IsNullOrEmpty(_success))
        {
            <FluentMessageBar Title="Succès" Intent="MessageIntent.Success" Style="width: 100%;">@_success</FluentMessageBar>
        }

        <!-- Campaign selector -->
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px; padding: 8px;">
                <FluentLabel Weight="FontWeight.Bold" Style="font-size: 16px;">Sélectionner une campagne</FluentLabel>
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 12px; align-items: flex-end;">
                    <div style="flex: 1;">
                        <FluentNumberField @bind-Value="_campaignId" Label="ID de la campagne" Min="1" Style="width: 100%;" />
                    </div>
                    <FluentButton Appearance="Appearance.Accent" @onclick="LoadProfile" Disabled="@(_campaignId <= 0)">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Search())" />
                        Charger le profil
                    </FluentButton>
                </FluentStack>
                <FluentLabel Style="font-size: 12px; color: var(--neutral-foreground-hint);">
                    Entrez l'ID de la campagne pour voir ou créer votre profil de jeu dans ce monde.
                </FluentLabel>
            </FluentStack>
        </FluentCard>

        @if (_profileLoaded)
        {
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 20px; padding: 8px;">
                    <FluentStack Orientation="Orientation.Horizontal" Style="justify-content: space-between; align-items: center;">
                        <FluentLabel Weight="FontWeight.Bold" Style="font-size: 18px;">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Style="margin-right: 8px;" />
                            Profil de jeu — Campagne #@_campaignId
                        </FluentLabel>
                        <FluentBadge Appearance="Appearance.Neutral">@(_profileExists ? "Profil existant" : "Nouveau profil")</FluentBadge>
                    </FluentStack>

                    <FluentDivider />

                    <FluentLabel Weight="FontWeight.Bold">Données du profil (JSON)</FluentLabel>
                    <FluentTextArea @bind-Value="_profileJson"
                                    Rows="12"
                                    Style="width: 100%; font-family: 'Courier New', monospace; font-size: 13px;"
                                    Placeholder='{"level": 1, "hp": 10, "maxHp": 10, "class": "Guerrier"}' />
                    <FluentLabel Style="font-size: 12px; color: var(--neutral-foreground-hint);">
                        Entrez les données de votre personnage en JSON selon le système de jeu de la campagne.
                    </FluentLabel>

                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 12px;">
                        <FluentButton Appearance="Appearance.Accent"
                                      @onclick="SaveProfile"
                                      Disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <FluentProgressRing Width="16px" />
                                <span style="margin-left: 8px;">Sauvegarde...</span>
                            }
                            else
                            {
                                <FluentIcon Value="@(new Icons.Regular.Size16.Save())" />
                                <span style="margin-left: 8px;">@(_profileExists ? "Mettre à jour" : "Créer le profil")</span>
                            }
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Outline" @onclick="ResetJson">
                            Réinitialiser
                        </FluentButton>
                    </FluentStack>
                </FluentStack>
            </FluentCard>
        }

        @if (_profileExists && !string.IsNullOrEmpty(_profileDisplayJson))
        {
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 12px; padding: 8px;">
                    <FluentLabel Weight="FontWeight.Bold">Données actuelles du profil</FluentLabel>
                    <pre style="background: var(--neutral-layer-3, #1a1f2e); padding: 16px; border-radius: 8px; overflow-x: auto; font-size: 13px; color: var(--neutral-foreground-rest); margin: 0;">@_profileDisplayJson</pre>
                </FluentStack>
            </FluentCard>
        }
    }
</FluentStack>

@code {
    [Parameter] public int CharacterId { get; set; }
    [SupplyParameterFromQuery] public int? CampaignId { get; set; }

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _profileLoaded = false;
    private bool _profileExists = false;

    private CharacterDto? _character;
    private int _campaignId;
    private string _profileJson = string.Empty;
    private string _profileDisplayJson = string.Empty;
    private string _originalProfileJson = string.Empty;
    private string _error = string.Empty;
    private string _success = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _character = await CharacterClient.GetCharacterByIdAsync(CharacterId);

        if (CampaignId.HasValue && CampaignId > 0)
        {
            _campaignId = CampaignId.Value;
            await LoadProfile();
        }

        _isLoading = false;
    }

    private async Task LoadProfile()
    {
        _error = string.Empty;
        _success = string.Empty;
        _profileLoaded = false;
        _profileExists = false;

        if (_campaignId <= 0) return;

        var profile = await CharacterClient.GetGameProfileAsync(CharacterId, _campaignId);

        if (profile.HasValue && profile.Value.ValueKind != JsonValueKind.Null)
        {
            _profileExists = true;
            _profileDisplayJson = JsonSerializer.Serialize(profile.Value, new JsonSerializerOptions { WriteIndented = true });
            _profileJson = _profileDisplayJson;
            _originalProfileJson = _profileDisplayJson;
        }
        else
        {
            _profileExists = false;
            _profileJson = "{\n  \"level\": 1,\n  \"hp\": 10,\n  \"maxHp\": 10\n}";
        }

        _profileLoaded = true;
    }

    private async Task SaveProfile()
    {
        _error = string.Empty;
        _success = string.Empty;

        if (string.IsNullOrWhiteSpace(_profileJson))
        {
            _error = "Le JSON du profil ne peut pas être vide.";
            return;
        }

        object? profileData;
        try
        {
            profileData = JsonSerializer.Deserialize<object>(_profileJson);
        }
        catch
        {
            _error = "Le JSON saisi n'est pas valide. Vérifiez la syntaxe.";
            return;
        }

        _isSaving = true;
        bool success;

        if (_profileExists)
            success = await CharacterClient.UpdateGameProfileAsync(CharacterId, _campaignId, profileData!);
        else
            success = await CharacterClient.CreateGameProfileAsync(CharacterId, _campaignId, profileData!);

        _isSaving = false;

        if (success)
        {
            _success = _profileExists ? "Profil de jeu mis à jour avec succès." : "Profil de jeu créé avec succès.";
            _profileExists = true;
            _profileDisplayJson = JsonSerializer.Serialize(JsonSerializer.Deserialize<object>(_profileJson), new JsonSerializerOptions { WriteIndented = true });
            _originalProfileJson = _profileJson;
        }
        else
        {
            _error = "Impossible de sauvegarder le profil. Vérifiez que la campagne existe et que vous êtes autorisé.";
        }
    }

    private void ResetJson()
    {
        _profileJson = _originalProfileJson;
        _error = string.Empty;
        _success = string.Empty;
    }
}
