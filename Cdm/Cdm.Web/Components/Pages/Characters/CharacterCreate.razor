@page "/characters/create"
@attribute [Authorize]

<PageTitle>@L["Characters_Create"] — Chronique des Mondes</PageTitle>

<AppPageHeader Title="@L["Characters_Create"]"
               Subtitle="@L["Characters_CreateSubtitle"]"
               Icon="bi-person-plus"
               Breadcrumbs="@Breadcrumbs" />

<div style="max-width: 680px;">
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-error" style="margin-bottom: var(--spacing-lg);">
            <i class="bi bi-exclamation-triangle-fill"></i>
            @ErrorMessage
        </div>
    }

    <EditForm Model="Model" OnValidSubmit="HandleCreate" FormName="character-create">
        <DataAnnotationsValidator />

        <div class="cdm-card" style="margin-bottom: var(--spacing-lg);">
            <h3 class="card-title" style="margin-bottom: var(--spacing-md);">@L["Characters_Identity"]</h3>

            <div class="form-two-col">
                <div class="form-group">
                    <label class="form-label">@L["Characters_Name"] *</label>
                    <InputText @bind-Value="Model.Name" class="form-control" placeholder="Nom de famille..." />
                    <ValidationMessage For="() => Model.Name" class="form-error" />
                </div>
                <div class="form-group">
                    <label class="form-label">@L["Characters_FirstName"]</label>
                    <InputText @bind-Value="Model.FirstName" class="form-control" placeholder="Prénom..." />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">@L["Characters_Age"]</label>
                <InputNumber @bind-Value="Model.Age" class="form-control" min="0" max="10000" />
                <ValidationMessage For="() => Model.Age" class="form-error" />
            </div>

            <div class="form-group">
                <label class="form-label">@L["Characters_Description"]</label>
                <InputTextArea @bind-Value="Model.Description" class="form-control" rows="4"
                               placeholder="@L["Characters_DescriptionPlaceholder"]" />
                <ValidationMessage For="() => Model.Description" class="form-error" />
            </div>

            <div class="form-group">
                <label class="form-label">@L["Characters_AvatarUrl"]</label>
                <InputText @bind-Value="Model.AvatarUrl" class="form-control"
                           type="url" placeholder="https://..." />
                <ValidationMessage For="() => Model.AvatarUrl" class="form-error" />
            </div>
        </div>

        <div class="form-actions">
            <a href="/characters" class="btn btn-ghost">
                <i class="bi bi-arrow-left"></i>
                @L["Common_Cancel"]
            </a>
            <button type="submit" class="btn btn-primary" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <AppLoadingSpinner Inline="true" Size="sm" />
                }
                else
                {
                    <i class="bi bi-check-circle"></i>
                }
                @(IsLoading ? L["Common_Saving"] : L["Common_Create"])
            </button>
        </div>
    </EditForm>
</div>
