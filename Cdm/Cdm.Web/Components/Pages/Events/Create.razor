@page "/events/create"
@using Cdm.Business.Abstraction.DTOs
@using Cdm.Common.Enums
@using Cdm.Web.Components.Layout
@using Cdm.Web.Services.ApiClients
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@inject EventApiClient EventApiClient
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Créer un Événement - Chronique des Mondes</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24" Style="max-width: 700px; margin: 0 auto;">
    <!-- Header -->
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
        <FluentButton Appearance="Appearance.Outline"
                      IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                      OnClick="@(() => NavigationManager.NavigateTo("/events"))">
            Retour
        </FluentButton>
        <FluentLabel Typo="Typography.H3" Style="color: var(--color-text-primary);">Créer un Événement</FluentLabel>
    </FluentStack>

    <FluentCard Style="padding: 24px;">
        <EditForm Model="@_dto" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="20">

                <!-- Name -->
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                    <FluentLabel>Nom de l'événement *</FluentLabel>
                    <FluentTextField @bind-Value="_dto.Name" Placeholder="Ex: Tempête de neige arcanique" Style="width: 100%;" />
                    <FluentValidationMessage For="@(() => _dto.Name)" />
                </FluentStack>

                <!-- Description -->
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                    <FluentLabel>Description</FluentLabel>
                    <FluentTextArea @bind-Value="_dto.Description" Rows="4" Placeholder="Décrivez l'événement et son contexte narratif..." Style="width: 100%;" />
                    <FluentValidationMessage For="@(() => _dto.Description)" />
                </FluentStack>

                <!-- Level + Context ID -->
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" Style="flex-wrap: wrap;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="6" Style="flex: 1; min-width: 200px;">
                        <FluentLabel>Niveau d'effet *</FluentLabel>
                        <FluentSelect TOption="string" @bind-Value="_levelStr" @bind-Value:after="OnLevelChanged" Style="width: 100%;">
                            <FluentOption Value="World">Monde</FluentOption>
                            <FluentOption Value="Campaign">Campagne</FluentOption>
                            <FluentOption Value="Chapter">Chapitre</FluentOption>
                        </FluentSelect>
                    </FluentStack>

                    @if (_dto.Level == EventLevel.World)
                    {
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6" Style="flex: 1; min-width: 200px;">
                            <FluentLabel>ID du Monde *</FluentLabel>
                            <FluentNumberField @bind-Value="_worldId" Min="1" Placeholder="ID du monde" Style="width: 100%;" />
                        </FluentStack>
                    }
                    else if (_dto.Level == EventLevel.Campaign)
                    {
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6" Style="flex: 1; min-width: 200px;">
                            <FluentLabel>ID de la Campagne *</FluentLabel>
                            <FluentNumberField @bind-Value="_campaignId" Min="1" Placeholder="ID de la campagne" Style="width: 100%;" />
                        </FluentStack>
                    }
                    else if (_dto.Level == EventLevel.Chapter)
                    {
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6" Style="flex: 1; min-width: 200px;">
                            <FluentLabel>ID du Chapitre *</FluentLabel>
                            <FluentNumberField @bind-Value="_chapterId" Min="1" Placeholder="ID du chapitre" Style="width: 100%;" />
                        </FluentStack>
                    }
                </FluentStack>

                <!-- Effect Type -->
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                    <FluentLabel>Type d'effet *</FluentLabel>
                    <FluentSelect TOption="string" @bind-Value="_effectStr" @bind-Value:after="OnEffectChanged" Style="width: 100%;">
                        <FluentOption Value="StatModifier">Modificateur de statistique</FluentOption>
                        <FluentOption Value="HealthModifier">Modificateur de PV</FluentOption>
                        <FluentOption Value="DiceModifier">Modificateur de jet de dé</FluentOption>
                        <FluentOption Value="Narrative">Narratif uniquement</FluentOption>
                    </FluentSelect>
                </FluentStack>

                <!-- Stat/Modifier fields (only for non-narrative) -->
                @if (_dto.EffectType != EventEffectType.Narrative)
                {
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" Style="flex-wrap: wrap;">
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6" Style="flex: 1; min-width: 180px;">
                            <FluentLabel>Statistique cible</FluentLabel>
                            <FluentTextField @bind-Value="_dto.TargetStat" Placeholder="Ex: Strength, MaxHP, AttackRoll" Style="width: 100%;" />
                        </FluentStack>
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6" Style="flex: 1; min-width: 120px;">
                            <FluentLabel>Valeur du modificateur</FluentLabel>
                            <FluentNumberField @bind-Value="_modifierValue" Placeholder="Ex: -2 ou +5" Style="width: 100%;" />
                        </FluentStack>
                    </FluentStack>
                }

                <!-- Duration -->
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" VerticalAlignment="VerticalAlignment.Center" Style="flex-wrap: wrap;">
                    <FluentCheckbox @bind-Value="_dto.IsPermanent" Label="Événement permanent" />
                    @if (!_dto.IsPermanent)
                    {
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6" Style="flex: 1; min-width: 200px;">
                            <FluentLabel>Date d'expiration</FluentLabel>
                            <FluentDatePicker @bind-Value="_expiresAt" Style="width: 100%;" />
                        </FluentStack>
                    }
                </FluentStack>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <FluentMessageBar Title="Erreur" Intent="MessageIntent.Error" Style="width: 100%;">@_errorMessage</FluentMessageBar>
                }

                <!-- Actions -->
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" HorizontalAlignment="HorizontalAlignment.End">
                    <FluentButton Appearance="Appearance.Outline" OnClick="@(() => NavigationManager.NavigateTo("/events"))">
                        Annuler
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Accent" Type="ButtonType.Submit" Loading="_isSaving">
                        Créer l'événement
                    </FluentButton>
                </FluentStack>
            </FluentStack>
        </EditForm>
    </FluentCard>
</FluentStack>

@code {
    private readonly CreateEventDto _dto = new() { IsPermanent = true };
    private string _levelStr = "World";
    private string _effectStr = "StatModifier";
    private int? _worldId;
    private int? _campaignId;
    private int? _chapterId;
    private int? _modifierValue;
    private DateTime? _expiresAt;
    private bool _isSaving;
    private string _errorMessage = string.Empty;

    private void OnLevelChanged() =>
        _dto.Level = Enum.TryParse<EventLevel>(_levelStr, out var l) ? l : EventLevel.World;

    private void OnEffectChanged() =>
        _dto.EffectType = Enum.TryParse<EventEffectType>(_effectStr, out var e) ? e : EventEffectType.StatModifier;

    private async Task HandleSubmit()
    {
        _isSaving = true;
        _errorMessage = string.Empty;

        _dto.WorldId = _dto.Level == EventLevel.World ? _worldId : null;
        _dto.CampaignId = _dto.Level == EventLevel.Campaign ? _campaignId : null;
        _dto.ChapterId = _dto.Level == EventLevel.Chapter ? _chapterId : null;
        _dto.ModifierValue = _dto.EffectType != EventEffectType.Narrative ? _modifierValue : null;
        _dto.ExpiresAt = _dto.IsPermanent ? null : _expiresAt;

        var contextIdMissing = (_dto.Level == EventLevel.World && !_dto.WorldId.HasValue)
            || (_dto.Level == EventLevel.Campaign && !_dto.CampaignId.HasValue)
            || (_dto.Level == EventLevel.Chapter && !_dto.ChapterId.HasValue);

        if (contextIdMissing)
        {
            _errorMessage = "Veuillez renseigner l'identifiant du contexte (monde, campagne ou chapitre).";
            _isSaving = false;
            return;
        }

        var created = await EventApiClient.CreateEventAsync(_dto);
        _isSaving = false;

        if (created is not null)
            NavigationManager.NavigateTo($"/events/{created.Id}");
        else
            _errorMessage = "Une erreur est survenue lors de la création de l'événement.";
    }
}
