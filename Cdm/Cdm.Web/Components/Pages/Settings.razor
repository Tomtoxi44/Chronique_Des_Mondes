@page "/settings"
@using Cdm.Web.Components.Layout
@using Cdm.Web.Models
@using Cdm.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout MainLayout
@inject ProfileApiClient ProfileClient
@inject ILogger<Settings> Logger

<PageTitle>Parametres - Chronique des Mondes</PageTitle>

<AuthorizeView>
    <Authorized>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 24px;">
            <!-- Page Header -->
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 4px;">
                <FluentLabel Typo="Typography.H3" Style="color: var(--color-text-primary);">Parametres</FluentLabel>
                <FluentLabel Typo="Typography.Body" Style="color: var(--color-text-secondary);">Gerez vos preferences et parametres de compte</FluentLabel>
            </FluentStack>

            <!-- General Settings -->
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Options())" Color="Color.Accent" />
                        <FluentLabel Typo="Typography.H5">General</FluentLabel>
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Theme</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Choisissez votre theme prefere</FluentLabel>
                            </FluentStack>
                            <FluentSelect TOption="string" @bind-Value="_themeStr" Style="min-width: 150px;">
                                <FluentOption Value="@("dark")">Sombre (Nuit)</FluentOption>
                                <FluentOption Value="@("light")">Clair (Parchemin)</FluentOption>
                                <FluentOption Value="@("auto")">Automatique</FluentOption>
                            </FluentSelect>
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Langue</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Langue de l'interface</FluentLabel>
                            </FluentStack>
                            <FluentSelect TOption="string" @bind-Value="_languageStr" Style="min-width: 150px;">
                                <FluentOption Value="@("fr")">Francais</FluentOption>
                                <FluentOption Value="@("en")">English</FluentOption>
                            </FluentSelect>
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Animations</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Activer les animations de l'interface</FluentLabel>
                            </FluentStack>
                            <FluentSwitch @bind-Value="@animationsEnabled" Label="@(animationsEnabled ? "Active" : "Desactive")" />
                        </FluentStack>
                    </FluentStack>
                </FluentStack>
            </FluentCard>

            <!-- Notifications -->
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Alert())" Color="Color.Accent" />
                        <FluentLabel Typo="Typography.H5">Notifications</FluentLabel>
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Notifications par email</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Recevoir des notifications par email</FluentLabel>
                            </FluentStack>
                            <FluentSwitch @bind-Value="@emailNotifications" Label="@(emailNotifications ? "Active" : "Desactive")" />
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Notifications in-app</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Recevoir des notifications dans l'application</FluentLabel>
                            </FluentStack>
                            <FluentSwitch @bind-Value="@inAppNotifications" Label="@(inAppNotifications ? "Active" : "Desactive")" />
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Sons</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Jouer des sons pour les notifications</FluentLabel>
                            </FluentStack>
                            <FluentSwitch @bind-Value="@soundEnabled" Label="@(soundEnabled ? "Active" : "Desactive")" />
                        </FluentStack>
                    </FluentStack>
                </FluentStack>
            </FluentCard>

            <!-- Game Settings -->
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Cube())" Color="Color.Accent" />
                        <FluentLabel Typo="Typography.H5">Preferences de jeu</FluentLabel>
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Animation des des</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Afficher l'animation lors des lancers de des</FluentLabel>
                            </FluentStack>
                            <FluentSwitch @bind-Value="@diceAnimations" Label="@(diceAnimations ? "Active" : "Desactive")" />
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Confirmations</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Demander confirmation avant les actions importantes</FluentLabel>
                            </FluentStack>
                            <FluentSwitch @bind-Value="@confirmations" Label="@(confirmations ? "Active" : "Desactive")" />
                        </FluentStack>
                    </FluentStack>
                </FluentStack>
            </FluentCard>

            <!-- Account Info -->
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Color="Color.Accent" />
                        <FluentLabel Typo="Typography.H5">Compte</FluentLabel>
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Email</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">
                                    @context.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value
                                </FluentLabel>
                            </FluentStack>
                            <FluentBadge Appearance="Appearance.Neutral">Non modifiable</FluentBadge>
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal" 
                                     VerticalAlignment="VerticalAlignment.Center"
                                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                     Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                            <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                                <FluentLabel Weight="FontWeight.Bold">Identifiant unique</FluentLabel>
                                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 10px; font-family: monospace;">
                                    @context.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                                </FluentLabel>
                            </FluentStack>
                        </FluentStack>
                    </FluentStack>
                </FluentStack>
            </FluentCard>

            <!-- Danger Zone -->
            <FluentCard Style="border: 1px solid var(--error);">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Warning())" Color="Color.Error" />
                        <FluentLabel Typo="Typography.H5" Style="color: var(--error);">Zone de danger</FluentLabel>
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Horizontal" 
                                 VerticalAlignment="VerticalAlignment.Center"
                                 HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                 Style="padding: 12px; background: var(--neutral-layer-2); border-radius: 4px;">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 2px;">
                            <FluentLabel Weight="FontWeight.Bold" Style="color: var(--error);">Supprimer mon compte</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 12px;">Cette action est irreversible. Toutes vos donnees seront supprimees.</FluentLabel>
                        </FluentStack>
                        <FluentButton Appearance="Appearance.Outline" 
                                      IconStart="@(new Icons.Regular.Size20.Delete())"
                                      Disabled="true"
                                      Style="color: var(--error); border-color: var(--error);">
                            Supprimer
                        </FluentButton>
                    </FluentStack>
                </FluentStack>
            </FluentCard>

            <!-- Save Actions -->
            <FluentStack Orientation="Orientation.Horizontal" 
                         VerticalAlignment="VerticalAlignment.Center"
                         HorizontalAlignment="HorizontalAlignment.End"
                         Style="gap: 16px;">
                @if (!string.IsNullOrEmpty(_saveSuccess))
                {
                    <FluentLabel Typo="Typography.Body" Style="color: var(--success, #2ecc71); font-size: 13px;">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())" Style="margin-right: 4px;" />
                        @_saveSuccess
                    </FluentLabel>
                }
                @if (!string.IsNullOrEmpty(_saveError))
                {
                    <FluentLabel Typo="Typography.Body" Style="color: var(--error); font-size: 13px;">@_saveError</FluentLabel>
                }
                <FluentButton Appearance="Appearance.Accent" 
                              IconStart="@(new Icons.Regular.Size20.Checkmark())"
                              @onclick="SaveSettingsAsync"
                              Disabled="@_isSaving">
                    @(_isSaving ? "Sauvegarde..." : "Sauvegarder les modifications")
                </FluentButton>
            </FluentStack>
        </FluentStack>
    </Authorized>
</AuthorizeView>

@code {
    private bool animationsEnabled = true;
    private bool emailNotifications = true;
    private bool inAppNotifications = true;
    private bool soundEnabled = false;
    private bool diceAnimations = true;
    private bool confirmations = true;
    private string _themeStr = "dark";
    private string _languageStr = "fr";
    private bool _isSaving = false;
    private string _saveSuccess = string.Empty;
    private string _saveError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var profile = await ProfileClient.GetProfileAsync();
        if (profile?.Preferences is not null)
        {
            try
            {
                var prefs = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(profile.Preferences);
                if (prefs != null)
                {
                    if (prefs.TryGetValue("theme", out var t)) _themeStr = t.GetString() ?? "dark";
                    if (prefs.TryGetValue("language", out var l)) _languageStr = l.GetString() ?? "fr";
                    if (prefs.TryGetValue("animations", out var a)) animationsEnabled = a.GetBoolean();
                    if (prefs.TryGetValue("emailNotifications", out var en)) emailNotifications = en.GetBoolean();
                    if (prefs.TryGetValue("inAppNotifications", out var ian)) inAppNotifications = ian.GetBoolean();
                    if (prefs.TryGetValue("sound", out var s)) soundEnabled = s.GetBoolean();
                    if (prefs.TryGetValue("diceAnimations", out var da)) diceAnimations = da.GetBoolean();
                    if (prefs.TryGetValue("confirmations", out var c)) confirmations = c.GetBoolean();
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Could not deserialize user preferences");
            }
        }
    }

    private async Task SaveSettingsAsync()
    {
        _isSaving = true;
        _saveSuccess = string.Empty;
        _saveError = string.Empty;

        var prefs = new Dictionary<string, object>
        {
            ["theme"] = _themeStr,
            ["language"] = _languageStr,
            ["animations"] = animationsEnabled,
            ["emailNotifications"] = emailNotifications,
            ["inAppNotifications"] = inAppNotifications,
            ["sound"] = soundEnabled,
            ["diceAnimations"] = diceAnimations,
            ["confirmations"] = confirmations
        };

        var request = new UpdateProfileRequest
        {
            Preferences = JsonSerializer.Serialize(prefs)
        };

        var result = await ProfileClient.UpdateProfileAsync(request);
        _isSaving = false;

        if (result != null)
            _saveSuccess = "Paramètres sauvegardés avec succès.";
        else
            _saveError = "Erreur lors de la sauvegarde. Réessayez.";
    }
}
