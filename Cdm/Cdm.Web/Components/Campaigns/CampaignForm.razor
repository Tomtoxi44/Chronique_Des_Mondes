@using Cdm.Common.Enums
@using Cdm.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations

<EditForm Model="@this.Model" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <FluentValidationSummary />

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="20">
        <!-- Campaign Name -->
        <div>
            <FluentTextField @bind-Value="this.Model.Name"
                            Label="Nom de la campagne"
                            Placeholder="Ex: La Quete du Dragon Pourpre"
                            Required="true"
                            Style="width: 100%;">
                <FluentIcon Value="@(new Icons.Regular.Size20.Bookmark())" Slot="start" />
            </FluentTextField>
            <ValidationMessage For="@(() => this.Model.Name)" />
            <FluentLabel Typo="Typography.Body" Style="font-size: 12px; color: var(--neutral-foreground-hint); margin-top: 4px;">
                Entre 3 et 100 caracteres
            </FluentLabel>
        </div>

        <!-- Campaign Description -->
        <div>
            <FluentTextArea @bind-Value="this.Model.Description"
                           Label="Description"
                           Placeholder="Decrivez l'univers, les objectifs et l'ambiance de votre campagne..."
                           Rows="5"
                           Style="width: 100%;" />
            <ValidationMessage For="@(() => this.Model.Description)" />
            <FluentLabel Typo="Typography.Body" Style="font-size: 12px; color: var(--neutral-foreground-hint); margin-top: 4px;">
                Maximum 5000 caracteres
            </FluentLabel>
        </div>

        <!-- Game Type -->
        <div>
            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="margin-bottom: 8px;">
                <FluentIcon Value="@(new Icons.Regular.Size20.Games())" Style="margin-right: 8px;" />
                Systeme de jeu
            </FluentLabel>
            <FluentSelect TOption="string"
                         Value="@this.Model.GameType.ToString()"
                         ValueChanged="@(value => this.Model.GameType = Enum.Parse<GameType>(value))"
                         Style="width: 100%;">
                <FluentOption Value="@nameof(GameType.Generic)">Generique</FluentOption>
                <FluentOption Value="@nameof(GameType.DnD5e)">Dungeons & Dragons 5e</FluentOption>
                <FluentOption Value="@nameof(GameType.Pathfinder)">Pathfinder</FluentOption>
                <FluentOption Value="@nameof(GameType.CallOfCthulhu)">L'Appel de Cthulhu</FluentOption>
                <FluentOption Value="@nameof(GameType.Warhammer)">Warhammer</FluentOption>
                <FluentOption Value="@nameof(GameType.Skyrim)">Skyrim</FluentOption>
                <FluentOption Value="@nameof(GameType.Custom)">Personnalise</FluentOption>
            </FluentSelect>
            <ValidationMessage For="@(() => this.Model.GameType)" />
        </div>

        <!-- Visibility -->
        <div>
            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="margin-bottom: 8px;">
                <FluentIcon Value="@(new Icons.Regular.Size20.Eye())" Style="margin-right: 8px;" />
                Visibilite
            </FluentLabel>
            <FluentSelect TOption="string"
                         Value="@this.Model.Visibility.ToString()"
                         ValueChanged="@(value => this.Model.Visibility = Enum.Parse<Visibility>(value))"
                         Style="width: 100%;">
                <FluentOption Value="@nameof(Visibility.Private)">Privee (sur invitation uniquement)</FluentOption>
                <FluentOption Value="@nameof(Visibility.Public)">Publique (recherche possible)</FluentOption>
            </FluentSelect>
            <ValidationMessage For="@(() => this.Model.Visibility)" />
        </div>

        <!-- Max Players -->
        <div>
            <FluentNumberField @bind-Value="this.Model.MaxPlayers"
                              Label="Nombre maximum de joueurs"
                              Min="1"
                              Max="20"
                              Style="width: 100%;">
                <FluentIcon Value="@(new Icons.Regular.Size20.People())" Slot="start" />
            </FluentNumberField>
            <ValidationMessage For="@(() => this.Model.MaxPlayers)" />
            <FluentLabel Typo="Typography.Body" Style="font-size: 12px; color: var(--neutral-foreground-hint); margin-top: 4px;">
                Entre 1 et 20 joueurs
            </FluentLabel>
        </div>

        <!-- Cover Image -->
        <div>
            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="margin-bottom: 8px;">
                <FluentIcon Value="@(new Icons.Regular.Size20.Image())" Style="margin-right: 8px;" />
                Image de couverture
            </FluentLabel>
            <ImageUploader OnImageSelected="HandleImageSelected" InputId="campaignCoverInput" />
        </div>

        <!-- Submit Button -->
        <FluentButton Type="ButtonType.Submit"
                      Appearance="Appearance.Accent"
                      Loading="@this.IsSubmitting"
                      Disabled="@this.IsSubmitting"
                      IconStart="@(new Icons.Regular.Size20.AddCircle())"
                      Style="width: 100%;">
            @if (this.IsSubmitting)
            {
                <span>Creation en cours...</span>
            }
            else
            {
                <span>Creer la campagne</span>
            }
        </FluentButton>
    </FluentStack>
</EditForm>

@code {
    /// <summary>
    /// Gets or sets the campaign creation model.
    /// </summary>
    [Parameter]
    public CreateCampaignModel Model { get; set; } = new();

    /// <summary>
    /// Gets or sets a value indicating whether the form is currently submitting.
    /// </summary>
    [Parameter]
    public bool IsSubmitting { get; set; }

    /// <summary>
    /// Event callback when the form is submitted with valid data.
    /// </summary>
    [Parameter]
    public EventCallback OnSubmit { get; set; }

    /// <summary>
    /// Handles image selection from the uploader component.
    /// </summary>
    /// <param name="base64Image">The Base64-encoded image string.</param>
    private void HandleImageSelected(string? base64Image)
    {
        this.Model.CoverImageBase64 = base64Image;
    }

    /// <summary>
    /// Handles form submission when validation succeeds.
    /// </summary>
    private async Task HandleValidSubmit()
    {
        await this.OnSubmit.InvokeAsync();
    }

    /// <summary>
    /// Model for campaign creation form.
    /// </summary>
    public class CreateCampaignModel
    {
        /// <summary>
        /// Gets or sets the campaign name.
        /// </summary>
        [Required(ErrorMessage = "Le nom de la campagne est requis")]
        [StringLength(100, MinimumLength = 3, ErrorMessage = "Le nom doit contenir entre 3 et 100 caracteres")]
        public string Name { get; set; } = string.Empty;

        /// <summary>
        /// Gets or sets the campaign description.
        /// </summary>
        [MaxLength(5000, ErrorMessage = "La description ne peut pas depasser 5000 caracteres")]
        public string? Description { get; set; }

        /// <summary>
        /// Gets or sets the game type.
        /// </summary>
        [Required(ErrorMessage = "Le systeme de jeu est requis")]
        public GameType GameType { get; set; } = GameType.Generic;

        /// <summary>
        /// Gets or sets the visibility level.
        /// </summary>
        public Visibility Visibility { get; set; } = Visibility.Private;

        /// <summary>
        /// Gets or sets the maximum number of players.
        /// </summary>
        [Range(1, 20, ErrorMessage = "Le nombre de joueurs doit etre entre 1 et 20")]
        public int MaxPlayers { get; set; } = 6;

        /// <summary>
        /// Gets or sets the cover image as Base64.
        /// </summary>
        public string? CoverImageBase64 { get; set; }
    }
}
