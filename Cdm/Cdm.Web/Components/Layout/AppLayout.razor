@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Cdm.Web.Components.Shared

<div class="@AppLayoutClass">
    <!-- Sidebar Navigation -->
    <aside class="sidebar @(isCollapsed ? "collapsed" : "") @(isMobileOpen ? "open" : "")" id="sidebar">
        <div class="sidebar-header">
            <a href="/" class="sidebar-logo">
                <div class="sidebar-logo-icon">
                    <img src="/images/LogoCdm.svg" alt="CDM" style="width: 32px; height: 32px;" />
                </div>
                @if (!isCollapsed)
                {
                    <div class="sidebar-logo-text">
                        <span class="sidebar-logo-title">Chronique</span>
                        <span class="sidebar-logo-subtitle">des Mondes</span>
                    </div>
                }
            </a>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-nav-section">
                @if (!isCollapsed)
                {
                    <span class="sidebar-nav-section-title">NAVIGATION</span>
                }
                
                <a href="/" class="sidebar-nav-item @(IsActive("/") ? "active" : "")" title="Accueil">
                    <i class="bi bi-@(IsActive("/") ? "house-door-fill" : "house-door")"></i>
                    @if (!isCollapsed) { <span>Accueil</span> }
                </a>

                <a href="/worlds" class="sidebar-nav-item @(IsActive("/worlds") ? "active" : "")" title="Mondes">
                    <i class="bi bi-@(IsActive("/worlds") ? "globe2" : "globe")"></i>
                    @if (!isCollapsed) { <span>Mondes</span> }
                </a>
                
                <a href="/campaigns" class="sidebar-nav-item @(IsActive("/campaigns") ? "active" : "")" title="Campagnes">
                    <i class="bi bi-@(IsActive("/campaigns") ? "map-fill" : "map")"></i>
                    @if (!isCollapsed) { <span>Campagnes</span> }
                </a>
                
                <a href="/characters" class="sidebar-nav-item @(IsActive("/characters") ? "active" : "")" title="Personnages">
                    <i class="bi bi-@(IsActive("/characters") ? "people-fill" : "people")"></i>
                    @if (!isCollapsed) { <span>Personnages</span> }
                </a>
            </div>
            
            <div class="sidebar-divider"></div>
            
            <div class="sidebar-nav-section">
                @if (!isCollapsed)
                {
                    <span class="sidebar-nav-section-title">COMPTE</span>
                }
                
                <a href="/profile" class="sidebar-nav-item @(IsActive("/profile") ? "active" : "")" title="Profil">
                    <i class="bi bi-person-circle"></i>
                    @if (!isCollapsed) { <span>Mon Profil</span> }
                </a>
                
                <a href="/settings" class="sidebar-nav-item @(IsActive("/settings") ? "active" : "")" title="Paramètres">
                    <i class="bi bi-@(IsActive("/settings") ? "gear-fill" : "gear")"></i>
                    @if (!isCollapsed) { <span>Paramètres</span> }
                </a>
            </div>
        </nav>

        <div class="sidebar-footer">
            <button class="sidebar-toggle-btn" @onclick="ToggleSidebar" title="@(isCollapsed ? "Agrandir le menu" : "Réduire le menu")">
                <i class="bi bi-chevron-@(isCollapsed ? "right" : "left")"></i>
                @if (!isCollapsed) { <span>Réduire</span> }
            </button>
        </div>
    </aside>

    <!-- Mobile Overlay -->
    @if (isMobileOpen)
    {
        <div class="sidebar-overlay" @onclick="CloseMobileSidebar"></div>
    }

    <!-- Main Content Area -->
    <div class="app-main">
        <!-- Top Bar -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="topbar-menu-btn" @onclick="ToggleMobileSidebar" aria-label="Toggle Menu">
                    <i class="bi bi-list"></i>
                </button>
                <span class="topbar-page-title">@GetPageTitle()</span>
            </div>
            
            <div class="topbar-center">
                <div class="topbar-logo">
                    <img src="/images/LogoCdm.svg" alt="CDM Logo" style="width: 36px; height: 36px; object-fit: contain;" />
                    <span>Chronique des Mondes</span>
                </div>
            </div>
            
            <div class="topbar-right">
                <button class="topbar-icon-btn" @onclick="ToggleTheme" title="@(isDarkTheme ? "Mode clair" : "Mode sombre")">
                    <i class="bi bi-@(isDarkTheme ? "sun" : "moon-stars")"></i>
                </button>
                
                <NotificationBell />
                
                <UserMenu />
            </div>
        </header>

        <!-- Fluent UI providers (required for menus, toasts, dialogs, message bars) -->
        <FluentMenuProvider />
        <FluentToastProvider />
        <FluentDialogProvider />
        <FluentMessageBarProvider />

        <!-- Page Content -->
        <main class="app-content">
            @Body
        </main>
    </div>
</div>

<style>
    .topbar-page-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-text-secondary);
        display: none;
    }

    @@media (min-width: 640px) {
        .topbar-page-title {
            display: block;
        }
    }
</style>
