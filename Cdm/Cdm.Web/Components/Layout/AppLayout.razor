@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.FluentUI.AspNetCore.Components
@using Cdm.Web.Components.Shared
@using Cdm.Web.Services
@implements IDisposable

<FluentDesignTheme @bind-Mode="@_themeMode"
                   CustomColor="@ThemeService.GetThemeColor()"
                   StorageName="cdm-theme" />

<div class="cdm-layout">
    <!-- Sidebar -->
    <nav class="cdm-sidebar @(_sidebarExpanded ? "" : "collapsed") @(_mobileOpen ? "mobile-open" : "")">
        <div class="cdm-sidebar-brand">
            <a href="/" class="cdm-sidebar-logo">
                <img src="/images/LogoCdm.svg" alt="CDM" />
                @if (_sidebarExpanded)
                {
                    <FluentStack Orientation="Orientation.Vertical" Style="gap: 0;">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Style="line-height: 1.2;">Chronique</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; line-height: 1.2; font-size: 12px;">des Mondes</FluentLabel>
                    </FluentStack>
                }
            </a>
        </div>

        <FluentNavMenu Width="100" Collapsible="true" @bind-Expanded="@_sidebarExpanded" Title="">
            <FluentNavGroup Title="Navigation" Icon="@(new Icons.Regular.Size20.Navigation())" Expanded="true">
                <FluentNavLink Icon="@(new Icons.Regular.Size20.Home())" Href="/" Match="NavLinkMatch.All">Accueil</FluentNavLink>
                <FluentNavLink Icon="@(new Icons.Regular.Size20.Map())" Href="/campaigns">Campagnes</FluentNavLink>
                <FluentNavLink Icon="@(new Icons.Regular.Size20.People())" Href="/characters">Personnages</FluentNavLink>
            </FluentNavGroup>
            <FluentNavGroup Title="Compte" Icon="@(new Icons.Regular.Size20.PersonAccounts())" Expanded="true">
                <FluentNavLink Icon="@(new Icons.Regular.Size20.Person())" Href="/profile">Mon Profil</FluentNavLink>
                <FluentNavLink Icon="@(new Icons.Regular.Size20.Settings())" Href="/settings">Paramètres</FluentNavLink>
            </FluentNavGroup>
        </FluentNavMenu>
    </nav>

    <!-- Mobile overlay -->
    @if (_mobileOpen)
    {
        <div class="cdm-overlay" @onclick="CloseMobile"></div>
    }

    <!-- Main area -->
    <div class="cdm-main">
        <header class="cdm-header">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="width: 100%; gap: 12px;">
                <FluentButton Appearance="Appearance.Stealth" class="cdm-mobile-toggle" OnClick="ToggleMobile"
                              IconStart="@(new Icons.Regular.Size24.LineHorizontal3())" Title="Menu" />

                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 8px;">
                    <img src="/images/LogoCdm.svg" alt="CDM" style="width: 32px; height: 32px;" />
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Class="cdm-header-title">Chronique des Mondes</FluentLabel>
                </FluentStack>

                <FluentSpacer />

                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 4px;">
                    <FluentButton Appearance="Appearance.Stealth"
                                  Title="@(_themeMode == DesignThemeModes.Dark ? "Mode clair" : "Mode sombre")"
                                  IconStart="@(_themeMode == DesignThemeModes.Dark ? new Icons.Regular.Size20.WeatherSunny() : new Icons.Regular.Size20.WeatherMoon())"
                                  OnClick="ToggleTheme" />
                    <UserMenu />
                </FluentStack>
            </FluentStack>
        </header>

        <main class="cdm-content">
            @Body
        </main>
    </div>
</div>
