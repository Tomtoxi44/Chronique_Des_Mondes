@inherits LayoutComponentBase
@using Cdm.Web.Components.Shared
@using Cdm.Web.Services.State
@inject NavigationManager NavigationManager
@inject CustomAuthStateProvider AuthStateProvider
@inject ThemeService ThemeService
@inject IStringLocalizer<AppStrings> L

<div class="app-layout @(ThemeService.IsDarkMode ? "" : "light-theme")">
    <!-- Sidebar Navigation -->
    <aside class="sidebar @(isCollapsed ? "collapsed" : "") @(isMobileOpen ? "open" : "")" id="sidebar">
        <div class="sidebar-header">
            <a href="/" class="sidebar-logo">
                <div class="sidebar-logo-icon">
                    <img src="/images/LogoCdm.svg" alt="CDM" />
                </div>
                <div class="sidebar-logo-text">
                    <span class="sidebar-logo-title">Chronique</span>
                    <span class="sidebar-logo-subtitle">@L["AppTagline"]</span>
                </div>
            </a>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-nav-section">
                <span class="sidebar-nav-section-title">@L["Nav_Navigation"]</span>
                
                <a href="/" class="sidebar-nav-item @(IsActive("/") ? "active" : "")" title="@L["Nav_Home"]">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Home())" Class="nav-icon" />
                    <span class="nav-label">@L["Nav_Home"]</span>
                </a>
                
                <a href="/worlds" class="sidebar-nav-item @(IsActive("/worlds") ? "active" : "")" title="@L["Nav_Worlds"]">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Globe())" Class="nav-icon" />
                    <span class="nav-label">@L["Nav_Worlds"]</span>
                </a>
                
                <a href="/campaigns" class="sidebar-nav-item @(IsActive("/campaigns") ? "active" : "")" title="@L["Nav_Campaigns"]">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Map())" Class="nav-icon" />
                    <span class="nav-label">@L["Nav_Campaigns"]</span>
                </a>
                
                <a href="/characters" class="sidebar-nav-item @(IsActive("/characters") ? "active" : "")" title="@L["Nav_Characters"]">
                    <FluentIcon Value="@(new Icons.Regular.Size20.People())" Class="nav-icon" />
                    <span class="nav-label">@L["Nav_Characters"]</span>
                </a>
            </div>
            
            <div class="sidebar-divider"></div>
            
            <div class="sidebar-nav-section">
                <span class="sidebar-nav-section-title">@L["Nav_Account"]</span>
                
                <a href="/profile" class="sidebar-nav-item @(IsActive("/profile") ? "active" : "")" title="@L["Nav_Profile"]">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Class="nav-icon" />
                    <span class="nav-label">@L["Nav_Profile"]</span>
                </a>
                
                <a href="/settings" class="sidebar-nav-item @(IsActive("/settings") ? "active" : "")" title="@L["Nav_Settings"]">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Settings())" Class="nav-icon" />
                    <span class="nav-label">@L["Nav_Settings"]</span>
                </a>
            </div>
        </nav>

        <div class="sidebar-footer">
            <button class="sidebar-toggle-btn" @onclick="ToggleSidebar" 
                    title="@(isCollapsed ? L["Nav_Expand"] : L["Nav_Collapse"])">
                <FluentIcon Value="@((Icon)(isCollapsed ? new Icons.Regular.Size16.ChevronRight() : new Icons.Regular.Size16.ChevronLeft()))" />
                <span class="toggle-label">@L["Nav_Collapse"]</span>
            </button>
        </div>
    </aside>

    <!-- Mobile Overlay -->
    @if (isMobileOpen)
    {
        <div class="sidebar-overlay visible" @onclick="CloseMobileSidebar"></div>
    }

    <!-- Main Content Area -->
    <div class="app-main">
        <!-- Top Bar -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="topbar-menu-btn" @onclick="ToggleMobileSidebar" aria-label="Toggle Menu">
                    <FluentIcon Value="@(new Icons.Regular.Size24.Navigation())" />
                </button>
            </div>
            
            <div class="topbar-center">
                @* Breadcrumb space — will be populated by pages *@
            </div>
            
            <div class="topbar-right">
                <FluentSwitch @bind-Value="@darkModeSwitch"
                              @bind-Value:after="OnThemeToggled"
                              Class="theme-toggle"
                              title="@(ThemeService.IsDarkMode ? L["Settings_LightMode"] : L["Settings_DarkMode"])">
                    <FluentIcon Value="@((Icon)(ThemeService.IsDarkMode ? new Icons.Regular.Size16.WeatherMoon() : new Icons.Regular.Size16.WeatherSunny()))" slot="checked-indicator" />
                </FluentSwitch>
                
                <NotificationBell />
                
                <UserMenu />
            </div>
        </header>

        <!-- Page Content -->
        <main class="app-content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool isCollapsed = false;
    private bool isMobileOpen = false;
    private bool darkModeSwitch = true;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        darkModeSwitch = ThemeService.IsDarkMode;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        isMobileOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleSidebar()
    {
        isCollapsed = !isCollapsed;
    }

    private void ToggleMobileSidebar()
    {
        isMobileOpen = !isMobileOpen;
    }

    private void CloseMobileSidebar()
    {
        isMobileOpen = false;
    }

    private void OnThemeToggled()
    {
        ThemeService.ToggleDarkMode();
    }

    private bool IsActive(string href)
    {
        var currentUri = NavigationManager.Uri;
        var baseUri = NavigationManager.BaseUri;
        var relativePath = currentUri.Replace(baseUri, "/").TrimEnd('/');
        
        if (string.IsNullOrEmpty(relativePath)) relativePath = "/";
        
        if (href == "/")
        {
            return relativePath == "/";
        }
        
        return relativePath.StartsWith(href, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
