@inherits LayoutComponentBase

<div class="app-shell" id="app-root">

    <!-- SIDEBAR PRINCIPALE -->
    <aside class="app-sidebar @(IsCollapsed ? "collapsed" : "") @(IsMobileOpen ? "mobile-open" : "") @ContextThemeClass" id="main-sidebar">
        <div class="sidebar-header">
            <a href="/" class="sidebar-brand d-flex align-items-center gap-sm text-decoration-none">
                <img src="/images/LogoCdm.svg" alt="CDM" class="sidebar-logo" />
                <span class="sidebar-brand">@L["AppName"]</span>
            </a>
        </div>

        <nav class="sidebar-nav" aria-label="Navigation principale">
            <span class="nav-section-label">@L["Nav_Navigation"]</span>

            <a href="/" class="nav-item @ActiveClass("/")" title="@L["Nav_Home"]">
                <i class="bi bi-house nav-icon"></i>
                <span class="nav-label">@L["Nav_Home"]</span>
            </a>
            <a href="/worlds" class="nav-item @ActiveClass("/worlds")" title="@L["Nav_Worlds"]">
                <i class="bi bi-globe2 nav-icon"></i>
                <span class="nav-label">@L["Nav_Worlds"]</span>
            </a>
            <a href="/characters" class="nav-item @ActiveClass("/characters")" title="@L["Nav_Characters"]">
                <i class="bi bi-people nav-icon"></i>
                <span class="nav-label">@L["Nav_Characters"]</span>
            </a>
            <a href="/sessions" class="nav-item @ActiveClass("/sessions")" title="@L["Nav_Sessions"]">
                <i class="bi bi-play-circle nav-icon"></i>
                <span class="nav-label">@L["Nav_Sessions"]</span>
            </a>

            <div class="nav-divider"></div>
            <span class="nav-section-label">@L["Nav_Account"]</span>

            <a href="/profile" class="nav-item @ActiveClass("/profile")" title="@L["Nav_Profile"]">
                <i class="bi bi-person nav-icon"></i>
                <span class="nav-label">@L["Nav_Profile"]</span>
            </a>
            <a href="/settings" class="nav-item @ActiveClass("/settings")" title="@L["Nav_Settings"]">
                <i class="bi bi-gear nav-icon"></i>
                <span class="nav-label">@L["Nav_Settings"]</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <button class="sidebar-collapse-btn" @onclick="ToggleSidebar"
                    title="@(IsCollapsed ? L["Nav_Expand"] : L["Nav_Collapse"])">
                <i class="bi @(IsCollapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
                <span class="nav-label" style="font-size: var(--font-size-xs)">
                    @(IsCollapsed ? "" : L["Nav_Collapse"])
                </span>
            </button>
        </div>
    </aside>

    <!-- SIDEBAR SECONDAIRE (contextuelle) -->
    @if (NavContext.HasContext)
    {
        <aside class="app-secondary-sidebar @ContextThemeClass @(GetSecondaryLeft())" id="secondary-sidebar"
               style="left: @(IsCollapsed ? "var(--sidebar-collapsed-width)" : "var(--sidebar-width)")">
            <div class="secondary-sidebar-header">
                @if (!string.IsNullOrEmpty(NavContext.BackHref))
                {
                    <a href="@NavContext.BackHref" class="secondary-back-btn">
                        <i class="bi bi-arrow-left"></i>
                        <span>@NavContext.BackLabel</span>
                    </a>
                }
                <span class="secondary-section-title">@NavContext.SectionTitle</span>
            </div>

            <nav class="secondary-nav" aria-label="Navigation contextuelle">
                @foreach (var item in NavContext.Items)
                {
                    @if (item.IsSection)
                    {
                        <div class="secondary-nav-section-label">@item.Label</div>
                    }
                    else
                    {
                        <div class="secondary-nav-item-row">
                            <a href="@item.Href"
                               class="secondary-nav-item @(item.IsActive ? "active" : "")"
                               title="@item.Label">
                                <i class="bi @item.Icon"></i>
                                <span class="secondary-nav-label">@item.Label</span>
                            </a>
                            @if (item.ToggleKey != null)
                            {
                                <button class="secondary-nav-toggle-btn"
                                        @onclick="async () => { if (NavContext.OnToggleItem != null) await NavContext.OnToggleItem(item.ToggleKey!); }"
                                        title="@(item.IsExpanded ? "Réduire" : "Développer")">
                                    <i class="bi @(item.IsExpanded ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                </button>
                            }
                        </div>
                        @if (item.IsExpanded && item.Children != null)
                        {
                            foreach (var child in item.Children)
                            {
                                <a href="@child.Href"
                                   class="secondary-nav-item secondary-nav-child @(child.IsActive ? "active" : "")"
                                   title="@child.Label">
                                    <i class="bi @child.Icon"></i>
                                    <span>@child.Label</span>
                                </a>
                            }
                        }
                    }
                }
            </nav>
        </aside>
    }

    <!-- OVERLAY MOBILE -->
    @if (IsMobileOpen)
    {
        <div class="sidebar-overlay visible" @onclick="CloseMobile"></div>
    }

    <!-- ZONE PRINCIPALE -->
    <div class="app-main-wrapper @GetMainClass()" id="main-content">

        <!-- TOPBAR -->
        <header class="app-topbar">
            <div class="topbar-left">
                <button class="topbar-icon-btn mobile-menu-btn" @onclick="ToggleMobile"
                        title="Menu" id="mobile-toggle">
                    <i class="bi bi-list"></i>
                </button>
                @if (NavContext.TopbarBreadcrumbs?.Count > 0)
                {
                    <nav class="topbar-breadcrumb" aria-label="Fil d'Ariane">
                        @for (int i = 0; i < NavContext.TopbarBreadcrumbs.Count; i++)
                        {
                            var crumb = NavContext.TopbarBreadcrumbs[i];
                            var isLast = i == NavContext.TopbarBreadcrumbs.Count - 1;
                            if (isLast)
                            {
                                <span class="topbar-breadcrumb-item active">@crumb.Label</span>
                            }
                            else
                            {
                                <a href="@crumb.Href" class="topbar-breadcrumb-item">@crumb.Label</a>
                                <span class="topbar-breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
                            }
                        }
                    </nav>
                }
            </div>

            <div class="topbar-right">
                <!-- Notification bell -->
                <div class="notification-bell-wrapper @(IsNotificationOpen ? "open" : "")">
                    <button class="topbar-icon-btn notification-bell-btn" @onclick="ToggleNotifications"
                            title="Notifications" aria-label="Notifications">
                        <i class="bi bi-bell"></i>
                        @if (UnreadNotificationCount > 0)
                        {
                            <span class="notification-badge">@(UnreadNotificationCount > 9 ? "9+" : UnreadNotificationCount.ToString())</span>
                        }
                    </button>

                    <div class="notification-dropdown">
                        <div class="notification-dropdown-header">
                            <span>Notifications</span>
                            @if (Notifications.Any(n => !n.IsRead))
                            {
                                <button class="btn-link-xs" @onclick="MarkAllNotificationsRead">
                                    Tout marquer lu
                                </button>
                            }
                        </div>

                        @if (IsLoadingNotifications)
                        {
                            <div style="padding: var(--spacing-lg); text-align: center; color: var(--color-text-muted);">
                                <span class="spinner-border spinner-border-sm"></span>
                            </div>
                        }
                        else if (Notifications.Count == 0)
                        {
                            <div style="padding: var(--spacing-lg); text-align: center; color: var(--color-text-muted); font-size: var(--font-size-sm);">
                                <i class="bi bi-bell-slash" style="font-size: 1.5rem; display: block; margin-bottom: var(--spacing-xs);"></i>
                                Aucune notification
                            </div>
                        }
                        else
                        {
                            <div class="notification-list">
                                @foreach (var n in Notifications.Take(8))
                                {
                                    <div class="notification-item @(!n.IsRead ? "unread" : "")"
                                         @onclick="() => NavigateFromNotification(n)">
                                        <div class="notification-icon">
                                            <i class="bi @n.TypeIcon"></i>
                                        </div>
                                        <div class="notification-content">
                                            <div class="notification-title">@n.Title</div>
                                            <div class="notification-message">@n.Message</div>
                                            <div class="notification-time">@n.TimeAgoDisplay</div>
                                        </div>
                                        @if (!n.IsRead)
                                        {
                                            <div class="notification-dot"></div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <button class="topbar-icon-btn" @onclick="ToggleTheme"
                        title="@(IsDarkMode ? L["Settings_LightMode"] : L["Settings_DarkMode"])">
                    <i class="bi @(IsDarkMode ? "bi-sun" : "bi-moon-stars")"></i>
                </button>

                <div class="topbar-dropdown @(IsDropdownOpen ? "open" : "")" id="user-dropdown">
                    <button class="topbar-avatar" @onclick="ToggleDropdown"
                            title="@UserInitials" aria-label="Menu utilisateur">
                        @UserInitials
                    </button>

                    <div class="topbar-dropdown-menu">
                        @if (!string.IsNullOrEmpty(UserName))
                        {
                            <div style="padding: var(--spacing-sm) var(--spacing-md); font-size: var(--font-size-xs); color: var(--color-text-muted);">
                                @UserName
                            </div>
                            <div class="dropdown-divider"></div>
                        }
                        <a href="/profile" class="dropdown-item">
                            <i class="bi bi-person"></i>
                            @L["Nav_Profile"]
                        </a>
                        <a href="/settings" class="dropdown-item">
                            <i class="bi bi-gear"></i>
                            @L["Nav_Settings"]
                        </a>
                        <div class="dropdown-divider"></div>
                        <button class="dropdown-item danger" @onclick="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                            @L["Nav_Logout"]
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <!-- MOBILE CONTEXT NAV (visible uniquement sur mobile quand context actif) -->
        @if (NavContext.HasContext)
        {
            <nav class="mobile-context-nav" aria-label="Navigation contextuelle mobile">
                @foreach (var item in NavContext.Items.Where(i => !i.IsSection))
                {
                    <a href="@item.Href"
                       class="mobile-context-item @(item.IsActive ? "active" : "")"
                       title="@item.Label">
                        <i class="bi @item.Icon"></i>
                        <span>@item.Label</span>
                    </a>
                }
            </nav>
        }

        <!-- CONTENU -->
        <main class="app-content">
            @Body
        </main>
    </div>
</div>

<!-- Aucun script JS nécessaire pour la navigation : tout est géré en C# / CSS -->

