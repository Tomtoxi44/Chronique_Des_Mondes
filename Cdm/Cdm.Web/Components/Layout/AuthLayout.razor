@inherits LayoutComponentBase

<div class="auth-layout">
    <div class="auth-container">
        <div class="auth-logo">
            <img src="/images/logo.png" alt="Chronique des Mondes" class="auth-logo-image" onerror="this.style.display='none'" />
            <h1 class="auth-logo-text">Chronique des Mondes</h1>
            <p class="auth-logo-subtitle">Forgez votre destinée</p>
        </div>
        
        <main class="auth-content">
            @Body
        </main>
        
        <footer class="auth-footer">
            <p>&copy; @DateTime.Now.Year Chronique des Mondes &bull; Tous droits réservés</p>
        </footer>
    </div>
</div>
