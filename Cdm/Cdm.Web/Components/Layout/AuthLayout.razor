@inherits LayoutComponentBase

<FluentDesignTheme Mode="DesignThemeModes.Dark" StorageName="theme" />

<div style="min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--neutral-layer-1) 0%, var(--neutral-layer-3) 100%); padding: 24px;">
    <FluentStack Orientation="Orientation.Vertical" 
                 HorizontalAlignment="HorizontalAlignment.Center" 
                 Style="width: 100%; max-width: 420px;">
        
        <FluentStack Orientation="Orientation.Vertical" 
                     HorizontalAlignment="HorizontalAlignment.Center"
                     Style="margin-bottom: 32px;">
            <img src="/images/LogoCdm.svg" 
                 alt="Chronique des Mondes" 
                 style="width: 80px; height: 80px; margin-bottom: 16px;" />
            <FluentLabel Typo="Typography.H3" Color="Color.Accent" Style="text-align: center;">
                Chronique des Mondes
            </FluentLabel>
            <FluentLabel Typo="Typography.Body" Style="text-align: center; opacity: 0.7;">
                Forgez votre destinee
            </FluentLabel>
        </FluentStack>
        
        @Body
        
        <FluentLabel Typo="Typography.Body" Style="text-align: center; opacity: 0.5; margin-top: 32px; font-size: 12px;">
            @DateTime.Now.Year Chronique des Mondes - Tous droits reserves
        </FluentLabel>
    </FluentStack>
</div>
