@using Microsoft.AspNetCore.Components.Routing

<div class="sidebar-header">
    <a href="" class="sidebar-logo">
        <span class="sidebar-logo-text">CDM</span>
    </a>
</div>

<nav class="sidebar-nav">
    <div class="sidebar-nav-section">
        <span class="sidebar-nav-section-title">Navigation</span>
        
        <NavLink class="sidebar-nav-item" href="" Match="NavLinkMatch.All" data-tooltip="Accueil">
            <i class="bi bi-house-door"></i>
            <span>Accueil</span>
        </NavLink>
        
        <NavLink class="sidebar-nav-item" href="campaigns" data-tooltip="Campagnes">
            <i class="bi bi-map"></i>
            <span>Campagnes</span>
        </NavLink>
        
        <NavLink class="sidebar-nav-item" href="characters" data-tooltip="Personnages">
            <i class="bi bi-people"></i>
            <span>Personnages</span>
        </NavLink>
    </div>
    
    <div class="sidebar-divider"></div>
    
    <div class="sidebar-nav-section">
        <span class="sidebar-nav-section-title">Mon Compte</span>
        
        <NavLink class="sidebar-nav-item" href="profile" data-tooltip="Profil">
            <i class="bi bi-person-circle"></i>
            <span>Mon Profil</span>
        </NavLink>
        
        <NavLink class="sidebar-nav-item" href="settings" data-tooltip="Paramètres">
            <i class="bi bi-gear"></i>
            <span>Paramètres</span>
        </NavLink>
    </div>
</nav>

<div class="sidebar-footer">
    <button class="sidebar-toggle" onclick="toggleSidebarCollapse()" title="Réduire le menu">
        <i class="bi bi-chevron-left"></i>
        <span>Réduire</span>
    </button>
</div>

<script>
    function toggleSidebarCollapse() {
        const sidebar = document.getElementById('sidebar');
        sidebar.classList.toggle('collapsed');
        
        // Save preference
        localStorage.setItem('sidebar-collapsed', sidebar.classList.contains('collapsed'));
    }
    
    // Restore sidebar state on load
    document.addEventListener('DOMContentLoaded', function() {
        const collapsed = localStorage.getItem('sidebar-collapsed') === 'true';
        if (collapsed) {
            const sidebar = document.getElementById('sidebar');
            if (sidebar) {
                sidebar.classList.add('collapsed');
            }
        }
    });
</script>
